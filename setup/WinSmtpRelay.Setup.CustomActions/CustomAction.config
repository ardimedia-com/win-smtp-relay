<?xml version="1.0" encoding="utf-8"?>
<!--
  CLR host configuration for the DTF (SFXCA) managed custom action. Without this, SFXCA tries to load an
  old (v2) CLR and fails on machines that only have .NET Framework 4.x with
  "SFXCA: Failed to get requested CLR info. Error code 0x80131700". useLegacyV2RuntimeActivationPolicy
  lets the v4 runtime host the assembly.
-->
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0.30319" />
  </startup>
</configuration>

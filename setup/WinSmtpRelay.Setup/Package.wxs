<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="WinSmtpRelay $(var.VersionLabel)"
           Manufacturer="ARDIMEDIA"
           Version="$(var.ProductVersion)"
           UpgradeCode="2cbb38d8-5035-40db-b30b-0e55f24ec496"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="WinSmtpRelay — Open-Source SMTP Relay for Windows" />

    <MajorUpgrade Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of WinSmtpRelay is already installed. Please uninstall it first."
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Custom dialog: choose whether the admin UI is reachable from the network. Inserted between
         InstallDirDlg and VerifyReadyDlg. Default off (loopback only) — secure by default. -->
    <UI>
      <Dialog Id="NetworkOptionsDlg" Width="370" Height="270" Title="WIN-SMTP-RELAY Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Options" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Network access and admin-password recovery" />

        <Control Id="NetworkCheckbox" Type="CheckBox" X="20" Y="60" Width="330" Height="18"
                 Property="NETWORKACCESS" CheckBoxValue="1"
                 Text="Make the admin UI reachable from other computers on the network" />
        <Control Id="Info" Type="Text" X="35" Y="82" Width="315" Height="52" Transparent="yes" NoPrefix="yes"
                 Text="Off (recommended): the admin UI binds to 127.0.0.1, reachable only from this computer. On: it binds to the network (all interfaces, or a custom bind address if one is configured) and the admin-port firewall rule is opened. The connection is always HTTPS." />

        <Control Id="ResetPwCheckbox" Type="CheckBox" X="20" Y="145" Width="330" Height="18"
                 Property="RESETADMINPASSWORD" CheckBoxValue="1"
                 Text="Reset administrator access (only if you have lost admin access)" />
        <Control Id="ResetPwInfo" Type="Text" X="35" Y="167" Width="315" Height="58" Transparent="yes" NoPrefix="yes"
                 Text="On the next service start all administrator accounts are removed; you then define a new administrator through first-run setup in the admin UI. Leave this unchecked for normal installs." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Options dialog flow. Fresh install / Change: InstallDirDlg → NetworkOptionsDlg → VerifyReadyDlg.
           Repair: MaintenanceTypeDlg → [Repair] → NetworkOptionsDlg → VerifyReadyDlg, so the operator can set
           network access + password reset just like a normal install. Back returns to InstallDirDlg on a
           fresh install / Change and to MaintenanceTypeDlg on a Repair. -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="NetworkOptionsDlg" Order="10" Condition="WIXUI_INSTALLDIR_VALID=&quot;1&quot;" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="NetworkOptionsDlg" Order="10" />
      <!-- Mark that the operator confirmed the options dialog in THIS run. The execute sequence uses this
           to NOT re-derive NETWORKACCESS from the saved registry state: an unchecked checkbox leaves the
           property empty, which is indistinguishable from "the dialog never ran" without this marker. -->
      <Publish Dialog="NetworkOptionsDlg" Control="Next" Property="WSRUIRAN" Value="1" Order="5" />
      <Publish Dialog="NetworkOptionsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="10" />
      <Publish Dialog="NetworkOptionsDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" Order="10" Condition="NOT (WixUI_InstallMode = &quot;Repair&quot;)" />
      <Publish Dialog="NetworkOptionsDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="20" Condition="WixUI_InstallMode = &quot;Repair&quot;" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="NetworkOptionsDlg" Order="10" Condition="NOT Installed" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="NetworkOptionsDlg" Order="20" Condition="WixUI_InstallMode = &quot;Repair&quot;" />
    </UI>

    <!-- Detect whether the service was running before upgrade (read during AppSearch, before service is stopped) -->
    <Property Id="SERVICEWASRUNNING">
      <RegistrySearch Id="ServiceWasRunningSearch"
                      Root="HKLM"
                      Key="SOFTWARE\ARDIMEDIA\WinSmtpRelay"
                      Name="ServiceRunning"
                      Type="raw" />
    </Property>

    <!-- Exit dialog: post-install info text (admin URL + initial credentials). There is no "start service"
         checkbox: the service is started by ServiceControl Start="install" in the elevated execute sequence.
         The old checkbox ran sc.exe start from the un-elevated UI sequence, where it is denied, so the
         service silently never started. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" Value="WIN-SMTP-RELAY is installed and the service is starting. Open the admin UI at https://localhost:8025 (also added to the Start menu). The built-in certificate is self-signed, so your browser will warn once — you can import a trusted certificate later in the admin UI.  Sign in as admin@local — the one-time initial password is in 'initial-admin-password.txt' in the install folder (also in the Windows Event Log, source WinSmtpRelay.Service)." />

    <!-- Deferred CA: auto-start service during upgrade if it was running before -->
    <CustomAction Id="StartServiceOnUpgrade"
                  Directory="SystemFolder"
                  ExeCommand="sc.exe start WinSmtpRelay"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <!-- Defensive cleanup: stop and delete any leftover WinSmtpRelay service before (re)installing it,
         so a previous failed/crashed install doesn't block ServiceInstall with "service could not be
         installed". Runs as SYSTEM, before InstallServices. net stop BLOCKS until the service reaches
         STOPPED (sc.exe stop only requests the stop asynchronously — deleting a still-stopping service
         marks it for deletion, which is the exact failure this CA exists to prevent). (A service already
         'marked for deletion' by an open handle can only be cleared by a reboot — no installer can
         override that.) -->
    <CustomAction Id="CleanupLeftoverService"
                  Directory="SystemFolder"
                  ExeCommand="cmd.exe /c &quot;net stop WinSmtpRelay &amp; sc.exe delete WinSmtpRelay&quot;"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <!-- Security hardening: the install dir holds the SQLite DB (DKIM keys, smart-host password, the
         imported admin-UI TLS key — DPAPI-LocalMachine protected, which is NOT a boundary between local
         users) and the one-time initial-admin-password.txt. Under Program Files the inherited ACL gives
         BUILTIN\Users read access, so any local user could copy them. Break inheritance and grant only
         SYSTEM, Administrators and the service account (NetworkService) — language-neutral SIDs.
         "[INSTALLFOLDER]." keeps the trailing backslash from escaping the closing quote. -->
    <CustomAction Id="HardenInstallDirAcl"
                  Directory="System64Folder"
                  ExeCommand="icacls.exe &quot;[INSTALLFOLDER].&quot; /inheritance:r /grant:r *S-1-5-18:(OI)(CI)F *S-1-5-32-544:(OI)(CI)F *S-1-5-20:(OI)(CI)F"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <!-- ============================================================
         Managed custom actions: detect ports + write appsettings.Production.json.
         Defaults below apply on upgrades/maintenance (CheckPorts only runs on a fresh install,
         so an upgrade preserves the existing config/port).
         ============================================================ -->
    <Binary Id="WinSmtpRelayCA"
            SourceFile="$(var.WinSmtpRelay.Setup.CustomActions.TargetDir)WinSmtpRelay.Setup.CustomActions.CA.dll" />

    <!-- Secure so the port read by ReadExistingConfig in the (un-elevated) UI sequence flows to the
         (elevated) execute sequence for WriteAdminConfig, preserving the port on a repair. -->
    <Property Id="ADMINUIPORT" Value="8025" Secure="yes" />
    <Property Id="ADMINUIURL" Value="https://localhost:8025" />
    <!-- Set by ReadExistingConfig when the maintenance UI runs; gates whether WriteAdminConfig re-applies the
         port/bind config on a Repair (a silent repair, where the dialog never ran, then preserves the file). -->
    <Property Id="WSRMAINTUI" Secure="yes" />
    <!-- Options-dialog checkboxes, both UNCHECKED by default. No Value on purpose: an MSI CheckBox shows
         CHECKED whenever its property is non-empty, so a "0" default would display as ticked — leaving them
         undefined makes them default to unchecked. Secure="yes" passes the value set in the (un-elevated)
         UI sequence to the (elevated) execute sequence, so the firewall rule / bind address / reset flag
         actually take effect. The checkboxes set the value to "1" when ticked. -->
    <Property Id="NETWORKACCESS" Secure="yes" />
    <Property Id="RESETADMINPASSWORD" Secure="yes" />
    <!-- Set by the options dialog's Next button (see the UI section): the operator confirmed the options
         in THIS run, so the execute sequence must respect the (possibly empty = unchecked) NETWORKACCESS
         instead of re-deriving it from the saved registry state. -->
    <Property Id="WSRUIRAN" Secure="yes" />

    <!-- ============================================================
         Upgrade survival: recover the previous install's admin port and network choice from the
         registry. CheckPorts and ReadExistingConfig do NOT run on a major upgrade (and AppSearch is the
         only thing that runs in a silent repair), so without this the new product would see an empty
         NETWORKACCESS — the AdminUiFirewall component condition would be false, the old product's
         firewall rule would be removed with it, and a network-enabled install would silently lose
         remote admin access on EVERY upgrade while the config still binds to the network.
         "AdminUiPort" is written by the FirewallRules component on every install; "AdminUiFirewall" is
         the key-path value of the conditional firewall component, so it exists exactly when the rule
         is installed (raw DWORD search yields "#1").
         ============================================================ -->
    <Property Id="WSR_SAVEDPORT" Secure="yes">
      <RegistrySearch Id="SavedAdminPortSearch" Root="HKLM"
                      Key="SOFTWARE\ARDIMEDIA\WinSmtpRelay" Name="AdminUiPort" Type="raw" />
    </Property>
    <Property Id="WSR_SAVEDNET" Secure="yes">
      <RegistrySearch Id="SavedNetworkAccessSearch" Root="HKLM"
                      Key="SOFTWARE\ARDIMEDIA\WinSmtpRelay" Name="AdminUiFirewall" Type="raw" />
    </Property>
    <SetProperty Id="ADMINUIPORT" After="AppSearch" Sequence="both" Value="[WSR_SAVEDPORT]"
                 Condition="WSR_SAVEDPORT AND NOT WSRUIRAN" />
    <SetProperty Id="ADMINUIURL" After="AppSearch" Sequence="both" Value="https://localhost:[WSR_SAVEDPORT]"
                 Condition="WSR_SAVEDPORT AND NOT WSRUIRAN" />
    <SetProperty Id="NETWORKACCESS" After="AppSearch" Sequence="both" Value="1"
                 Condition="(WSR_SAVEDNET = &quot;#1&quot;) AND NOT WSRUIRAN" />
    <!-- Maintenance marker: the interactive maintenance UI ran, so WriteAdminConfig may re-apply the
         port/bind config on Repair/Change. Set via the UI sequence (not inside ReadExistingConfig), so a
         SILENT repair keeps its "preserve the file" semantics even now that ReadExistingConfig can also
         run in the execute sequence (legacy upgrade recovery below). -->
    <SetProperty Id="WSRMAINTUI" After="AppSearch" Sequence="ui" Value="1"
                 Condition="Installed AND NOT WIX_UPGRADE_DETECTED" />

    <!-- Immediate: pick a free admin port (8025 → 8125 …), detect port 25, and set
         ADMINUIPORT / ADMINUIURL / PORT25INUSE plus the dynamic exit-dialog text. -->
    <!-- Return="ignore": port detection is an optional convenience. If the managed CA can't run (e.g. an
         old/odd .NET Framework state), the install must still succeed with the default port (8025). -->
    <CustomAction Id="CheckPorts" BinaryRef="WinSmtpRelayCA" DllEntry="CheckPorts"
                  Execute="immediate" Return="ignore" />

    <!-- Immediate: read the existing appsettings.Production.json so the options dialog reflects the
         current state and the admin port is preserved. Runs only when the registry has NO saved port
         (WSR_SAVEDPORT) — i.e. on maintenance/upgrades of a pre-build45 install that never wrote it.
         From build45 on, the registry is the source of truth (readable un-elevated, unlike the
         ACL-hardened install dir). Return="ignore" — optional. -->
    <CustomAction Id="ReadExistingConfig" BinaryRef="WinSmtpRelayCA" DllEntry="ReadExistingConfig"
                  Execute="immediate" Return="ignore" />

    <!-- Deferred: patch appsettings.Production.json (admin Port + BindAddress) in the install dir. Runs on
         a fresh install, on a major UPGRADE (with the registry-recovered or dialog-confirmed values, so a
         toggled checkbox takes effect and a silent upgrade re-applies the previous choice), and on a
         maintenance run that went through the options dialog (WSRMAINTUI) — but not during uninstall.
         The CA merges into the existing file (only the AdminUi keys), so operator overrides survive. -->
    <SetProperty Id="WriteAdminConfig"
                 Value="DIR=[INSTALLFOLDER]|PORT=[ADMINUIPORT]|NET=[NETWORKACCESS]"
                 Before="WriteAdminConfig" Sequence="execute"
                 Condition="(NOT Installed) OR (WSRMAINTUI = &quot;1&quot; AND NOT REMOVE)" />
    <!-- Return="ignore": writing the port/bind override is optional; on failure the service falls back to
         the shipped appsettings.json (port 8025, loopback) — never abort the install. -->
    <CustomAction Id="WriteAdminConfig" BinaryRef="WinSmtpRelayCA" DllEntry="WriteAdminConfig"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Lost-access recovery: when the operator ticks the reset option, set a registry flag the service
         reads on its next start to remove all administrator accounts (the operator then defines a new
         administrator via first-run setup). /reg:64 targets the 64-bit view the service reads. The service
         clears the flag after acting. -->
    <CustomAction Id="SetResetAdminFlag"
                  Directory="System64Folder"
                  ExeCommand="reg.exe add HKLM\SOFTWARE\ARDIMEDIA\WinSmtpRelay /v ResetAdminPassword /t REG_DWORD /d 1 /f /reg:64"
                  Execute="deferred" Return="ignore" Impersonate="no" />

    <!-- Register the SYSTEM updater scheduled task (elevated). This task is the security boundary for the
         unattended self-update: it RE-VERIFIES the staged MSI's Authenticode signature + publisher before
         installing as SYSTEM, so the low-privilege relay account (NetworkService) can hand it a verified
         download without ever gaining SYSTEM code-execution. Mirrors HardenInstallDirAcl: deferred type-34
         CA with [INSTALLFOLDER] in the command (which DOES resolve here, as the Target is formatted at
         script-generation time). -Force overwrites any prior registration on upgrade.

         IMPORTANT — do NOT use a .NET type literal like [System.IO.File]::ReadAllText(...) in a Formatted
         field: MSI treats anything in [square brackets] as a property reference, so [System.IO.File] is
         substituted with the (empty) value of a non-existent property, leaving the broken PowerShell
         "(::ReadAllText(...))" — a parse error that, with Return="ignore", silently never registers the
         task. (This was the real cause of "auto-update never installs": UnregisterUpdateTask removed the
         task on every major upgrade while this CA failed to re-create it.) Use Get-Content -Raw, which has
         no square brackets to collide with. -->
    <CustomAction Id="RegisterUpdateTask"
                  Directory="System64Folder"
                  ExeCommand="powershell.exe -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -Command &quot;Register-ScheduledTask -TaskName 'WinSmtpRelayUpdate' -Xml (Get-Content -Raw -LiteralPath '[INSTALLFOLDER]update-task.xml') -Force&quot;"
                  Execute="deferred" Return="ignore" Impersonate="no" />

    <!-- Remove the updater task on uninstall. -->
    <CustomAction Id="UnregisterUpdateTask"
                  Directory="System64Folder"
                  ExeCommand="powershell.exe -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -Command &quot;Unregister-ScheduledTask -TaskName 'WinSmtpRelayUpdate' -Confirm:$false -ErrorAction SilentlyContinue&quot;"
                  Execute="deferred" Return="ignore" Impersonate="no" />

    <!-- Lock the SYSTEM-only updater staging folder to SYSTEM + Administrators (break inheritance) so the
         low-privilege relay account cannot tamper with the package between the task's signature check and
         the install (TOCTOU). Mirrors HardenInstallDirAcl. "[UpdaterWorkFolder]." keeps the trailing
         backslash from escaping the closing quote. -->
    <CustomAction Id="HardenUpdaterWorkAcl"
                  Directory="System64Folder"
                  ExeCommand="icacls.exe &quot;[UpdaterWorkFolder].&quot; /inheritance:r /grant:r *S-1-5-18:(OI)(CI)F *S-1-5-32-544:(OI)(CI)F"
                  Execute="deferred" Return="ignore" Impersonate="no" />

    <InstallUISequence>
      <Custom Action="CheckPorts" After="CostFinalize"
              Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
      <!-- Legacy recovery (pre-build45 installs only, where no AdminUiPort registry value exists yet):
           maintenance AND major upgrades pre-read the config file so the options dialog reflects the
           current port/bind. On build45+ the registry SetPropertys above already pre-filled them. -->
      <Custom Action="ReadExistingConfig" After="CostFinalize"
              Condition="(Installed OR WIX_UPGRADE_DETECTED) AND NOT WSR_SAVEDPORT" />
    </InstallUISequence>

    <InstallExecuteSequence>
      <Custom Action="CheckPorts" After="CostFinalize"
              Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
      <!-- Legacy recovery for SILENT upgrades from pre-build45 (no saved registry port, no UI ran):
           without this, a silent upgrade would fall back to port 8025 and rewrite a reassigned port.
           NOT WSRUIRAN: when the options dialog ran, its (Secure) values must win — re-reading the file
           here would override e.g. an unchecked network checkbox. -->
      <Custom Action="ReadExistingConfig" After="CostFinalize"
              Condition="(Installed OR WIX_UPGRADE_DETECTED) AND (NOT WSR_SAVEDPORT) AND (NOT WSRUIRAN)" />
      <Custom Action="CleanupLeftoverService" Before="InstallServices"
              Condition="NOT Installed" />
      <Custom Action="WriteAdminConfig" After="InstallFiles"
              Condition="(NOT Installed) OR (WSRMAINTUI = &quot;1&quot; AND NOT REMOVE)" />
      <Custom Action="HardenInstallDirAcl" After="WriteAdminConfig"
              Condition="NOT (REMOVE = &quot;ALL&quot;)" />
      <Custom Action="HardenUpdaterWorkAcl" After="HardenInstallDirAcl"
              Condition="NOT (REMOVE = &quot;ALL&quot;)" />
      <Custom Action="SetResetAdminFlag" After="WriteRegistryValues"
              Condition="RESETADMINPASSWORD = &quot;1&quot;" />
      <Custom Action="StartServiceOnUpgrade"
              After="StartServices"
              Condition="WIX_UPGRADE_DETECTED AND (SERVICEWASRUNNING = &quot;#1&quot;)" />
      <!-- (Re)register the SYSTEM updater task on every install/upgrade, after the task XML is laid down;
           remove it on a full uninstall. -->
      <Custom Action="RegisterUpdateTask" After="StartServices" Condition="NOT REMOVE" />
      <Custom Action="UnregisterUpdateTask" Before="RemoveFiles" Condition="REMOVE = &quot;ALL&quot;" />
    </InstallExecuteSequence>

    <!-- .NET 10 runtime check for framework-dependent variant -->
    <?if $(var.SelfContained) = false ?>
    <Property Id="NETCORERUNTIME10">
      <RegistrySearch Id="NetCore10Search"
                      Root="HKLM"
                      Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedhost"
                      Name="Version"
                      Type="raw" />
    </Property>
    <Launch Condition="Installed OR NETCORERUNTIME10"
            Message="WinSmtpRelay requires the .NET 10 Runtime (x64). Please download and install it from https://dotnet.microsoft.com/download/dotnet/10.0 and run this installer again." />
    <?endif?>

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="WinSmtpRelay" />
    </StandardDirectory>
    <!-- Start menu (All Users) — holds the admin-UI shortcut -->
    <StandardDirectory Id="ProgramMenuFolder" />

    <!-- Single feature containing all components -->
    <Feature Id="Complete" Title="WinSmtpRelay" Level="1">
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="ConfigComponent" />
      <ComponentRef Id="FirewallRules" />
      <ComponentRef Id="AdminUiFirewall" />
      <ComponentRef Id="EventLogSource" />
      <ComponentRef Id="InstallDirPermissions" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="UpdateDropFolderComponent" />
      <ComponentRef Id="UpdaterWorkFolderComponent" />
      <ComponentRef Id="UpdaterTaskFile" />

      <!-- Auto-harvested published files -->
      <Files Directory="INSTALLFOLDER" Include="$(var.HarvestPath)**">
        <Exclude Files="$(var.HarvestPath)appsettings.json" />
        <Exclude Files="$(var.HarvestPath)appsettings.Development.json" />
        <Exclude Files="$(var.HarvestPath)WinSmtpRelay.Service.exe" />
      </Files>
    </Feature>

  </Package>

</Wix>

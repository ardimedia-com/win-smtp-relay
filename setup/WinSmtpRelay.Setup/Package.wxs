<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="WinSmtpRelay $(var.VersionLabel)"
           Manufacturer="ARDIMEDIA"
           Version="$(var.ProductVersion)"
           UpgradeCode="2cbb38d8-5035-40db-b30b-0e55f24ec496"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="WinSmtpRelay — Open-Source SMTP Relay for Windows" />

    <MajorUpgrade Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of WinSmtpRelay is already installed. Please uninstall it first."
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Custom dialog: choose whether the admin UI is reachable from the network. Inserted between
         InstallDirDlg and VerifyReadyDlg. Default off (loopback only) — secure by default. -->
    <UI>
      <Dialog Id="NetworkOptionsDlg" Width="370" Height="270" Title="WIN-SMTP-RELAY Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Admin UI network access" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Who may reach the admin web interface" />

        <Control Id="NetworkCheckbox" Type="CheckBox" X="20" Y="65" Width="330" Height="18"
                 Property="NETWORKACCESS" CheckBoxValue="1"
                 Text="Make the admin UI reachable from other computers on the network" />
        <Control Id="Info" Type="Text" X="35" Y="88" Width="315" Height="100" Transparent="yes" NoPrefix="yes"
                 Text="Off (recommended): the admin UI binds to 127.0.0.1 and is reachable only from this computer.&#xD;&#xA;&#xD;&#xA;On: it binds to all network interfaces and the firewall is opened for the admin port, so you can manage it from another machine. The connection is always HTTPS (a self-signed certificate until you import a trusted one in the admin UI)." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Flow: InstallDirDlg → NetworkOptionsDlg → VerifyReadyDlg (higher Order overrides the defaults). -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="NetworkOptionsDlg" Order="10" Condition="WIXUI_INSTALLDIR_VALID=&quot;1&quot;" />
      <Publish Dialog="NetworkOptionsDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" Order="10" />
      <Publish Dialog="NetworkOptionsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="10" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="NetworkOptionsDlg" Order="10" Condition="NOT Installed" />
    </UI>

    <!-- Detect whether the service was running before upgrade (read during AppSearch, before service is stopped) -->
    <Property Id="SERVICEWASRUNNING">
      <RegistrySearch Id="ServiceWasRunningSearch"
                      Root="HKLM"
                      Key="SOFTWARE\ARDIMEDIA\WinSmtpRelay"
                      Name="ServiceRunning"
                      Type="raw" />
    </Property>

    <!-- Exit dialog: admin URL text + "Start service now?" checkbox -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" Value="WIN-SMTP-RELAY is installed. Open the admin UI at https://localhost:8025 (also added to the Start menu). The built-in certificate is self-signed, so your browser will warn once — you can import a trusted certificate later in the admin UI.  Sign in as admin@local — the one-time initial password is in 'initial-admin-password.txt' in the install folder (also in the Windows Event Log, source WinSmtpRelay.Service)." />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Start WinSmtpRelay service now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- On upgrade where service was NOT running: uncheck the exit dialog checkbox -->
    <SetProperty Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX"
                 Value="{}"
                 Before="CostFinalize"
                 Sequence="ui"
                 Condition="WIX_UPGRADE_DETECTED AND NOT (SERVICEWASRUNNING = &quot;#1&quot;)" />

    <!-- WixUI ExitDlg triggers DoAction "LaunchApplication" when checkbox is checked -->
    <CustomAction Id="LaunchApplication"
                  Directory="SystemFolder"
                  ExeCommand="sc.exe start WinSmtpRelay"
                  Execute="immediate"
                  Return="ignore"
                  Impersonate="no" />

    <!-- Deferred CA: auto-start service during upgrade if it was running before -->
    <CustomAction Id="StartServiceOnUpgrade"
                  Directory="SystemFolder"
                  ExeCommand="sc.exe start WinSmtpRelay"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <!-- Defensive cleanup: stop and delete any leftover WinSmtpRelay service before (re)installing it,
         so a previous failed/crashed install doesn't block ServiceInstall with "service could not be
         installed". Runs as SYSTEM, before InstallServices. (A service already 'marked for deletion' by
         an open handle can only be cleared by a reboot — no installer can override that.) -->
    <CustomAction Id="CleanupLeftoverService"
                  Directory="SystemFolder"
                  ExeCommand="cmd.exe /c &quot;sc.exe stop WinSmtpRelay &amp; sc.exe delete WinSmtpRelay&quot;"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <!-- ============================================================
         Managed custom actions: detect ports + write appsettings.Production.json.
         Defaults below apply on upgrades/maintenance (CheckPorts only runs on a fresh install,
         so an upgrade preserves the existing config/port).
         ============================================================ -->
    <Binary Id="WinSmtpRelayCA"
            SourceFile="$(var.WinSmtpRelay.Setup.CustomActions.TargetDir)WinSmtpRelay.Setup.CustomActions.CA.dll" />

    <Property Id="ADMINUIPORT" Value="8025" />
    <Property Id="ADMINUIURL" Value="https://localhost:8025" />
    <!-- Admin-UI network exposure: off by default (loopback only); the Network options dialog sets it to 1. -->
    <Property Id="NETWORKACCESS" Value="0" />

    <!-- Immediate: pick a free admin port (8025 → 8125 …), detect port 25, and set
         ADMINUIPORT / ADMINUIURL / PORT25INUSE plus the dynamic exit-dialog text. -->
    <!-- Return="ignore": port detection is an optional convenience. If the managed CA can't run (e.g. an
         old/odd .NET Framework state), the install must still succeed with the default port (8025). -->
    <CustomAction Id="CheckPorts" BinaryRef="WinSmtpRelayCA" DllEntry="CheckPorts"
                  Execute="immediate" Return="ignore" />

    <!-- Deferred: write appsettings.Production.json (admin Port + BindAddress) into the install dir. -->
    <SetProperty Id="WriteAdminConfig"
                 Value="DIR=[INSTALLFOLDER]|PORT=[ADMINUIPORT]|NET=[NETWORKACCESS]"
                 Before="WriteAdminConfig" Sequence="execute"
                 Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
    <!-- Return="ignore": writing the port/bind override is optional; on failure the service falls back to
         the shipped appsettings.json (port 8025, loopback) — never abort the install. -->
    <CustomAction Id="WriteAdminConfig" BinaryRef="WinSmtpRelayCA" DllEntry="WriteAdminConfig"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <InstallUISequence>
      <Custom Action="CheckPorts" After="CostFinalize"
              Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
    </InstallUISequence>

    <InstallExecuteSequence>
      <Custom Action="CheckPorts" After="CostFinalize"
              Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
      <Custom Action="CleanupLeftoverService" Before="InstallServices"
              Condition="NOT Installed" />
      <Custom Action="WriteAdminConfig" After="InstallFiles"
              Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED" />
      <Custom Action="StartServiceOnUpgrade"
              After="StartServices"
              Condition="WIX_UPGRADE_DETECTED AND (SERVICEWASRUNNING = &quot;#1&quot;)" />
    </InstallExecuteSequence>

    <!-- .NET 10 runtime check for framework-dependent variant -->
    <?if $(var.SelfContained) = false ?>
    <Property Id="NETCORERUNTIME10">
      <RegistrySearch Id="NetCore10Search"
                      Root="HKLM"
                      Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedhost"
                      Name="Version"
                      Type="raw" />
    </Property>
    <Launch Condition="Installed OR NETCORERUNTIME10"
            Message="WinSmtpRelay requires the .NET 10 Runtime (x64). Please download and install it from https://dotnet.microsoft.com/download/dotnet/10.0 and run this installer again." />
    <?endif?>

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="WinSmtpRelay" />
    </StandardDirectory>
    <!-- Start menu (All Users) — holds the admin-UI shortcut -->
    <StandardDirectory Id="ProgramMenuFolder" />

    <!-- Single feature containing all components -->
    <Feature Id="Complete" Title="WinSmtpRelay" Level="1">
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="ConfigComponent" />
      <ComponentRef Id="FirewallRules" />
      <ComponentRef Id="AdminUiFirewall" />
      <ComponentRef Id="EventLogSource" />
      <ComponentRef Id="InstallDirPermissions" />
      <ComponentRef Id="StartMenuShortcut" />

      <!-- Auto-harvested published files -->
      <Files Directory="INSTALLFOLDER" Include="$(var.HarvestPath)**">
        <Exclude Files="$(var.HarvestPath)appsettings.json" />
        <Exclude Files="$(var.HarvestPath)appsettings.Development.json" />
        <Exclude Files="$(var.HarvestPath)WinSmtpRelay.Service.exe" />
      </Files>
    </Feature>

  </Package>

</Wix>

{
  "ConnectionStrings": {
    "RelayDb": "Data Source=winsmtprelay.db"
  },
  "SmtpListener": {
    "Endpoints": [
      {
        "Address": "0.0.0.0",
        "Port": 25,
        "RequireTls": false,
        "ImplicitTls": false,
        "RequireAuth": false
      }
    ],
    "MaxMessageSizeBytes": 26214400,
    "MaxConnections": 100,
    "AllowedNetworks": [
      "10.0.0.0/8",
      "192.168.0.0/16",
      "172.16.0.0/12",
      "127.0.0.1/32"
    ],
    "AcceptedDomains": []
  },
  "Tls": {
    "CertificatePath": null,
    "CertificatePassword": null,
    "CertificateThumbprint": null
  },
  "AdminUi": {
    "Enabled": true,
    "Port": 8025,
    "BindAddress": "127.0.0.1",
    "UseHttps": true,
    "CertificatePath": null,
    "CertificatePassword": null,
    "SelfServiceSignupEnabled": false,
    "SignupFromAddress": null
  },
  "Dkim": {
    "Enabled": false,
    "Domains": []
  },
  "Dns": {
    "PublicHostname": null,
    "SendingIpAddresses": [],
    "SpfIncludes": [],
    "SpfAllQualifier": "~all",
    "DmarcReportEmail": null,
    "DmarcPolicy": "none",
    "DmarcPercentage": 100
  },
  "EmailAuthentication": {
    "SpfEnabled": false,
    "DmarcEnabled": false,
    "Enforcement": "LogOnly"
  },
  "Statistics": {
    "RetentionDays": 90,
    "AggregationTimeUtc": "00:00"
  },
  "DataRetention": {
    "Profile": "Standard",
    "StripBodyOnDelivery": true,
    "MessageHistoryDays": 30,
    "DeliveryLogDays": 90,
    "SuppressionDays": 0
  },
  "Delivery": {
    "MaxConcurrentDeliveries": 4,
    "MaxRetryHours": 48,
    "RetryIntervalsMinutes": [1, 5, 30, 120, 480, 1440],
    "SmartHost": null,
    "OpportunisticTls": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "EventLog": {
      "SourceName": "WinSmtpRelay",
      "LogName": "Application"
    }
  }
}

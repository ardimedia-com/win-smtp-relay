@page "/settings"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Configuration
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject IServiceScopeFactory ScopeFactory
@inject WinSmtpRelay.AdminUi.Services.PublicIpDetector IpDetector

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Settings</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>Settings</h1>
    <p>Host-level portal settings. Applied immediately — no restart required.</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[160px] w-full" />
}
else
{
    <BbTabs DefaultValue="dns" @bind-Value="activeTab">
        <BbTabsList>
            <BbTabsTrigger Value="dns">Sending identity</BbTabsTrigger>
            <BbTabsTrigger Value="email-auth">Email auth</BbTabsTrigger>
            <BbTabsTrigger Value="signup">Signup</BbTabsTrigger>
            <BbTabsTrigger Value="backup-mx">Backup MX</BbTabsTrigger>
            <BbTabsTrigger Value="statistics">Statistics</BbTabsTrigger>
            <BbTabsTrigger Value="reporting">Reporting</BbTabsTrigger>
        </BbTabsList>

        <BbTabsContent Value="signup">
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Self-service signup</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="settings-group">
                <div class="settings-group-title">Self-service signup</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <BbSwitch Checked="signupEnabled" CheckedChanged="OnToggleAsync" id="signup-toggle" AriaLabel="Allow anonymous organizations to sign up" />
                    <span>Allow anonymous organizations to sign up at <span class="mono">/signup</span></span>
                </div>
                <p class="text-muted" style="font-size:0.8rem;margin-top:0.75rem;margin-bottom:0;">
                    When enabled, a "Create an organization" link appears on the sign-in page. A new signup creates a
                    <strong>disabled</strong> tenant that must be confirmed by email verification or host approval before it can sign in.
                </p>
            </div>

            <div class="settings-group">
                <div class="settings-group-title">Verification email</div>
                <div class="form-group" style="margin-bottom:0;">
                    <BbLabel For="from-address">From-address</BbLabel>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <BbInput Id="from-address" @bind-Value="signupFromAddress" Placeholder="noreply@yourdomain.tld" />
                        <BbButton Variant="ButtonVariant.Default" @onclick="SaveFromAddressAsync">
                            <LucideIcon Name="save" /> Save
                        </BbButton>
                    </div>
                    <p class="text-muted" style="font-size:0.8rem;margin-top:0.5rem;margin-bottom:0;">
                        From-address for signup verification and password-reset emails, sent through this relay's own
                        delivery pipeline. Leave blank to use the <span class="mono">appsettings</span> value. The domain
                        should be one this relay is configured to send for (accepted sender domain, ideally with DKIM).
                    </p>
                </div>
            </div>

            <div class="settings-group">
                <div class="settings-group-title">Abuse protection</div>
                <div class="form-group" style="margin-bottom:0;">
                    <BbLabel For="signup-attempts-per-ip-per-hour">Signup attempts per IP per hour</BbLabel>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <BbInput Id="signup-attempts-per-ip-per-hour" Type="InputType.Number" @bind-Value="signupMaxPerHour" />
                        <BbButton Variant="ButtonVariant.Default" @onclick="SaveThrottleAsync">
                            <LucideIcon Name="save" /> Save
                        </BbButton>
                    </div>
                    <p class="text-muted" style="font-size:0.8rem;margin-top:0.5rem;margin-bottom:0;">
                        Abuse limit on the anonymous signup page, per client IP. Set to <span class="mono">0</span> to disable the throttle.
                    </p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@statusMessage</p>
            }
        </BbCardContent>
    </BbCard>
        </BbTabsContent>

        <BbTabsContent Value="email-auth">
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Inbound email authentication</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="settings-group">
                <div class="settings-group-title">Inbound checks</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <BbSwitch Checked="spfEnabled" CheckedChanged="(bool v) => spfEnabled = v" id="spf-toggle" AriaLabel="Run SPF checks on inbound mail" />
                    <span>Run SPF checks on inbound mail</span>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;margin-top:0.5rem;">
                    <BbSwitch Checked="dmarcEnabled" CheckedChanged="(bool v) => dmarcEnabled = v" id="dmarc-toggle" AriaLabel="Run DMARC checks on inbound mail" />
                    <span>Run DMARC checks on inbound mail</span>
                </div>
                <div class="form-group" style="margin-top:1rem;">
                    <BbLabel For="enforcement">Enforcement on failure</BbLabel>
                    <select class="account-input" id="enforcement" @bind="enforcement">
                        <option value="@EnforcementMode.LogOnly">Log only — accept and record the result</option>
                        <option value="@EnforcementMode.Reject">Reject — return 550 on SPF/DMARC failure</option>
                        <option value="@EnforcementMode.Quarantine">Quarantine — accept but flag the message</option>
                    </select>
                </div>
            </div>

            <div class="settings-group">
                <div class="settings-group-title">Domain ownership</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <BbSwitch Checked="requireSenderVerification" CheckedChanged="(bool v) => requireSenderVerification = v" id="require-sender-verify" AriaLabel="Require verified ownership for accepted sender domains" />
                    <span>Require verified ownership for accepted <strong>sender</strong> domains</span>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;margin-top:0.5rem;">
                    <BbSwitch Checked="requireRecipientVerification" CheckedChanged="(bool v) => requireRecipientVerification = v" id="require-recipient-verify" AriaLabel="Require verified ownership for accepted recipient domains" />
                    <span>Require verified ownership for accepted <strong>recipient</strong> domains</span>
                </div>
                <p class="text-muted" style="font-size:0.78rem;margin-top:0.35rem;margin-bottom:0;">
                    When on, a configured domain must have its ownership verified (a DNS TXT record, checked on the
                    Accepted Domains pages) before the relay accepts mail from/for it. Applies only among configured
                    domains — an empty list still means "accept all", and backup-MX domains are unaffected.
                </p>
            </div>

            <div class="settings-group">
                <div class="settings-group-title">Tenant binding (unauthenticated submission)</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <BbSwitch Checked="bindTenantToAllowIpRule" CheckedChanged="(bool v) => bindTenantToAllowIpRule = v" id="bind-tenant-ip" AriaLabel="Bind the tenant to the matching allow IP rule" />
                    <span>Bind the tenant to the matching allow IP rule (reject cross-tenant sender domains)</span>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;margin-top:0.5rem;">
                    <BbSwitch Checked="rejectUnresolvedTenant" CheckedChanged="(bool v) => rejectUnresolvedTenant = v" id="reject-unresolved-tenant" AriaLabel="Reject when no tenant can be determined" />
                    <span>Reject when no tenant can be determined (instead of using the default tenant)</span>
                </div>
                <p class="text-muted" style="font-size:0.78rem;margin-top:0.35rem;margin-bottom:0;">
                    For mail submitted <strong>without SMTP AUTH</strong>: by default the tenant is guessed from the
                    MAIL FROM domain (falling back to the default tenant). The first toggle instead derives the tenant
                    from the tenant's own allow IP rule and rejects a MAIL FROM domain owned by another tenant — closing
                    cross-tenant spoofing. A client allowed only by a host-wide (shared) IP rule isn't bound to any
                    tenant: it may send only as an unclaimed/host domain, otherwise it's rejected — give each tenant
                    its own allow IP rule, or use SMTP AUTH. The second toggle rejects mail that can't be attributed at
                    all. Authenticated sessions are unaffected (their tenant comes from the SMTP user).
                </p>
            </div>

            <BbButton Variant="ButtonVariant.Default" @onclick="SaveEmailAuthAsync" Class="mt-1">
                <LucideIcon Name="save" /> Save
            </BbButton>
            @if (!string.IsNullOrEmpty(emailAuthStatus))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@emailAuthStatus</p>
            }
        </BbCardContent>
    </BbCard>
        </BbTabsContent>

        <BbTabsContent Value="backup-mx">
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Backup MX</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="settings-group">
                <div class="settings-group-title">Backup MX</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <BbSwitch Checked="bmEnabled" CheckedChanged="(bool v) => bmEnabled = v" id="backupmx-toggle" AriaLabel="Accept and hold mail for backup-MX domains when the primary is unreachable" />
                    <span>Accept and hold mail for backup-MX domains when the primary is unreachable</span>
                </div>
                <div class="form-group" style="margin-top:1rem;margin-bottom:0;">
                    <BbLabel For="backup-mx-domains">Backup-MX domains</BbLabel>
                    <BbInput Id="backup-mx-domains" @bind-Value="bmDomains" Placeholder="example.com; example.net" />
                </div>
            </div>

            <div class="settings-group">
                <div class="settings-group-title">Retry policy</div>
                <div class="form-grid">
                    <div class="form-group">
                        <BbLabel For="retry-interval">Retry interval (minutes)</BbLabel>
                        <BbInput Id="retry-interval" Type="InputType.Number" @bind-Value="bmRetryInterval" />
                    </div>
                    <div class="form-group">
                        <BbLabel For="max-hold-time">Max hold time (hours)</BbLabel>
                        <BbInput Id="max-hold-time" Type="InputType.Number" @bind-Value="bmMaxHold" />
                    </div>
                </div>
            </div>

            <BbButton Variant="ButtonVariant.Default" @onclick="SaveBackupMxAsync" Class="mt-1">
                <LucideIcon Name="save" /> Save
            </BbButton>
            @if (!string.IsNullOrEmpty(backupMxStatus))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@backupMxStatus</p>
            }
        </BbCardContent>
    </BbCard>
        </BbTabsContent>

        <BbTabsContent Value="statistics">
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Statistics retention</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="settings-group">
                <div class="settings-group-title">Retention</div>
                <div class="form-grid">
                    <div class="form-group">
                        <BbLabel For="retention">Retention (days)</BbLabel>
                        <BbInput Id="retention" Type="InputType.Number" @bind-Value="statRetentionDays" />
                    </div>
                    <div class="form-group">
                        <BbLabel For="daily-aggregation-time">Daily aggregation time (UTC, HH:mm)</BbLabel>
                        <BbInput Id="daily-aggregation-time" @bind-Value="statAggTime" Placeholder="00:00" />
                    </div>
                </div>
                <p class="text-muted" style="font-size:0.8rem;margin-top:0.25rem;margin-bottom:0;">
                    Daily statistics older than the retention window are purged by the background aggregator, which runs at the configured UTC time.
                </p>
            </div>
            <BbButton Variant="ButtonVariant.Default" @onclick="SaveStatisticsAsync" Class="mt-1">
                <LucideIcon Name="save" /> Save
            </BbButton>
            @if (!string.IsNullOrEmpty(statisticsStatus))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@statisticsStatus</p>
            }
        </BbCardContent>
    </BbCard>
        </BbTabsContent>

        <BbTabsContent Value="dns">
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>DNS recommendations (SPF / DMARC)</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <p class="text-muted" style="font-size:0.8rem;margin-bottom:0.75rem;">
                These describe the relay's sending identity and drive the recommended records shown on the
                <a href="/deliverability">Deliverability</a> page. They don't change how mail is processed.
            </p>
            <div class="settings-group">
                <div class="settings-group-title">Basic</div>
                <div class="form-group">
                    <BbLabel For="public-hostname">Public hostname</BbLabel>
                    <BbInput Id="public-hostname" @bind-Value="dnsPublicHostname" Placeholder="relay.example.com" />
                </div>
                <div class="form-group" style="margin-top:0.75rem;">
                    <BbLabel For="sending-ip-addresses">Sending IP addresses (delimited)</BbLabel>
                    <BbInput Id="sending-ip-addresses" @bind-Value="dnsSendingIps" Placeholder="203.0.113.10; 2001:db8::1" />
                    <div style="margin-top:0.35rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;font-size:0.8rem;">
                        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="DetectIpAsync" Disabled="@detectingIp">
                            <LucideIcon Name="globe" /> @(detectingIp ? "Detecting…" : "Detect public IP")
                        </BbButton>
                        @foreach (var ip in detectedIps)
                        {
                            var alreadyAdded = SendingIpsContains(ip);
                            <span class="mono text-muted">@ip</span>
                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" @onclick="() => AddDetectedIp(ip)" Disabled="@alreadyAdded">
                                @(alreadyAdded ? "Added" : "Add")
                            </BbButton>
                        }
                        @if (detectedNone)
                        {
                            <span class="text-muted">Could not detect a public IP (no internet, or the lookup was blocked).</span>
                        }
                    </div>
                    <p class="text-muted" style="font-size:0.75rem;margin-top:0.25rem;">Detected by asking an external service (api.ipify.org) for this server's public address — a proposal; confirm it's the IP your outbound mail actually uses.</p>
                </div>
            </div>
            <div class="settings-group">
                <div class="settings-group-title">SPF</div>
                <div class="form-group">
                    <BbLabel For="spf-includes">SPF includes (delimited)</BbLabel>
                    <BbInput Id="spf-includes" @bind-Value="dnsSpfIncludes" Placeholder="_spf.example.net" />
                </div>
                <div class="form-group" style="margin-top:0.75rem;">
                    <BbLabel For="spf-all">SPF "all" qualifier</BbLabel>
                    <select class="account-input" id="spf-all" @bind="dnsSpfAll">
                        <option value="~all">~all (softfail)</option>
                        <option value="-all">-all (hardfail)</option>
                    </select>
                </div>
            </div>
            <div class="settings-group">
                <div class="settings-group-title">DMARC</div>
                <div class="form-group">
                    <BbLabel For="dmarc-report-address">DMARC report address (rua)</BbLabel>
                    <BbInput Id="dmarc-report-address" @bind-Value="dnsDmarcEmail" Placeholder="dmarc@example.com" />
                </div>
                <div class="form-group" style="margin-top:0.75rem;">
                    <BbLabel For="dmarc-policy">DMARC policy</BbLabel>
                    <select class="account-input" id="dmarc-policy" @bind="dnsDmarcPolicy">
                        <option value="none">none</option>
                        <option value="quarantine">quarantine</option>
                        <option value="reject">reject</option>
                    </select>
                </div>
                <div class="form-group" style="margin-top:0.75rem;">
                    <BbLabel For="dmarc-percentage">DMARC percentage (1-100)</BbLabel>
                    <BbInput Id="dmarc-percentage" Type="InputType.Number" @bind-Value="dnsDmarcPct" />
                </div>
            </div>
            <BbButton Variant="ButtonVariant.Default" @onclick="SaveDnsAsync" Class="mt-1">
                <LucideIcon Name="save" /> Save
            </BbButton>
            @if (!string.IsNullOrEmpty(dnsStatus))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@dnsStatus</p>
            }
        </BbCardContent>
    </BbCard>
        </BbTabsContent>

        <BbTabsContent Value="reporting">
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Email reporting</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="settings-group">
                <div class="settings-group-title">Reports &amp; alerts</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <BbSwitch Checked="reportEnabled" CheckedChanged="(bool v) => reportEnabled = v" id="report-toggle" AriaLabel="Send a daily activity digest and immediate incident alerts" />
                    <span>Send a daily activity digest and immediate incident alerts</span>
                </div>
                <p class="text-muted" style="font-size:0.8rem;margin-top:0.5rem;margin-bottom:0;">
                    Immediate alerts: a sending IP getting blocklisted (DNSBL), or the 24-hour bounce rate exceeding the
                    threshold below. The daily digest summarises volume, bounce/suppression counts and blocklist status.
                    All sent through this relay's own delivery pipeline.
                </p>
            </div>
            <div class="settings-group">
                <div class="settings-group-title">Delivery</div>
                <div class="form-grid">
                    <div class="form-group">
                        <BbLabel For="report-recipient">Report recipient</BbLabel>
                        <BbInput Id="report-recipient" @bind-Value="reportRecipient" Placeholder="ops@yourdomain.tld" />
                    </div>
                    <div class="form-group">
                        <BbLabel For="report-from">From-address (optional)</BbLabel>
                        <BbInput Id="report-from" @bind-Value="reportFrom" Placeholder="(uses the signup from-address)" />
                    </div>
                    <div class="form-group">
                        <BbLabel For="daily-digest-time">Daily digest time (UTC, HH:mm)</BbLabel>
                        <BbInput Id="daily-digest-time" @bind-Value="reportDailyTime" Placeholder="06:00" />
                    </div>
                    <div class="form-group">
                        <BbLabel For="bounce-rate-alert-threshold">Bounce-rate alert threshold (%)</BbLabel>
                        <BbInput Id="bounce-rate-alert-threshold" Type="InputType.Number" @bind-Value="reportBounceThreshold" />
                    </div>
                </div>
                <p class="text-muted" style="font-size:0.8rem;margin-top:0.25rem;margin-bottom:0;">
                    The recipient is required. Leave the from-address blank to use the signup/system from-address.
                    Set the threshold to <span class="mono">0</span> to disable the bounce-rate alert.
                </p>
            </div>
            <BbButton Variant="ButtonVariant.Default" @onclick="SaveReportingAsync" Class="mt-1">
                <LucideIcon Name="save" /> Save
            </BbButton>
            @if (!string.IsNullOrEmpty(reportingStatus))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@reportingStatus</p>
            }
        </BbCardContent>
    </BbCard>
        </BbTabsContent>
    </BbTabs>
}

@code {
    // Deep-linkable tab, e.g. /settings?tab=dns (used by the Setup checklist).
    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    private string activeTab = "dns";

    private bool signupEnabled;
    private string? signupFromAddress;
    private string signupMaxPerHour = "5";
    private bool isLoading = true;
    private string? statusMessage;

    private bool spfEnabled;
    private bool dmarcEnabled;
    private EnforcementMode enforcement = EnforcementMode.LogOnly;
    private bool requireSenderVerification;
    private bool requireRecipientVerification;
    private bool bindTenantToAllowIpRule;
    private bool rejectUnresolvedTenant;
    private string? emailAuthStatus;

    private bool bmEnabled;
    private string? bmDomains;
    private string bmRetryInterval = "15";
    private string bmMaxHold = "168";
    private string? backupMxStatus;

    private string statRetentionDays = "90";
    private string statAggTime = "00:00";
    private string? statisticsStatus;

    private string? dnsPublicHostname;
    private string? dnsSendingIps;
    private string? dnsSpfIncludes;
    private string dnsSpfAll = "~all";
    private string? dnsDmarcEmail;
    private string dnsDmarcPolicy = "none";
    private string dnsDmarcPct = "100";
    private string? dnsStatus;

    private bool reportEnabled;
    private string? reportRecipient;
    private string? reportFrom;
    private string reportDailyTime = "06:00";
    private string reportBounceThreshold = "10";
    private string? reportingStatus;

    private bool detectingIp;
    private List<string> detectedIps = [];
    private bool detectedNone;

    protected override async Task OnInitializedAsync()
    {
        activeTab = Tab is "signup" or "email-auth" or "backup-mx" or "statistics" or "dns" or "reporting" ? Tab : "dns";

        using var scope = ScopeFactory.CreateScope();
        var sp = scope.ServiceProvider;

        var portal = await sp.GetRequiredService<IPortalSettingsService>().GetAsync();
        signupEnabled = portal.SelfServiceSignupEnabled;
        signupFromAddress = portal.SignupFromAddress;
        signupMaxPerHour = portal.SignupMaxAttemptsPerIpPerHour.ToString();

        var emailAuth = await sp.GetRequiredService<IEmailAuthSettingsService>().GetAsync();
        spfEnabled = emailAuth.SpfEnabled;
        dmarcEnabled = emailAuth.DmarcEnabled;
        enforcement = emailAuth.Enforcement;
        requireSenderVerification = emailAuth.RequireSenderDomainVerification;
        requireRecipientVerification = emailAuth.RequireRecipientDomainVerification;
        bindTenantToAllowIpRule = emailAuth.BindTenantToAllowIpRule;
        rejectUnresolvedTenant = emailAuth.RejectUnresolvedTenant;

        var backupMx = await sp.GetRequiredService<IBackupMxSettingsService>().GetAsync();
        bmEnabled = backupMx.Enabled;
        bmDomains = backupMx.Domains;
        bmRetryInterval = backupMx.RetryIntervalMinutes.ToString();
        bmMaxHold = backupMx.MaxHoldHours.ToString();

        var stats = await sp.GetRequiredService<IStatisticsRetentionSettingsService>().GetAsync();
        statRetentionDays = stats.RetentionDays.ToString();
        statAggTime = stats.AggregationTimeUtc;

        var dns = await sp.GetRequiredService<IDnsSettingsService>().GetAsync();
        dnsPublicHostname = dns.PublicHostname;
        dnsSendingIps = dns.SendingIpAddresses;
        dnsSpfIncludes = dns.SpfIncludes;
        dnsSpfAll = dns.SpfAllQualifier;
        dnsDmarcEmail = dns.DmarcReportEmail;
        dnsDmarcPolicy = dns.DmarcPolicy;
        dnsDmarcPct = dns.DmarcPercentage.ToString();

        var reporting = await sp.GetRequiredService<IReportingSettingsService>().GetAsync();
        reportEnabled = reporting.Enabled;
        reportRecipient = reporting.RecipientAddress;
        reportFrom = reporting.FromAddress;
        reportDailyTime = reporting.DailyTimeUtc;
        reportBounceThreshold = reporting.BounceRateAlertPercent.ToString();

        isLoading = false;
    }

    // Best-effort public-IP detection after first paint, to propose a Sending IP.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await DetectIpAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DetectIpAsync()
    {
        detectingIp = true;
        detectedNone = false;
        StateHasChanged();
        try
        {
            detectedIps = [.. await IpDetector.DetectAsync()];
            detectedNone = detectedIps.Count == 0;
        }
        catch
        {
            detectedIps = [];
            detectedNone = true;
        }
        finally
        {
            detectingIp = false;
        }
    }

    private static List<string> SplitIps(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? []
            : [.. value.Split([';', ','], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)];

    private bool SendingIpsContains(string ip) =>
        SplitIps(dnsSendingIps).Contains(ip, StringComparer.OrdinalIgnoreCase);

    private void AddDetectedIp(string ip)
    {
        var parts = SplitIps(dnsSendingIps);
        if (!parts.Contains(ip, StringComparer.OrdinalIgnoreCase))
            parts.Add(ip);
        dnsSendingIps = string.Join("; ", parts);
    }

    private async Task SaveEmailAuthAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IEmailAuthSettingsService>()
            .UpdateAsync(spfEnabled, dmarcEnabled, enforcement, requireSenderVerification, requireRecipientVerification,
                bindTenantToAllowIpRule, rejectUnresolvedTenant);
        emailAuthStatus = $"Email authentication saved (SPF {(spfEnabled ? "on" : "off")}, DMARC {(dmarcEnabled ? "on" : "off")}, enforcement {enforcement}).";
    }

    private async Task SaveBackupMxAsync()
    {
        var retry = int.TryParse(bmRetryInterval, out var r) ? Math.Max(1, r) : 15;
        var hold = int.TryParse(bmMaxHold, out var h) ? Math.Max(1, h) : 168;
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IBackupMxSettingsService>()
            .UpdateAsync(bmEnabled, bmDomains, retry, hold);
        bmRetryInterval = retry.ToString();
        bmMaxHold = hold.ToString();
        backupMxStatus = bmEnabled
            ? $"Backup MX enabled for: {(string.IsNullOrWhiteSpace(bmDomains) ? "(no domains set)" : bmDomains)}."
            : "Backup MX disabled.";
    }

    private async Task SaveStatisticsAsync()
    {
        var days = int.TryParse(statRetentionDays, out var d) ? Math.Max(1, d) : 90;
        var time = TimeOnly.TryParse(statAggTime, out var t) ? t.ToString("HH:mm") : "00:00";
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IStatisticsRetentionSettingsService>()
            .UpdateAsync(days, time);
        statRetentionDays = days.ToString();
        statAggTime = time;
        statisticsStatus = $"Statistics retention set to {days} days; aggregation at {time} UTC.";
    }

    private async Task SaveDnsAsync()
    {
        var pct = int.TryParse(dnsDmarcPct, out var p) ? Math.Clamp(p, 1, 100) : 100;
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IDnsSettingsService>().UpdateAsync(new WinSmtpRelay.Core.Models.DnsSettings
        {
            PublicHostname = dnsPublicHostname,
            SendingIpAddresses = dnsSendingIps ?? "",
            SpfIncludes = dnsSpfIncludes ?? "",
            SpfAllQualifier = dnsSpfAll,
            DmarcReportEmail = dnsDmarcEmail,
            DmarcPolicy = dnsDmarcPolicy,
            DmarcPercentage = pct
        });
        dnsDmarcPct = pct.ToString();
        dnsStatus = "DNS recommendation settings saved. The Deliverability page reflects them on its next check.";
    }

    private async Task SaveReportingAsync()
    {
        var threshold = int.TryParse(reportBounceThreshold, out var t) ? Math.Clamp(t, 0, 100) : 10;
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IReportingSettingsService>()
            .UpdateAsync(reportEnabled, reportRecipient, reportFrom, reportDailyTime, threshold);
        reportBounceThreshold = threshold.ToString();
        reportingStatus = reportEnabled
            ? (string.IsNullOrWhiteSpace(reportRecipient)
                ? "Saved, but reporting needs a recipient address to send anything."
                : $"Reporting enabled — sending to {reportRecipient!.Trim()}.")
            : "Reporting disabled.";
    }

    private async Task OnToggleAsync(bool value)
    {
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IPortalSettingsService>().SetSelfServiceSignupEnabledAsync(value);
        signupEnabled = value;
        statusMessage = value ? "Self-service signup enabled." : "Self-service signup disabled.";
    }

    private async Task SaveFromAddressAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IPortalSettingsService>().SetSignupFromAddressAsync(signupFromAddress);
        statusMessage = string.IsNullOrWhiteSpace(signupFromAddress)
            ? "From-address cleared (using the appsettings value)."
            : $"From-address set to {signupFromAddress.Trim()}.";
    }

    private async Task SaveThrottleAsync()
    {
        var max = int.TryParse(signupMaxPerHour, out var v) ? Math.Max(0, v) : 0;
        using var scope = ScopeFactory.CreateScope();
        await scope.ServiceProvider.GetRequiredService<IPortalSettingsService>().SetSignupMaxAttemptsPerIpPerHourAsync(max);
        signupMaxPerHour = max.ToString();
        statusMessage = max == 0
            ? "Signup throttle disabled."
            : $"Signup throttle set to {max}/hour per IP.";
    }
}

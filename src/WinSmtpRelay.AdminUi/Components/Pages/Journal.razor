@page "/journal"
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject ITenantScopeFactory ScopeFactory
@inject IActivityFeed Feed
@inject ICurrentTenant CurrentTenant
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Journal</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Message Journal</h1>
        <p>Per-recipient delivery audit trail</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

@* A form so Enter in the search box triggers the search (the BbButton stays type="button"). *@
<form class="search-bar" @onsubmit="ApplySearch" @onsubmit:preventDefault>
    <BbInput Type="InputType.Search" @bind-Value="searchTerm" Placeholder="Search by recipient, message ID, or status..." />
    <BbButton Variant="ButtonVariant.Secondary" @onclick="ApplySearch">
        <LucideIcon Name="search" />
        Search
    </BbButton>
</form>

@* Infinite scroll: <Virtualize> renders only the visible rows and pulls the next window from the server
   via the ItemsProvider as you scroll, so the whole journal is browsable without a page picker. Newest
   first; scroll down to load older entries. The scroll happens in .app-main and the <thead> stays sticky. *@
<table>
    <thead>
        <tr>
            <th>Time</th>
            <th>Msg ID</th>
            <th>Recipient</th>
            <th>Status</th>
            <th>Remote Server</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @* SpacerElement="tr" keeps Virtualize's height-spacer elements valid inside <tbody>. *@
        <Virtualize @ref="virtualize" TItem="DeliveryLog" ItemsProvider="LoadRows" Context="log"
                    ItemSize="42" SpacerElement="tr" OverscanCount="6">
            <ItemContent>
                <tr class="log-row-clickable" @onclick="() => selected = log">
                    <td><LocalTime Utc="@log.TimestampUtc" Format="yyyy-MM-dd HH:mm:ss" /></td>
                    <td title="@($"Queue ID: {log.QueuedMessageId}")">@log.QueuedMessageId</td>
                    <td>@log.Recipient</td>
                    <td><span class="badge-status @GetStatusCss(log.StatusCode)">@log.StatusCode</span></td>
                    <td>@(log.RemoteServer ?? "-")</td>
                    <td>@Truncate(log.StatusMessage, 60)</td>
                </tr>
            </ItemContent>
            <Placeholder>
                <tr><td colspan="6" style="text-align:center;color:var(--muted-foreground);padding:0.75rem;">Loading…</td></tr>
            </Placeholder>
            <EmptyContent>
                <tr><td colspan="6" style="text-align:center;padding:1rem;">No delivery log entries found.</td></tr>
            </EmptyContent>
        </Virtualize>
    </tbody>
</table>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About the Message Journal</BbDialogTitle>
            <BbDialogDescription>Per-recipient delivery audit trail</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The journal records every delivery attempt for every recipient. Unlike the queue (which tracks
                messages), the journal tracks <strong>individual deliveries</strong> &mdash; one message sent to
                three recipients produces three journal entries.
            </p>
            <h4 style="margin-top:1rem;">What each column means</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Time</strong> &mdash; when the delivery attempt was made, shown in your browser's local time zone (hover for the exact UTC value).</li>
                <li><strong>Msg ID</strong> &mdash; links back to the queued message by its internal queue ID.</li>
                <li><strong>Recipient</strong> &mdash; the email address this attempt targeted.</li>
                <li><strong>Status</strong> &mdash; the SMTP status code returned by the remote server (250 = success, 4xx = temporary failure, 5xx = permanent failure).</li>
                <li><strong>Remote Server</strong> &mdash; the MX host or smart host that handled the delivery.</li>
                <li><strong>Details</strong> &mdash; the status message from the remote server (truncated). Click any row to see the full message.</li>
            </ul>
            <h4 style="margin-top:1rem;">Searching</h4>
            <p>
                Use the search bar to filter by recipient address, status code, status message, or remote server name.
                The list loads more entries automatically as you scroll &mdash; there are no pages to click through.
            </p>
            <h4 style="margin-top:1rem;">Live updates</h4>
            <p>
                While you are at the top of the list, the journal refreshes automatically as new delivery attempts
                are recorded. Once you scroll down into older entries it stays still so rows don't shift while you read.
            </p>
            <h4 style="margin-top:1rem;">Retention</h4>
            <p>
                Journal entries are kept for the delivery-log retention window configured under
                <strong>Settings &rarr; Data retention</strong> (an enforced minimum guarantees a baseline
                audit trail); entries older than that window are purged automatically.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbDialog Open="@(selected is not null)" OpenChanged="@(open => { if (!open) selected = null; })">
    <BbDialogContent>
        @if (selected is not null)
        {
            <BbDialogHeader>
                <BbDialogTitle><span class="badge-status @GetStatusCss(selected.StatusCode)">@selected.StatusCode</span> @selected.Recipient</BbDialogTitle>
                <BbDialogDescription><LocalTime Utc="@selected.TimestampUtc" Format="yyyy-MM-dd HH:mm:ss" /> &middot; Msg @selected.QueuedMessageId</BbDialogDescription>
            </BbDialogHeader>
            <div style="font-size:0.875rem;line-height:1.6;max-height:60vh;overflow-y:auto;">
                <div style="margin-bottom:0.5rem;">
                    <strong class="text-muted">Remote server</strong><br />
                    <span style="word-break:break-word;">@(selected.RemoteServer ?? "-")</span>
                </div>
                <div>
                    <strong class="text-muted">Status message</strong><br />
                    <span class="mono" style="word-break:break-word;white-space:pre-wrap;">@selected.StatusMessage</span>
                </div>
            </div>
            <BbDialogFooter>
                <BbButton Variant="ButtonVariant.Default" @onclick="@(() => Nav.NavigateTo($"/messages/{selected.QueuedMessageId}"))">
                    <LucideIcon Name="mail" /> View message
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" @onclick="() => selected = null">Close</BbButton>
            </BbDialogFooter>
        }
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private DeliveryLog? selected;
    private string searchTerm = "";
    private Virtualize<DeliveryLog>? virtualize;
    // StartIndex of the most recent window Virtualize requested. 0 means the newest rows are in view;
    // used to gate the live refresh so it never shifts the ground under someone reading older history.
    private int lastStartIndex;
    private bool _disposed;
    private System.Threading.Timer? _refreshDebounceTimer;

    protected override void OnInitialized()
    {
        // Created disarmed, before subscribing, so OnActivity can never see a null timer; re-armed
        // per event via Change(), which is thread-safe (OnActivity runs on the publisher's thread).
        _refreshDebounceTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            try
            {
                await InvokeAsync(async () =>
                {
                    // Only refresh while the newest rows are on screen; if the user has scrolled down into
                    // older entries, leave the view stable (RefreshDataAsync would re-query their window).
                    if (_disposed || virtualize is null || lastStartIndex != 0) return;
                    await virtualize.RefreshDataAsync();
                });
            }
            catch { } // the circuit may be tearing down; a missed background refresh is harmless
        }, null, Timeout.InfiniteTimeSpan, Timeout.InfiniteTimeSpan);
        Feed.Received += OnActivity;
    }

    /// <summary>
    /// Virtualize's data source: returns the requested window (newest first) plus the total count so the
    /// scrollbar reflects the whole journal. Called again as the user scrolls and on RefreshDataAsync.
    /// </summary>
    private async ValueTask<ItemsProviderResult<DeliveryLog>> LoadRows(ItemsProviderRequest request)
    {
        lastStartIndex = request.StartIndex;

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<RelayDbContext>();

        var query = db.DeliveryLogs.AsNoTracking().AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim();
            query = query.Where(l =>
                l.Recipient.Contains(term) ||
                l.StatusCode.Contains(term) ||
                l.StatusMessage.Contains(term) ||
                (l.RemoteServer != null && l.RemoteServer.Contains(term)));
        }

        var total = await query.CountAsync(request.CancellationToken);

        var items = await query
            .OrderByDescending(l => l.Id)
            .Skip(request.StartIndex)
            .Take(request.Count)
            .ToListAsync(request.CancellationToken);

        return new ItemsProviderResult<DeliveryLog>(items, total);
    }

    private void OnActivity(ActivityEvent e)
    {
        if (_disposed) return;
        // Each delivery attempt writes one journal row; react only to this circuit's tenant scope.
        if (e.Kind is not ActivityKind.DeliveryAttempt || !CurrentTenant.Owns(e)) return;
        // The timer callback additionally gates on lastStartIndex so we only refresh when at the top.
        ScheduleRefresh();
    }

    /// <summary>
    /// Debounces the feed-driven refresh so one message to N recipients (N events) causes one query.
    /// </summary>
    private void ScheduleRefresh()
    {
        try { _refreshDebounceTimer?.Change(TimeSpan.FromMilliseconds(500), Timeout.InfiniteTimeSpan); }
        catch (ObjectDisposedException) { } // disposed during teardown — a missed refresh is harmless
    }

    /// <summary>Applies the current search term: jump back to the newest results and re-query.</summary>
    private async Task ApplySearch()
    {
        try { await JS.InvokeVoidAsync("winSmtpRelay.scrollMainToTop"); } catch { /* interop not ready */ }
        if (virtualize is not null)
            await virtualize.RefreshDataAsync();
    }

    private static string GetStatusCss(string statusCode) => statusCode switch
    {
        "250" => "badge-success",
        _ when statusCode.StartsWith("5") => "badge-error",
        _ when statusCode.StartsWith("4") => "badge-warning",
        _ => "badge-muted"
    };

    private static string Truncate(string text, int maxLen) =>
        text.Length > maxLen ? text[..maxLen] + "..." : text;

    public void Dispose()
    {
        _disposed = true;
        Feed.Received -= OnActivity;
        _refreshDebounceTimer?.Dispose();
    }
}

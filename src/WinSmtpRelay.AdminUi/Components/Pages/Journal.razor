@page "/journal"
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using WinSmtpRelay.Core.Models
@inject ITenantScopeFactory ScopeFactory

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Journal</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Message Journal</h1>
        <p>Per-recipient delivery audit trail</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

<div class="search-bar">
    <BbInput Type="InputType.Search" @bind-Value="searchTerm" Placeholder="Search by recipient, message ID, or status..." />
    <BbButton Variant="ButtonVariant.Secondary" @onclick="LoadLogs">
        <LucideIcon Name="search" />
        Search
    </BbButton>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[400px] w-full" />
}
else
{
    <BbTable Data="@logs">
        <BbTableHeader>
            <BbTableRow TData="DeliveryLog">
                <BbTableHeaderCell TData="DeliveryLog">Time</BbTableHeaderCell>
                <BbTableHeaderCell TData="DeliveryLog">Msg ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="DeliveryLog">Recipient</BbTableHeaderCell>
                <BbTableHeaderCell TData="DeliveryLog">Status</BbTableHeaderCell>
                <BbTableHeaderCell TData="DeliveryLog">Remote Server</BbTableHeaderCell>
                <BbTableHeaderCell TData="DeliveryLog">Details</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (logs.Count == 0)
            {
                <BbTableRow TData="DeliveryLog">
                    <BbTableCell colspan="6" style="text-align:center;">No delivery log entries found.</BbTableCell>
                </BbTableRow>
            }
            @foreach (var log in logs)
            {
                <BbTableRow Item="@log" class="log-row-clickable" @onclick="() => selected = log">
                    <BbTableCell><LocalTime Utc="@log.TimestampUtc" Format="yyyy-MM-dd HH:mm:ss" /></BbTableCell>
                    <BbTableCell title="@($"Queue ID: {log.QueuedMessageId}")">@log.QueuedMessageId</BbTableCell>
                    <BbTableCell>@log.Recipient</BbTableCell>
                    <BbTableCell><span class="badge-status @GetStatusCss(log.StatusCode)">@log.StatusCode</span></BbTableCell>
                    <BbTableCell>@(log.RemoteServer ?? "-")</BbTableCell>
                    <BbTableCell>@Truncate(log.StatusMessage, 60)</BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>

    @if (totalPages > 1)
    {
        <div style="margin-top:1rem;">
            <BbPagination>
                <BbPaginationContent>
                    <BbPaginationItem>
                        <BbPaginationPrevious OnClick="PrevPage" Disabled="@(currentPage <= 1)" />
                    </BbPaginationItem>
                    @for (var p = 1; p <= totalPages; p++)
                    {
                        var page = p;
                        <BbPaginationItem>
                            <BbPaginationLink IsActive="@(page == currentPage)" OnClick="() => GoToPage(page)">@(page)</BbPaginationLink>
                        </BbPaginationItem>
                    }
                    <BbPaginationItem>
                        <BbPaginationNext OnClick="NextPage" Disabled="@(currentPage >= totalPages)" />
                    </BbPaginationItem>
                </BbPaginationContent>
            </BbPagination>
        </div>
    }
}

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About the Message Journal</BbDialogTitle>
            <BbDialogDescription>Per-recipient delivery audit trail</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The journal records every delivery attempt for every recipient. Unlike the queue (which tracks
                messages), the journal tracks <strong>individual deliveries</strong> &mdash; one message sent to
                three recipients produces three journal entries.
            </p>
            <h4 style="margin-top:1rem;">What each column means</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Time</strong> &mdash; when the delivery attempt was made, shown in your browser's local time zone (hover for the exact UTC value).</li>
                <li><strong>Msg ID</strong> &mdash; links back to the queued message by its internal queue ID.</li>
                <li><strong>Recipient</strong> &mdash; the email address this attempt targeted.</li>
                <li><strong>Status</strong> &mdash; the SMTP status code returned by the remote server (250 = success, 4xx = temporary failure, 5xx = permanent failure).</li>
                <li><strong>Remote Server</strong> &mdash; the MX host or smart host that handled the delivery.</li>
                <li><strong>Details</strong> &mdash; the status message from the remote server (truncated). Click any row to see the full message.</li>
            </ul>
            <h4 style="margin-top:1rem;">Searching</h4>
            <p>
                Use the search bar to filter by recipient address, status code, status message, or remote server name.
                Results are paginated (50 per page).
            </p>
            <h4 style="margin-top:1rem;">Retention</h4>
            <p>
                Journal entries are stored permanently in the SQLite database. They are never automatically purged,
                giving you a complete audit trail of all delivery activity.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbDialog Open="@(selected is not null)" OpenChanged="@(open => { if (!open) selected = null; })">
    <BbDialogContent>
        @if (selected is not null)
        {
            <BbDialogHeader>
                <BbDialogTitle><span class="badge-status @GetStatusCss(selected.StatusCode)">@selected.StatusCode</span> @selected.Recipient</BbDialogTitle>
                <BbDialogDescription><LocalTime Utc="@selected.TimestampUtc" Format="yyyy-MM-dd HH:mm:ss" /> &middot; Msg @selected.QueuedMessageId</BbDialogDescription>
            </BbDialogHeader>
            <div style="font-size:0.875rem;line-height:1.6;max-height:60vh;overflow-y:auto;">
                <div style="margin-bottom:0.5rem;">
                    <strong class="text-muted">Remote server</strong><br />
                    <span style="word-break:break-word;">@(selected.RemoteServer ?? "-")</span>
                </div>
                <div>
                    <strong class="text-muted">Status message</strong><br />
                    <span class="mono" style="word-break:break-word;white-space:pre-wrap;">@selected.StatusMessage</span>
                </div>
            </div>
            <BbDialogFooter>
                <BbButton Variant="ButtonVariant.Outline" @onclick="() => selected = null">Close</BbButton>
            </BbDialogFooter>
        }
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private DeliveryLog? selected;
    private List<DeliveryLog> logs = [];
    private string searchTerm = "";
    private int pageSize = 50;
    private int currentPage = 1;
    private int totalCount = 0;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        currentPage = 1;
        await FetchLogs();
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await FetchLogs();
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await FetchLogs();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await FetchLogs();
        }
    }

    private async Task FetchLogs()
    {
        isLoading = true;

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<RelayDbContext>();

        var query = db.DeliveryLogs.AsNoTracking().AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim();
            query = query.Where(l =>
                l.Recipient.Contains(term) ||
                l.StatusCode.Contains(term) ||
                l.StatusMessage.Contains(term) ||
                (l.RemoteServer != null && l.RemoteServer.Contains(term)));
        }

        totalCount = await query.CountAsync();

        var skip = (currentPage - 1) * pageSize;

        logs = await query
            .OrderByDescending(l => l.Id)
            .Skip(skip)
            .Take(pageSize)
            .ToListAsync();

        isLoading = false;
    }

    private static string GetStatusCss(string statusCode) => statusCode switch
    {
        "250" => "badge-success",
        _ when statusCode.StartsWith("5") => "badge-error",
        _ when statusCode.StartsWith("4") => "badge-warning",
        _ => "badge-muted"
    };

    private static string Truncate(string text, int maxLen) =>
        text.Length > maxLen ? text[..maxLen] + "..." : text;
}

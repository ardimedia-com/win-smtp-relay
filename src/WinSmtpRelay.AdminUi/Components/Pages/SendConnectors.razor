@page "/connectors/send"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.AdminFull)]
@inject ITenantScopeFactory ScopeFactory
@inject IRuntimeConfigCache ConfigCache
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Send Connectors</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Send Connectors</h1>
        <p>Outbound delivery routes, smart hosts and domain routing</p>
    </div>
    <div class="flex gap-1 items-center">
        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/connectors/send/new"))">
            <LucideIcon Name="plus" /> New connector
        </BbButton>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
            <LucideIcon Name="info" /> About Send Connectors
        </BbButton>
    </div>
</div>

<BbTabs DefaultValue="connectors" @bind-Value="activeTab">
    <BbTabsList>
        <BbTabsTrigger Value="connectors">Send Connectors</BbTabsTrigger>
        <BbTabsTrigger Value="routes">Domain Routes</BbTabsTrigger>
    </BbTabsList>

    <BbTabsContent Value="connectors">
        <div style="margin-bottom:1rem;">
            <BrevoConnectorInfo />
        </div>
        @if (isLoading)
        {
            <BbSkeleton Class="h-[300px] w-full" />
        }
        else
        {
            <BbTable Data="@connectors">
                <BbTableHeader>
                    <BbTableRow TData="SendConnector">
                        <BbTableHeaderCell TData="SendConnector">Name</BbTableHeaderCell>
                        <BbTableHeaderCell TData="SendConnector">Smart Host</BbTableHeaderCell>
                        <BbTableHeaderCell TData="SendConnector">TLS</BbTableHeaderCell>
                        <BbTableHeaderCell TData="SendConnector">Default</BbTableHeaderCell>
                        <BbTableHeaderCell TData="SendConnector">Concurrency</BbTableHeaderCell>
                        <BbTableHeaderCell TData="SendConnector">Enabled</BbTableHeaderCell>
                        <BbTableHeaderCell TData="SendConnector"></BbTableHeaderCell>
                    </BbTableRow>
                </BbTableHeader>
                <BbTableBody>
                    @if (connectors.Count == 0)
                    {
                        <BbTableRow TData="SendConnector">
                            <BbTableCell colspan="7" style="text-align:center;">No send connectors configured</BbTableCell>
                        </BbTableRow>
                    }
                    @foreach (var c in connectors)
                    {
                        <BbTableRow Item="@c" class="list-row-clickable" @onclick="() => Edit(c.Id)">
                            <BbTableCell>@c.Name</BbTableCell>
                            <BbTableCell>@(string.IsNullOrEmpty(c.SmartHost) ? "Direct MX" : $"{c.SmartHost}:{c.SmartHostPort}")</BbTableCell>
                            <BbTableCell>
                                @if (c.RequireTls) { <span>Required</span> }
                                else if (c.OpportunisticTls) { <span>Opportunistic</span> }
                                else { <span class="text-muted">None</span> }
                            </BbTableCell>
                            <BbTableCell><span class="badge-status @(c.IsDefault ? "badge-success" : "badge-muted")">@(c.IsDefault ? "Yes" : "No")</span></BbTableCell>
                            <BbTableCell>@c.MaxConcurrentDeliveries</BbTableCell>
                            <BbTableCell><span class="badge-status @(c.IsEnabled ? "badge-success" : "badge-muted")">@(c.IsEnabled ? "Yes" : "No")</span></BbTableCell>
                            <BbTableCell>
                                <div class="list-row-actions" @onclick:stopPropagation="true">
                                    <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => Edit(c.Id)">
                                        <LucideIcon Name="pencil" />
                                    </BbButton>
                                    <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                            @onclick="() => { deleteTargetId = c.Id; showDeleteConfirm = true; }">
                                        <LucideIcon Name="trash-2" />
                                    </BbButton>
                                </div>
                            </BbTableCell>
                        </BbTableRow>
                    }
                </BbTableBody>
            </BbTable>
        }
    </BbTabsContent>

    <BbTabsContent Value="routes">
        <div class="page-header-row" style="margin-bottom:0.5rem;">
            <span></span>
            <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/connectors/send/routes/new"))">
                <LucideIcon Name="plus" /> New domain route
            </BbButton>
        </div>
        <BbTable Data="@routes">
            <BbTableHeader>
                <BbTableRow TData="DomainRoute">
                    <BbTableHeaderCell TData="DomainRoute">Order</BbTableHeaderCell>
                    <BbTableHeaderCell TData="DomainRoute">Domain Pattern</BbTableHeaderCell>
                    <BbTableHeaderCell TData="DomainRoute">Send Connector</BbTableHeaderCell>
                    <BbTableHeaderCell TData="DomainRoute"></BbTableHeaderCell>
                </BbTableRow>
            </BbTableHeader>
            <BbTableBody>
                @if (routes.Count == 0)
                {
                    <BbTableRow TData="DomainRoute">
                        <BbTableCell colspan="4" style="text-align:center;">No domain routes &mdash; all mail uses the default connector</BbTableCell>
                    </BbTableRow>
                }
                @foreach (var r in routes)
                {
                    <BbTableRow Item="@r" class="list-row-clickable" @onclick="() => EditRoute(r.Id)">
                        <BbTableCell>@r.SortOrder</BbTableCell>
                        <BbTableCell><code>@r.DomainPattern</code></BbTableCell>
                        <BbTableCell>@(r.SendConnector?.Name ?? $"ID {r.SendConnectorId}")</BbTableCell>
                        <BbTableCell>
                            <div class="list-row-actions" @onclick:stopPropagation="true">
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => EditRoute(r.Id)">
                                    <LucideIcon Name="pencil" />
                                </BbButton>
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                        @onclick="() => { deleteRouteId = r.Id; showDeleteRouteConfirm = true; }">
                                    <LucideIcon Name="trash-2" />
                                </BbButton>
                            </div>
                        </BbTableCell>
                    </BbTableRow>
                }
            </BbTableBody>
        </BbTable>
    </BbTabsContent>
</BbTabs>

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Send Connector</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will remove this send connector and all associated domain routes.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbAlertDialog @bind-Open="showDeleteRouteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Domain Route</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will remove this domain route. Mail for this domain will use the default connector.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteRouteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Send Connectors</BbDialogTitle>
            <BbDialogDescription>Outbound delivery configuration</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>Send connectors define how outbound email is delivered.</p>
            <h4 style="margin-top:1rem;">Direct MX vs Smart Host</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Direct MX</strong> &mdash; WIN-SMTP-RELAY looks up the recipient's MX record and delivers directly. Leave Smart Host empty.</li>
                <li><strong>Smart Host</strong> &mdash; All mail is forwarded to an upstream relay (e.g. SendGrid, Microsoft 365, your ISP).</li>
            </ul>
            <h4 style="margin-top:1rem;">Domain Routes</h4>
            <p>Domain routes override the default connector for specific recipient domains. Routes are evaluated in sort order; the first match wins. Use <code>*.example.com</code> for wildcard matching.</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<SendConnector> connectors = [];
    private IReadOnlyList<DomainRoute> routes = [];
    private bool isLoading = true;
    private bool showHelp;
    private bool showDeleteConfirm;
    private bool showDeleteRouteConfirm;
    private int deleteTargetId;
    private int deleteRouteId;
    private string? statusMessage;
    private string activeTab = "connectors";

    [SupplyParameterFromQuery(Name = "tab")] public string? Tab { get; set; }

    protected override async Task OnInitializedAsync()
    {
        activeTab = Tab is "routes" or "connectors" ? Tab : "connectors";
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var connSvc = scope.ServiceProvider.GetRequiredService<ISendConnectorService>();
        var routeSvc = scope.ServiceProvider.GetRequiredService<IDomainRouteService>();
        connectors = await connSvc.GetAllAsync();
        routes = await routeSvc.GetAllAsync();
        isLoading = false;
    }

    private void Edit(int id) => Nav.NavigateTo($"/connectors/send/{id}");
    private void EditRoute(int id) => Nav.NavigateTo($"/connectors/send/routes/{id}");

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ISendConnectorService>();
        await svc.DeleteAsync(deleteTargetId);
        ConfigCache.Invalidate();
        statusMessage = "Connector deleted";
        showDeleteConfirm = false;
        await RefreshAsync();
    }

    private async Task ConfirmDeleteRouteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IDomainRouteService>();
        await svc.DeleteAsync(deleteRouteId);
        ConfigCache.Invalidate();
        statusMessage = "Route deleted";
        showDeleteRouteConfirm = false;
        await RefreshAsync();
    }
}

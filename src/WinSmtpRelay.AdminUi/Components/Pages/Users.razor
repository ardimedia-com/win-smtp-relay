@page "/smtpusers"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = AuthorizationPolicies.AdminFull)]
@inject ITenantScopeFactory ScopeFactory
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>SMTP Users</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>SMTP Users</h1>
        <p>SMTP relay user accounts and permissions</p>
    </div>
    <div class="flex gap-1 items-center">
        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/smtpusers/new"))">
            <LucideIcon Name="plus" /> New user
        </BbButton>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelpDialog = true">
            <LucideIcon Name="info" /> What are SMTP users?
        </BbButton>
    </div>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@users">
        <BbTableHeader>
            <BbTableRow TData="RelayUser">
                <BbTableHeaderCell TData="RelayUser">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Username</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Enabled</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Allowed Senders</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Rate Limit</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Created</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser"></BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (users.Count == 0)
            {
                <BbTableRow TData="RelayUser">
                    <BbTableCell colspan="7" style="text-align:center;">No users configured</BbTableCell>
                </BbTableRow>
            }
            @foreach (var user in users)
            {
                <BbTableRow Item="@user" class="list-row-clickable" @onclick="() => Edit(user.Id)">
                    <BbTableCell>@user.Id</BbTableCell>
                    <BbTableCell>@user.Username</BbTableCell>
                    <BbTableCell><span class="badge-status @(user.IsEnabled ? "badge-success" : "badge-muted")">@(user.IsEnabled ? "Yes" : "No")</span></BbTableCell>
                    <BbTableCell style="max-width:200px;overflow:hidden;text-overflow:ellipsis;">
                        @(string.IsNullOrEmpty(user.AllowedSenderAddresses) ? "Any" : user.AllowedSenderAddresses)
                    </BbTableCell>
                    <BbTableCell>
                        @(user.RateLimitPerMinute.HasValue ? $"{user.RateLimitPerMinute}/min" : "—")
                        @(user.RateLimitPerDay.HasValue ? $", {user.RateLimitPerDay}/day" : "")
                    </BbTableCell>
                    <BbTableCell><LocalTime Utc="@user.CreatedUtc" Format="yyyy-MM-dd" /></BbTableCell>
                    <BbTableCell>
                        <div class="list-row-actions" @onclick:stopPropagation="true">
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => Edit(user.Id)">
                                <LucideIcon Name="pencil" />
                            </BbButton>
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                    @onclick="() => { deleteTargetId = user.Id; showDeleteConfirm = true; }">
                                <LucideIcon Name="trash-2" />
                            </BbButton>
                        </div>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete User</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will permanently delete this user account. This action cannot be undone.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelpDialog">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>What are SMTP Relay Users?</BbDialogTitle>
            <BbDialogDescription>Understanding user accounts in WIN-SMTP-RELAY</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                These are <strong>SMTP relay accounts</strong> &mdash; credentials that applications
                (web servers, ERP systems, monitoring tools) use to authenticate when submitting
                email through WIN-SMTP-RELAY.
            </p>
            <h4 style="margin-top:1rem;">How it works</h4>
            <ol style="padding-left:1.25rem;">
                <li>An application connects to WIN-SMTP-RELAY on the SMTP port and authenticates with a username and password.</li>
                <li>WIN-SMTP-RELAY validates the credentials and enforces per-user policies.</li>
                <li>The message is queued and delivered to the recipient's mail server.</li>
            </ol>
            <h4 style="margin-top:1rem;">Per-user settings</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Allowed Senders</strong> &mdash; restricts which <em>From:</em> addresses this user can send as. Empty means any address.</li>
                <li><strong>Rate Limit</strong> &mdash; throttles how many messages per minute/day this user can send.</li>
                <li><strong>Enabled</strong> &mdash; disabled users are rejected at login.</li>
            </ul>
            <h4 style="margin-top:1rem;">Example</h4>
            <p>
                User <code>webapp</code> with allowed sender <code>noreply@example.com</code>
                and rate limit <code>1000/day</code> &mdash; your web app can only send as that
                address, max 1000 emails per day.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<RelayUser> users = [];
    private bool isLoading = true;
    private bool showHelpDialog;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IUserService>();
        users = await svc.GetAllUsersAsync();
        isLoading = false;
    }

    private void Edit(int id) => Nav.NavigateTo($"/smtpusers/{id}");

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IUserService>();
        await svc.DeleteUserAsync(deleteTargetId);
        showDeleteConfirm = false;
        await RefreshAsync();
    }
}

@page "/tenants"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Tenants</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Tenants</h1>
        <p>Isolated relay configurations sharing this installation. Host administrators only.</p>
    </div>
    <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/tenants/new"))">
        <LucideIcon Name="plus" /> New tenant
    </BbButton>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[200px] w-full" />
}
else
{
    <BbTable Data="@tenants">
        <BbTableHeader>
            <BbTableRow TData="Tenant">
                <BbTableHeaderCell TData="Tenant">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Name</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Slug</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Status</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Outbound IP</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Created</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant"></BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @foreach (var t in tenants)
            {
                <BbTableRow Item="@t" class="list-row-clickable" @onclick="() => Edit(t.Id)">
                    <BbTableCell>@t.Id</BbTableCell>
                    <BbTableCell>@t.Name</BbTableCell>
                    <BbTableCell><span class="mono">@t.Slug</span></BbTableCell>
                    <BbTableCell>
                        <span class="badge-status @(t.IsEnabled ? "" : "badge-muted")">@(t.IsEnabled ? "Enabled" : "Disabled")</span>
                    </BbTableCell>
                    <BbTableCell><span class="mono text-muted">@(string.IsNullOrWhiteSpace(t.EgressIpAddress) ? "—" : t.EgressIpAddress)</span></BbTableCell>
                    <BbTableCell><LocalTime Utc="@t.CreatedUtc" Format="yyyy-MM-dd" /></BbTableCell>
                    <BbTableCell>
                        <div class="list-row-actions" @onclick:stopPropagation="true">
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => Edit(t.Id)">
                                <LucideIcon Name="pencil" />
                            </BbButton>
                            @if (t.Id != TenantDefaults.DefaultTenantId)
                            {
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                        @onclick="() => { deleteTargetId = t.Id; showDeleteConfirm = true; }">
                                    <LucideIcon Name="trash-2" />
                                </BbButton>
                            }
                        </div>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Tenant</BbAlertDialogTitle>
            <BbAlertDialogDescription>This permanently deletes the tenant <strong>and all of its data</strong> — relay users, mail queue, delivery logs, connectors, domains, DKIM keys, filters, API keys, and admin accounts. This cannot be undone.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

@code {
    private IReadOnlyList<Tenant> tenants = [];
    private bool isLoading = true;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        tenants = await svc.GetAllAsync();
        isLoading = false;
    }

    private void Edit(int id) => Nav.NavigateTo($"/tenants/{id}");

    private async Task ConfirmDeleteAsync()
    {
        showDeleteConfirm = false;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        try { await svc.PurgeAndDeleteAsync(deleteTargetId); }
        catch (InvalidOperationException) { /* surfaced on the detail page; ignore here */ }
        await RefreshAsync();
    }
}

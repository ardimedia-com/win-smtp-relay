@page "/tenants"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject IServiceScopeFactory ScopeFactory

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Tenants</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Tenants</h1>
        <p>Isolated relay configurations sharing this installation. Host administrators only.</p>
    </div>
</div>

<div style="max-width:480px;">
<BbCard Class="mb-1">
    <BbCardHeader>
        <BbCardTitle>Add Tenant</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        <div class="form-group">
            <BbLabel>Name</BbLabel>
            <BbInput @bind-Value="newName" Placeholder="Acme Corp" />
        </div>
        <div class="form-group">
            <BbLabel>Slug</BbLabel>
            <BbInput @bind-Value="newSlug" Placeholder="acme" />
        </div>
    </BbCardContent>
    <BbCardFooter>
        <BbButton Variant="ButtonVariant.Default" @onclick="CreateAsync"
                Disabled="@(string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newSlug))">
            <LucideIcon Name="plus" /> Add
        </BbButton>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="text-muted" style="margin-left:1rem">@statusMessage</span>
        }
    </BbCardFooter>
</BbCard>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[200px] w-full" />
}
else
{
    <BbTable Data="@tenants">
        <BbTableHeader>
            <BbTableRow TData="Tenant">
                <BbTableHeaderCell TData="Tenant">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Name</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Slug</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Status</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Created</BbTableHeaderCell>
                <BbTableHeaderCell TData="Tenant">Actions</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @foreach (var t in tenants)
            {
                <BbTableRow Item="@t">
                    <BbTableCell>@t.Id</BbTableCell>
                    <BbTableCell>@t.Name</BbTableCell>
                    <BbTableCell><span class="mono">@t.Slug</span></BbTableCell>
                    <BbTableCell>
                        <span class="badge-status @(t.IsEnabled ? "" : "badge-muted")">@(t.IsEnabled ? "Enabled" : "Disabled")</span>
                    </BbTableCell>
                    <BbTableCell>@t.CreatedUtc.ToString("yyyy-MM-dd")</BbTableCell>
                    <BbTableCell>
                        @if (t.Id != TenantDefaults.DefaultTenantId || !t.IsEnabled)
                        {
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost"
                                    @onclick="() => ToggleAsync(t)" title="@(t.IsEnabled ? "Disable" : "Enable")">
                                <LucideIcon Name="@(t.IsEnabled ? "pause" : "play")" />
                            </BbButton>
                        }
                        @if (t.Id != TenantDefaults.DefaultTenantId)
                        {
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost"
                                    @onclick="() => { deleteTargetId = t.Id; showDeleteConfirm = true; }" title="Delete">
                                <LucideIcon Name="trash-2" />
                            </BbButton>
                        }
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Tenant</BbAlertDialogTitle>
            <BbAlertDialogDescription>This permanently deletes the tenant <strong>and all of its data</strong> — relay users, mail queue, delivery logs, connectors, domains, DKIM keys, filters, API keys, and admin accounts. This cannot be undone.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

@code {
    private IReadOnlyList<Tenant> tenants = [];
    private string newName = "";
    private string newSlug = "";
    private string? statusMessage;
    private bool isLoading = true;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        tenants = await svc.GetAllAsync();
        isLoading = false;
    }

    private async Task CreateAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        try
        {
            var created = await svc.CreateAsync(newName, newSlug);
            statusMessage = $"Tenant '{created.Name}' created";
            newName = "";
            newSlug = "";
            await RefreshAsync();
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
        }
    }

    private async Task ToggleAsync(Tenant t)
    {
        using var scope = ScopeFactory.CreateScope();
        try
        {
            if (!t.IsEnabled)
            {
                // Enabling — also approves a pending self-service signup (confirms + unlocks its admins).
                var signup = scope.ServiceProvider.GetRequiredService<ITenantSignupService>();
                await signup.ApproveTenantAsync(t.Id);
                statusMessage = $"Tenant '{t.Name}' enabled";
            }
            else
            {
                var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
                await svc.UpdateAsync(t.Id, t.Name, false);
                statusMessage = $"Tenant '{t.Name}' disabled";
            }
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
        }
        await RefreshAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        showDeleteConfirm = false;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        try
        {
            await svc.PurgeAndDeleteAsync(deleteTargetId);
            statusMessage = "Tenant and all its data deleted";
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
        }
        await RefreshAsync();
    }
}

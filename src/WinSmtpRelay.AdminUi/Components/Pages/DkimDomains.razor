@page "/dkim"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject ITenantScopeFactory ScopeFactory
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>DKIM</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>DKIM Domains</h1>
        <p>Per-domain DKIM signing keys and settings</p>
    </div>
    <div class="flex gap-1 items-center">
        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/dkim/new"))">
            <LucideIcon Name="plus" /> New DKIM domain
        </BbButton>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
            <LucideIcon Name="info" /> About
        </BbButton>
    </div>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@dkimDomains">
        <BbTableHeader>
            <BbTableRow TData="DkimDomain">
                <BbTableHeaderCell TData="DkimDomain">Domain</BbTableHeaderCell>
                <BbTableHeaderCell TData="DkimDomain">Selector</BbTableHeaderCell>
                <BbTableHeaderCell TData="DkimDomain">Key</BbTableHeaderCell>
                <BbTableHeaderCell TData="DkimDomain">Enabled</BbTableHeaderCell>
                <BbTableHeaderCell TData="DkimDomain"></BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (dkimDomains.Count == 0)
            {
                <BbTableRow TData="DkimDomain">
                    <BbTableCell colspan="5" style="text-align:center;">No DKIM domains configured</BbTableCell>
                </BbTableRow>
            }
            @foreach (var d in dkimDomains)
            {
                <BbTableRow Item="@d" class="list-row-clickable" @onclick="() => Edit(d.Id)">
                    <BbTableCell>@d.Domain</BbTableCell>
                    <BbTableCell>@d.Selector</BbTableCell>
                    <BbTableCell>
                        @if (!string.IsNullOrWhiteSpace(d.PrivateKeyPem)) { <span class="badge-status badge-success">Stored</span> }
                        else if (!string.IsNullOrWhiteSpace(d.PrivateKeyPath)) { <span class="badge-status badge-muted" title="@d.PrivateKeyPath">File</span> }
                        else { <span class="badge-status badge-error">None</span> }
                    </BbTableCell>
                    <BbTableCell><span class="badge-status @(d.IsEnabled ? "badge-success" : "badge-muted")">@(d.IsEnabled ? "Yes" : "No")</span></BbTableCell>
                    <BbTableCell>
                        <div class="list-row-actions" @onclick:stopPropagation="true">
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => Edit(d.Id)">
                                <LucideIcon Name="pencil" />
                            </BbButton>
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                    @onclick="() => { deleteTargetId = d.Id; showDeleteConfirm = true; }">
                                <LucideIcon Name="trash-2" />
                            </BbButton>
                        </div>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete DKIM Domain</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will remove DKIM signing for this domain. Outbound messages will no longer be signed.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About DKIM</BbDialogTitle>
            <BbDialogDescription>DomainKeys Identified Mail signing</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>DKIM adds a cryptographic signature to outbound emails, letting receiving servers verify the message was sent by an authorized server for that domain.</p>
            <h4 style="margin-top:1rem;">Setup</h4>
            <ol style="padding-left:1.25rem;">
                <li>Add a DKIM domain here with a selector — a key pair is generated and stored securely (no files to manage).</li>
                <li>Publish the shown public key as a DNS TXT record at <code>selector._domainkey.domain</code>.</li>
                <li>Enable it; outbound mail for that domain is then signed.</li>
            </ol>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<DkimDomain> dkimDomains = [];
    private bool isLoading = true;
    private bool showHelp;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IDkimDomainService>();
        dkimDomains = await svc.GetAllAsync();
        isLoading = false;
    }

    private void Edit(int id) => Nav.NavigateTo($"/dkim/{id}");

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IDkimDomainService>();
        await svc.DeleteAsync(deleteTargetId);
        showDeleteConfirm = false;
        await RefreshAsync();
    }
}

@page "/host/audit"
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.EntityFrameworkCore
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject IServiceScopeFactory ScopeFactory
@inject IJSRuntime JS

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>Audit Log</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>Audit Log</h1>
    <p>Admin- and security-relevant events: account and membership lifecycle, break-glass, and sign-in.
       Append-only.</p>
</div>

<div class="search-bar">
    <BbNativeSelect TValue="string" @bind-Value="actionFilter" @bind-Value:after="OnFilterChanged">
        <option value="">All actions</option>
        @foreach (var a in KnownActions)
        {
            <option value="@a.Key">@a.Value</option>
        }
    </BbNativeSelect>
    <div class="search-input-wrapper">
        <BbInput @bind-Value="search" @bind-Value:after="OnFilterChanged" Placeholder="Search actor or detail…" />
    </div>
</div>

@* Infinite scroll: <Virtualize> renders only the visible rows and pulls the next window from the server
   (IAdminAuditService.QueryAsync skip/take) as you scroll — no page picker. Newest first; the <thead>
   stays sticky and the scroll happens in .app-main. *@
<table>
    <thead>
        <tr>
            <th>When</th>
            <th>Action</th>
            <th>Actor</th>
            <th>Target</th>
            <th>Tenant</th>
            <th>Detail</th>
        </tr>
    </thead>
    <tbody>
        @* SpacerElement="tr" keeps Virtualize's height-spacer elements valid inside <tbody>. *@
        <Virtualize @ref="virtualize" TItem="Row" ItemsProvider="LoadRows" Context="r"
                    ItemSize="42" SpacerElement="tr" OverscanCount="6">
            <ItemContent>
                <tr>
                    <td><LocalTime Utc="@r.When" Format="yyyy-MM-dd HH:mm:ss" /></td>
                    <td>@Humanize(r.Action)</td>
                    <td>@(r.Actor ?? "—")</td>
                    <td>@(r.Target ?? "—")</td>
                    <td>@(r.TenantId?.ToString() ?? "—")</td>
                    <td><span class="text-muted" style="font-size:0.82rem;">@r.Detail</span></td>
                </tr>
            </ItemContent>
            <Placeholder>
                <tr><td colspan="6" style="text-align:center;color:var(--muted-foreground);padding:0.75rem;">Loading…</td></tr>
            </Placeholder>
            <EmptyContent>
                <tr><td colspan="6" style="text-align:center;padding:1rem;">No audit events</td></tr>
            </EmptyContent>
        </Virtualize>
    </tbody>
</table>

@code {
    private sealed record Row(DateTimeOffset When, string Action, string? Actor, string? Target, int? TenantId, string? Detail);

    private static readonly Dictionary<string, string> KnownActions = new()
    {
        [AdminAuditActions.AdminCreated] = "Admin created",
        [AdminAuditActions.AdminDisabled] = "Admin disabled",
        [AdminAuditActions.AdminEnabled] = "Admin enabled",
        [AdminAuditActions.AdminDeleted] = "Admin deleted",
        [AdminAuditActions.AdminPasswordReset] = "Password reset",
        [AdminAuditActions.MembershipGranted] = "Membership granted",
        [AdminAuditActions.MembershipRevoked] = "Membership revoked",
        [AdminAuditActions.BreakGlassEntered] = "Break-glass access",
        [AdminAuditActions.SignInSucceeded] = "Sign-in succeeded",
        [AdminAuditActions.SignInFailed] = "Sign-in failed",
        [AdminAuditActions.SignInLink] = "Sign-in link requested",
        [AdminAuditActions.MfaEnabled] = "Two-factor enabled",
        [AdminAuditActions.MfaDisabled] = "Two-factor disabled",
        [AdminAuditActions.MfaRecoveryCodesRegenerated] = "Recovery codes regenerated",
        [AdminAuditActions.PasskeyAdded] = "Passkey added",
        [AdminAuditActions.PasskeyRemoved] = "Passkey removed",
    };

    private static string Humanize(string action) => KnownActions.TryGetValue(action, out var label) ? label : action;

    private Virtualize<Row>? virtualize;
    private string actionFilter = "";
    private string search = "";

    /// <summary>
    /// Virtualize's data source: returns the requested window (newest first) plus the total count so the
    /// scrollbar reflects the whole log. Called again as the user scrolls and on a filter change.
    /// </summary>
    private async ValueTask<ItemsProviderResult<Row>> LoadRows(ItemsProviderRequest request)
    {
        using var scope = ScopeFactory.CreateScope();
        var sp = scope.ServiceProvider;
        var audit = sp.GetRequiredService<IAdminAuditService>();
        var um = sp.GetRequiredService<UserManager<AdminUser>>();

        var (events, count) = await audit.QueryAsync(
            string.IsNullOrWhiteSpace(actionFilter) ? null : actionFilter,
            null,
            string.IsNullOrWhiteSpace(search) ? null : search,
            request.StartIndex, request.Count);

        // Resolve target emails for this window (the actor email is denormalised on the event already).
        var targetIds = events.Where(e => e.TargetUserId is not null).Select(e => e.TargetUserId!.Value).Distinct().ToList();
        var emails = targetIds.Count == 0
            ? new Dictionary<int, string?>()
            : await um.Users.Where(u => targetIds.Contains(u.Id))
                .ToDictionaryAsync(u => u.Id, u => u.Email, request.CancellationToken);

        var rows = events.Select(e => new Row(
            e.OccurredUtc, e.Action, e.ActorEmail,
            e.TargetUserId is int tid ? (emails.GetValueOrDefault(tid) ?? $"#{tid}") : null,
            e.TenantId, e.Detail)).ToList();

        return new ItemsProviderResult<Row>(rows, count);
    }

    /// <summary>A filter (action or search) changed: jump back to the newest results and re-query.</summary>
    private async Task OnFilterChanged()
    {
        try { await JS.InvokeVoidAsync("winSmtpRelay.scrollMainToTop"); } catch { /* interop not ready */ }
        if (virtualize is not null)
            await virtualize.RefreshDataAsync();
    }
}

@page "/setup"
@using WinSmtpRelay.AdminUi.Components.Account
@using Microsoft.EntityFrameworkCore
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject ITenantScopeFactory ScopeFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IAuthorizationService AuthorizationService

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>Setup</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Setup</h1>
        <p>A live checklist of what your organization needs to send mail — and the best practices that get it into the inbox.</p>
    </div>
    <div class="flex gap-1 items-center">
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="RefreshAsync" Disabled="@isLoading">
            <LucideIcon Name="refresh-cw" /> Re-check
        </BbButton>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
            <LucideIcon Name="info" /> About
        </BbButton>
    </div>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[120px] w-full mb-1" />
    <BbSkeleton Class="h-[260px] w-full" />
}
else if (readiness is null || readiness.IsHostScope)
{
    <BbCard>
        <BbCardContent>
            <div class="setup-row" style="border:none;">
                <span class="setup-row-icon s-blocked"><LucideIcon Name="building-2" Size="18" /></span>
                <div class="setup-row-main">
                    <div class="setup-row-title">Pick an organization</div>
                    <div class="setup-row-detail">Setup readiness is shown per organization. Use the tenant switcher at the top right to select one, then return here.</div>
                </div>
            </div>
        </BbCardContent>
    </BbCard>
}
else
{
    @* Inline row template, reused by every group *@
    RenderFragment<SetupItem> row = item =>
        @<div class="setup-row">
            <span class="setup-row-icon @StatusIconClass(item.Status)"><LucideIcon Name="@StatusIcon(item.Status)" Size="18" /></span>
            <div class="setup-row-main">
                <div class="setup-row-title">
                    @item.Title
                    <span class="badge-status @StatusBadge(item.Status)">@StatusText(item.Status)</span>
                </div>
                <div class="setup-row-detail">@item.Detail</div>
            </div>
            @if (!string.IsNullOrEmpty(item.ActionUrl))
            {
                <div class="setup-row-action">
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => Nav.NavigateTo(item.ActionUrl)">
                        @item.ActionLabel <LucideIcon Name="chevron-right" Size="14" />
                    </BbButton>
                </div>
            }
        </div>;

    <div class="setup-summary">
        <div class="setup-tile">
            <div class="setup-tile-icon @(readiness.CanSend ? "setup-tile-ok" : "setup-tile-bad")">
                <LucideIcon Name="@(readiness.CanSend ? "check" : "x")" Size="20" />
            </div>
            <div>
                <div class="setup-tile-label">Inbound (submission)</div>
                <div class="setup-tile-value">@(readiness.CanSend ? "Relay can receive mail" : "Not ready to receive")</div>
            </div>
        </div>
        <div class="setup-tile">
            <div class="setup-tile-icon @OutboundTileClass()">
                <LucideIcon Name="@OutboundTileIcon()" Size="20" />
            </div>
            <div>
                <div class="setup-tile-label">Outbound (delivery)</div>
                <div class="setup-tile-value">@OutboundTileText()</div>
            </div>
        </div>
        <div class="setup-tile">
            <div class="setup-tile-icon @(recDone == recTotal ? "setup-tile-ok" : "setup-tile-warn")">
                <LucideIcon Name="shield-check" Size="20" />
            </div>
            <div>
                <div class="setup-tile-label">Best practices</div>
                <div class="setup-tile-value">@recDone of @recTotal in place</div>
            </div>
        </div>
    </div>

    @if (!readiness.CanSend && nextAction is null)
    {
        @* e.g. a host admin viewing a tenant the host has not enabled yet *@
        <div class="setup-next">
            <LucideIcon Name="lock" Size="20" />
            <div class="setup-next-body">
                <div class="setup-next-title">Not ready to send</div>
                <div class="setup-next-detail">This organization isn't active yet — a host administrator must enable it.</div>
            </div>
        </div>
    }
    else if (nextAction is not null)
    {
        <div class="setup-next">
            <LucideIcon Name="arrow-right" Size="20" />
            <div class="setup-next-body">
                <div class="setup-next-title">Next: @nextAction.Title</div>
                <div class="setup-next-detail">@nextAction.Detail</div>
            </div>
            @if (!string.IsNullOrEmpty(nextAction.ActionUrl))
            {
                <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="() => Nav.NavigateTo(nextAction.ActionUrl)">
                    @nextAction.ActionLabel
                </BbButton>
            }
        </div>
    }
    else if (recDone == recTotal)
    {
        <div class="setup-next setup-next-done">
            <LucideIcon Name="check" Size="20" />
            <div class="setup-next-body">
                <div class="setup-next-title">You're all set</div>
                <div class="setup-next-detail">Basic setup is complete and the recommended deliverability best practices are in place.</div>
            </div>
        </div>
    }
    else
    {
        <div class="setup-next setup-next-done">
            <LucideIcon Name="check" Size="20" />
            <div class="setup-next-body">
                <div class="setup-next-title">No action needed right now</div>
                <div class="setup-next-detail">You can send mail. The remaining recommended items are optional for your setup or waiting on a choice you've made (for example, not restricting sender domains).</div>
            </div>
        </div>
    }

    <AuthorizeView Policy="@AuthorizationPolicies.AdminFull">
        <BbCard Class="mb-1">
            <BbCardHeader>
                <BbCardTitle>Send a test message</BbCardTitle>
                <BbCardDescription>Once the steps below are in place, send a test email to confirm outbound delivery works end to end — recipient (MX) lookup, a secure TLS connection, and DKIM signing if configured. Send to an address you control, then watch the result under Journal.</BbCardDescription>
            </BbCardHeader>
            <BbCardContent>
                <div class="test-send-row">
                    <div class="form-group">
                        <BbLabel For="from">From</BbLabel>
                        <BbInput Id="from" @bind-Value="testFrom" Placeholder="test@your-domain.com" />
                    </div>
                    <div class="form-group">
                        <BbLabel For="to">To</BbLabel>
                        <BbInput Id="to" @bind-Value="testTo" Placeholder="you@example.com" />
                    </div>
                    <div class="test-send-action">
                        <BbButton Variant="ButtonVariant.Default" @onclick="SendTestAsync" Disabled="@testSending">
                            <LucideIcon Name="send" /> @(testSending ? "Sending…" : "Send test")
                        </BbButton>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(testError))
                {
                    <p class="text-danger" style="font-size:0.8rem;margin:0.5rem 0 0;">@testError</p>
                }
                @if (!string.IsNullOrEmpty(testResult))
                {
                    <p style="font-size:0.8rem;color:var(--primary);margin:0.5rem 0 0;">@testResult</p>
                }
            </BbCardContent>
        </BbCard>
    </AuthorizeView>

    <div class="setup-group-label">Basic <span class="text-muted" style="font-weight:400;font-size:0.85rem;">— your organization and the sending identity it relays with · @basicDone of @basicTotal in place</span></div>
    <BbCard>
        <BbCardContent>
            @* Basic can otherwise read all-green while the org still can't send (no submission path),
               since Submission access lives under Recommended. Surface that gap right here. *@
            @if (readiness.TenantActive && !readiness.CanSend)
            {
                <div class="setup-cantsend">
                    <LucideIcon Name="alert-triangle" Size="16" />
                    <span>
                        This organization can't send mail yet — set up <strong>Submission access</strong>
                        (under <em>Recommended</em>): add an <a href="/smtpusers">SMTP user</a>, or allow a
                        client IP under <a href="/ip-rules">IP access rules</a>.
                    </span>
                </div>
            }
            @foreach (var item in requiredItems) { @row(item) }
            <div style="margin-top:0.85rem;">
                <BrevoConnectorInfo Compact="true" />
            </div>
        </BbCardContent>
    </BbCard>

    <div class="setup-group-label">Best practices <span class="text-muted" style="font-weight:400;font-size:0.85rem;">— secure submission and reaching the inbox · @recDone of @recTotal in place</span></div>
    <BbCard>
        <BbCardContent>
            @foreach (var item in recommendedItems) { @row(item) }
            @if (dnsLoading)
            {
                <div class="setup-row">
                    <span class="setup-row-icon s-blocked"><LucideIcon Name="loader" Size="18" /></span>
                    <div class="setup-row-main">
                        <div class="setup-row-title">Publish SPF / DKIM / DMARC <span class="badge-status badge-muted">Checking…</span></div>
                        <div class="setup-row-detail">Looking up your published DNS records…</div>
                    </div>
                </div>
            }
        </BbCardContent>
    </BbCard>

    @if (ToPublish.Count > 0)
    {
        <div class="setup-group-label">DNS records to publish <span class="text-muted" style="font-weight:400;font-size:0.85rem;">— add these at your DNS provider, then Re-check</span></div>
        <BbCard>
            <BbCardContent>
                @foreach (var entry in ToPublish)
                {
                    <div class="dns-record">
                        <div class="dns-record-head">
                            <strong>@entry.Record.RecordType</strong>
                            <span class="text-muted" style="font-size:0.8rem;">@entry.Domain</span>
                            <span class="badge-status @DnsBadgeClass(entry.Record.Status)">@entry.Record.Status</span>
                        </div>
                        <div class="dns-record-name mono text-muted">@entry.Record.RecordName</div>
                        <div class="dns-record-row">
                            <span class="dns-record-label">Expected</span>
                            <code class="mono dns-record-value">@entry.Record.Expected</code>
                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" @onclick="() => CopyAsync(entry.Record.Expected)" AriaLabel="Copy expected DNS record value" title="Copy">
                                <LucideIcon Name="copy" />
                            </BbButton>
                        </div>
                    </div>
                }
                <div style="margin-top:0.75rem;">
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/deliverability"))">
                        Open Deliverability page <LucideIcon Name="chevron-right" Size="14" />
                    </BbButton>
                </div>
            </BbCardContent>
        </BbCard>
    }

    <div class="setup-group-label">Optional <span class="text-muted" style="font-weight:400;font-size:0.85rem;">— sensible defaults already apply; tune these as needed</span></div>
    <BbCard>
        <BbCardContent>
            @foreach (var item in readiness.Optional) { @row(item) }
        </BbCardContent>
    </BbCard>
}

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Setup</BbDialogTitle>
            <BbDialogDescription>How to read this page</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>This page checks your organization's configuration in real time and groups it into three tiers:</p>
            <ul style="padding-left:1.25rem;">
                <li><strong>Basic</strong> — your organization and the sending identity the rest of the config builds on (public hostname + IP). The <em>Inbound</em> tile turns green once the org is active and clients can submit; the <em>Outbound</em> tile reflects whether mail actually leaves the relay.</li>
                <li><strong>Best practices</strong> — secure submission (SMTP credentials) plus deliverability best practice (verified domains, DKIM, published DNS). Mail can still flow without them, but authenticated submission and these records keep it out of spam.</li>
                <li><strong>Optional</strong> — refinements where a sensible default already applies (e.g. an empty list means "allow all"); these show as Done with the default noted.</li>
            </ul>
            <h4 style="margin-top:1rem;">Status badges</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Done</strong> — configured, or a sensible default already applies; nothing to do.</li>
                <li><strong>In progress</strong> — started but incomplete (e.g. some domains verified).</li>
                <li><strong>To do</strong> — a recommended step that isn't set up yet (do its prerequisite first if it mentions one).</li>
            </ul>
            <h4 style="margin-top:1rem;">Receiving mail</h4>
            <p class="text-muted">Sending (outbound) needs nothing host-side. To <em>receive</em> mail for your domains, a host administrator must run an SMTP listener (Receive Connector) and your domain's <strong>MX</strong> record must point to it.</p>
            <h4 style="margin-top:1rem;">Glossary</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>SPF</strong> — a DNS record listing which servers may send mail for your domain.</li>
                <li><strong>DKIM</strong> — a cryptographic signature on your mail proving it's genuine and unaltered.</li>
                <li><strong>DMARC</strong> — a DNS policy telling receivers what to do when SPF/DKIM fail.</li>
                <li><strong>MX</strong> — the DNS record that points a domain's incoming mail at a server.</li>
                <li><strong>TLS</strong> — encryption for the SMTP connection.</li>
            </ul>
            <p class="text-muted">Use <strong>Re-check</strong> after making changes to refresh the status.</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose><BbButton Variant="ButtonVariant.Outline">Close</BbButton></BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private TenantReadiness? readiness;
    private List<SetupItem> recommendedItems = [];
    private List<SetupItem> requiredItems = [];
    private string? identityIssue;
    private SetupItem? nextAction;
    private int recDone;
    private int recTotal;
    private int basicDone;
    private int basicTotal;
    private bool isLoading = true;
    private bool dnsLoading;
    private bool showHelp;

    // DNS is checked separately because the lookup is a live network call.
    private SetupItem? dnsItem;
    private List<DomainDnsSetup> dnsResults = [];

    // Records that have an expected value but are not yet correctly published (shown with copy buttons).
    private List<(string Domain, DnsRecordResult Record)> ToPublish => dnsResults
        .SelectMany(d => new[] { d.Spf, d.Dkim, d.Dmarc }.Select(r => (d.Domain, Record: r)))
        .Where(x => x.Record.Status != DnsRecordStatus.Ok && !string.IsNullOrEmpty(x.Record.Expected))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadBaseAsync();
        isLoading = false;
        // DNS is loaded after the first render so the checklist appears instantly.
        if (readiness is { IsHostScope: false })
        {
            dnsLoading = true;
            await PrefillTestFromAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && dnsLoading)
        {
            await LoadDnsAsync();
            try
            {
                await InvokeAsync(StateHasChanged);
            }
            catch (ObjectDisposedException) { /* circuit gone while the DNS lookup was in flight */ }
            catch (OperationCanceledException) { /* circuit gone while the DNS lookup was in flight */ }
        }
    }

    /// <summary>Re-check button: reloads both the base checklist and the live DNS state.</summary>
    private async Task RefreshAsync()
    {
        isLoading = true;
        await LoadBaseAsync();
        isLoading = false;
        if (readiness is { IsHostScope: false })
        {
            // Show the "Checking…" row while the (potentially slow) DNS lookup runs.
            dnsLoading = true;
            StateHasChanged();
            await LoadDnsAsync();
        }
    }

    private async Task LoadBaseAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantReadinessService>();
        readiness = await svc.GetAsync();
        Recompute();
        await LoadOutboundHealthAsync();
    }

    // ----- Outbound delivery health (from recent delivery-log outcomes) -----
    private enum OutboundHealth { Untested, Healthy, Degraded, Failing }
    private OutboundHealth outbound = OutboundHealth.Untested;

    /// <summary>Classifies the last few delivery attempts so the Outbound tile reflects whether mail
    /// actually leaves the relay — not just whether clients can submit to it.</summary>
    private async Task LoadOutboundHealthAsync()
    {
        outbound = OutboundHealth.Untested;
        if (readiness is null or { IsHostScope: true })
            return;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<RelayDbContext>();
            var recent = await db.DeliveryLogs.AsNoTracking()
                .OrderByDescending(l => l.Id)
                .Take(20)
                .Select(l => l.StatusCode)
                .ToListAsync();
            if (recent.Count == 0)
                return; // no attempts yet → Untested
            var delivered = recent.Count(s => s.StartsWith("2", StringComparison.Ordinal));
            outbound = delivered == 0 ? OutboundHealth.Failing
                     : delivered == recent.Count ? OutboundHealth.Healthy
                     : OutboundHealth.Degraded;
        }
        catch { outbound = OutboundHealth.Untested; }
    }

    private string OutboundTileClass() => outbound switch
    {
        OutboundHealth.Healthy => "setup-tile-ok",
        OutboundHealth.Failing => "setup-tile-bad",
        _ => "setup-tile-warn",
    };

    private string OutboundTileIcon() => outbound switch
    {
        OutboundHealth.Healthy => "check",
        OutboundHealth.Failing => "x",
        OutboundHealth.Degraded => "alert-triangle",
        _ => "circle",
    };

    private string OutboundTileText() => outbound switch
    {
        OutboundHealth.Healthy => "Can send mail",
        OutboundHealth.Degraded => "Some recent sends failed",
        OutboundHealth.Failing => "Outbound delivery failing",
        _ => "Not tested yet",
    };

    private async Task LoadDnsAsync()
    {
        identityIssue = null;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dns = scope.ServiceProvider.GetRequiredService<IDnsSetupService>();
            dnsResults = [.. await dns.CheckAllSenderDomainsAsync()];
            dnsItem = BuildDnsItem(dnsResults);
            identityIssue = await CheckSendingIdentityAsync();
        }
        catch
        {
            // A DNS lookup failure should not break the page; show it as unknown.
            dnsResults = [];
            dnsItem = new SetupItem("dns", "Publish SPF / DKIM / DMARC", SetupGroup.Recommended,
                SetupStatus.Todo, "Could not check DNS just now — try Re-check", "/deliverability", "Deliverability");
        }
        finally
        {
            dnsLoading = false;
            Recompute();
        }
    }

    /// <summary>
    /// Live correctness of the sending identity: does the public hostname resolve to a configured sending
    /// IP, and is the detected outbound IP one of them? Returns a problem description, or null when it
    /// looks fine (or there is nothing configured to validate against). Best-effort — never throws.
    /// </summary>
    private async Task<string?> CheckSendingIdentityAsync()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dns = scope.ServiceProvider.GetRequiredService<IDnsSetupService>();
            var settingsSvc = scope.ServiceProvider.GetRequiredService<IDnsSettingsService>();
            var ipDetector = scope.ServiceProvider.GetRequiredService<WinSmtpRelay.AdminUi.Services.PublicIpDetector>();

            var settings = await settingsSvc.GetAsync();
            var sendingIps = (settings.SendingIpAddresses ?? "")
                .Split([',', ';', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (sendingIps.Length == 0)
                return null; // nothing configured to validate against

            var problems = new List<string>();

            var hostname = await dns.CheckHostnameAsync();
            if (hostname.Status is DnsRecordStatus.Mismatch or DnsRecordStatus.Missing)
                problems.Add("the public hostname doesn't resolve to a sending IP");

            var outbound = await ipDetector.DetectAsync();
            var unlisted = outbound.FirstOrDefault(o => !sendingIps.Contains(o, StringComparer.OrdinalIgnoreCase));
            if (unlisted is not null)
                problems.Add($"the detected outbound IP ({unlisted}) isn't among your sending IPs");

            return problems.Count == 0
                ? null
                : $"Live check: {string.Join("; ", problems)} — mail may be rejected. Review the Deliverability page.";
        }
        catch
        {
            return null; // best-effort; never break the page
        }
    }

    private static SetupItem BuildDnsItem(List<DomainDnsSetup> results)
    {
        if (results.Count == 0)
            return new SetupItem("dns", "Publish SPF / DKIM / DMARC", SetupGroup.Recommended,
                SetupStatus.Todo, "Add a sender domain first", "/domains/sender", "Sender domains");

        // Only records with an expected value are "publishable"; NotConfigured records (e.g. DKIM not
        // set up, or no sending IPs configured) have nothing to publish yet and are covered elsewhere.
        var publishable = results
            .SelectMany(d => new[] { d.Spf, d.Dkim, d.Dmarc })
            .Where(r => r.Status != DnsRecordStatus.NotConfigured)
            .ToList();

        if (publishable.Count == 0)
            return new SetupItem("dns", "Publish SPF / DKIM / DMARC", SetupGroup.Recommended,
                SetupStatus.Todo, "Set up DKIM and the DNS recommendation settings to generate records", "/deliverability", "Deliverability");

        var ok = publishable.Count(r => r.Status == DnsRecordStatus.Ok);
        var total = publishable.Count;
        var status = ok == total ? SetupStatus.Done : ok > 0 ? SetupStatus.Partial : SetupStatus.Todo;
        var detail = ok == total
            ? $"All {total} records published across {results.Count} domain{(results.Count == 1 ? "" : "s")}"
            : $"{ok} of {total} records published";
        return new SetupItem("dns", "Publish SPF / DKIM / DMARC", SetupGroup.Recommended,
            status, detail, "/deliverability", "Deliverability");
    }

    private void Recompute()
    {
        if (readiness is null || readiness.IsHostScope)
            return;
        recommendedItems = [.. readiness.Recommended];
        if (dnsItem is not null)
            recommendedItems.Add(dnsItem);
        recTotal = recommendedItems.Count;
        recDone = recommendedItems.Count(i => i.Status == SetupStatus.Done);
        // Basic items, with the live sending-identity correctness check folded into the sending-identity
        // row — downgraded to "In progress" when the public hostname / outbound IP don't match the
        // configured sending IPs (a problem that "the fields are filled in" alone cannot detect).
        requiredItems = [.. readiness.Required];
        if (identityIssue is not null)
        {
            var idx = requiredItems.FindIndex(x => x.Key == "sending-identity");
            if (idx >= 0)
                requiredItems[idx] = requiredItems[idx] with
                {
                    Status = SetupStatus.Partial,
                    Detail = identityIssue,
                    ActionUrl = "/deliverability",
                    ActionLabel = "Deliverability"
                };
        }
        basicTotal = requiredItems.Count;
        basicDone = requiredItems.Count(i => i.Status == SetupStatus.Done);
        // The submission path determines whether mail can flow at all, so when the tenant can't send,
        // surface that item first — even though it now lives under Recommended. Otherwise fall back to
        // the usual Basic-then-Recommended attention order.
        var submissionBlocker = readiness.CanSend
            ? null
            : readiness.Items.FirstOrDefault(i => i.Key == "smtp-users" && i.NeedsAttention);
        nextAction = submissionBlocker
                     ?? requiredItems.FirstOrDefault(i => i.NeedsAttention)
                     ?? recommendedItems.FirstOrDefault(i => i.NeedsAttention);
    }

    private async Task CopyAsync(string value)
    {
        // clipboard API throws on non-secure origins or when permission is denied.
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", value); }
        catch { /* best-effort copy */ }
    }

    // ----- Test message -----
    private string testFrom = "";
    private string testTo = "";
    private bool testSending;
    private string? testResult;
    private string? testError;

    /// <summary>Prefills the From field with the tenant's first sender domain (best-effort).</summary>
    private async Task PrefillTestFromAsync()
    {
        if (!string.IsNullOrWhiteSpace(testFrom))
            return;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var senders = scope.ServiceProvider.GetRequiredService<IAcceptedSenderDomainService>();
            var domains = await senders.GetAllAsync();
            if (domains.Count > 0)
                testFrom = $"test@{domains[0].Domain}";
        }
        catch { /* prefill is best-effort */ }
    }

    private async Task SendTestAsync()
    {
        testResult = null;
        testError = null;
        var from = testFrom.Trim();
        var to = testTo.Trim();
        if (!IsEmail(from)) { testError = "Enter a valid From address."; return; }
        if (!IsEmail(to)) { testError = "Enter a valid recipient address."; return; }
        if (readiness?.TenantId is not { } tenantId) { testError = "No tenant in scope."; return; }

        // The AuthorizeView around the button only hides UI — the circuit handler must re-check the
        // policy server-side, otherwise a read-only viewer could invoke it over the circuit.
        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            if (!(await AuthorizationService.AuthorizeAsync(user, AuthorizationPolicies.AdminFull)).Succeeded)
            {
                testError = "You don't have permission to send test messages.";
                return;
            }
        }

        testSending = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();

            // Direct queue injection bypasses the SMTP ingress checks (RelayMailboxFilter), so enforce
            // the sender-domain restriction here: when the tenant lists sender domains, the From must be
            // one of them. With no sender domains configured the relay accepts any sender, so allow it.
            var senders = scope.ServiceProvider.GetRequiredService<IAcceptedSenderDomainService>();
            var domains = await senders.GetAllAsync();
            if (domains.Count > 0)
            {
                var fromDomain = from[(from.IndexOf('@') + 1)..];
                if (!domains.Any(d => string.Equals(d.Domain, fromDomain, StringComparison.OrdinalIgnoreCase)))
                {
                    testError = $"The From domain must be one of your sender domains: {string.Join(", ", domains.Select(d => d.Domain))}.";
                    return;
                }
            }

            var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
            var body = "This is a test message from the WIN-SMTP-RELAY Setup page, " +
                       "sent to verify that outbound delivery works.\r\n";
            await AccountEmail.EnqueueAsync(
                queue, from, to, "WIN-SMTP-RELAY test message", body, tenantId);
            testResult = $"Queued for delivery to {to}. Watch the result under Journal.";
        }
        catch (Exception ex)
        {
            testError = $"Could not queue the test message: {ex.Message}";
        }
        finally
        {
            testSending = false;
        }
    }

    /// <summary>Accepts a single bare email address (no display name, no second address).</summary>
    private static bool IsEmail(string v)
        => !string.IsNullOrWhiteSpace(v)
           && !v.Contains(' ')
           && System.Net.Mail.MailAddress.TryCreate(v, out var addr)
           && string.Equals(addr.Address, v, StringComparison.OrdinalIgnoreCase);

    private static string DnsBadgeClass(DnsRecordStatus status) => status switch
    {
        DnsRecordStatus.Ok => "badge-success",
        DnsRecordStatus.Mismatch => "badge-warning",
        DnsRecordStatus.Missing => "badge-error",
        _ => "badge-muted"
    };

    private static string StatusIcon(SetupStatus s) => s switch
    {
        SetupStatus.Done => "check",
        SetupStatus.Partial => "clock",
        SetupStatus.Todo => "circle",
        SetupStatus.Blocked => "lock",
        _ => "info"
    };

    private static string StatusIconClass(SetupStatus s) => s switch
    {
        SetupStatus.Done => "s-done",
        SetupStatus.Partial => "s-partial",
        SetupStatus.Todo => "s-todo",
        SetupStatus.Blocked => "s-blocked",
        _ => "s-permissive"
    };

    private static string StatusBadge(SetupStatus s) => s switch
    {
        SetupStatus.Done => "badge-success",
        SetupStatus.Partial => "badge-info",
        SetupStatus.Todo => "badge-warning",
        _ => "badge-muted"
    };

    private static string StatusText(SetupStatus s) => s switch
    {
        SetupStatus.Done => "Done",
        SetupStatus.Partial => "In progress",
        SetupStatus.Todo => "To do",
        SetupStatus.Blocked => "Blocked",
        _ => "Default"
    };

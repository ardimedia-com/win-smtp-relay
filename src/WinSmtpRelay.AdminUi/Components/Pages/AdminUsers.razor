@page "/adminusers"
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using WinSmtpRelay.Core.Interfaces
@attribute [Authorize(Policy = AuthorizationPolicies.AdminFull)]
@inject IServiceScopeFactory ScopeFactory
@inject ICurrentTenant CurrentTenant
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>Admin Users</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Admin Users</h1>
        <p>
            Web-admin login accounts (separate from SMTP relay users).
            @if (CurrentTenant.FilterEnabled)
            {
                <text>Managing tenant <strong>#@CurrentTenant.FilterTenantId</strong>.</text>
            }
            else
            {
                <text>Managing <strong>host administrators</strong>. Switch to a tenant to manage its admins.</text>
            }
        </p>
    </div>
    <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/adminusers/new"))">
        <LucideIcon Name="user-plus" /> New admin
    </BbButton>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[200px] w-full" />
}
else
{
    <BbTable Data="@rows">
        <BbTableHeader>
            <BbTableRow TData="Row">
                <BbTableHeaderCell TData="Row">Email</BbTableHeaderCell>
                <BbTableHeaderCell TData="Row">Role</BbTableHeaderCell>
                <BbTableHeaderCell TData="Row">Tenant</BbTableHeaderCell>
                <BbTableHeaderCell TData="Row">Status</BbTableHeaderCell>
                <BbTableHeaderCell TData="Row"></BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (rows.Count == 0)
            {
                <BbTableRow TData="Row"><BbTableCell colspan="5" style="text-align:center;">No admin users</BbTableCell></BbTableRow>
            }
            @foreach (var r in rows)
            {
                <BbTableRow Item="@r" class="list-row-clickable" @onclick="() => Edit(r.Id)">
                    <BbTableCell>@r.Email</BbTableCell>
                    <BbTableCell>@r.Role</BbTableCell>
                    <BbTableCell>@(r.TenantId?.ToString() ?? "host")</BbTableCell>
                    <BbTableCell><span class="badge-status @(r.Enabled ? "" : "badge-muted")">@(r.Enabled ? "Enabled" : "Disabled")</span></BbTableCell>
                    <BbTableCell>
                        <div class="list-row-actions" @onclick:stopPropagation="true">
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => Edit(r.Id)">
                                <LucideIcon Name="pencil" />
                            </BbButton>
                            @if (!r.IsSelf)
                            {
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                        @onclick="() => { deleteTargetId = r.Id; showDelete = true; }">
                                    <LucideIcon Name="trash-2" />
                                </BbButton>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:0.75rem;">you</span>
                            }
                        </div>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDelete">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete admin user</BbAlertDialogTitle>
            <BbAlertDialogDescription>This permanently removes the login account.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel><BbButton Variant="ButtonVariant.Outline">Cancel</BbButton></BbAlertDialogCancel>
            <BbAlertDialogAction><BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton></BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

@code {
    private sealed record Row(int Id, string Email, string Role, int? TenantId, bool Enabled, bool IsSelf);

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<Row> rows = [];
    private bool isLoading = true;
    private bool showDelete;
    private int deleteTargetId;
    private int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var idVal = (await AuthState).User.FindFirstValue(ClaimTypes.NameIdentifier);
            int.TryParse(idVal, out currentUserId);
        }
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var um = scope.ServiceProvider.GetRequiredService<UserManager<AdminUser>>();

        var query = um.Users.AsQueryable();
        if (CurrentTenant.FilterEnabled)
        {
            var tid = CurrentTenant.FilterTenantId;
            query = query.Where(u => u.TenantId == tid);
        }
        var users = await query.OrderBy(u => u.Email).ToListAsync();

        rows = [];
        foreach (var u in users)
        {
            var roles = await um.GetRolesAsync(u);
            var enabled = u.LockoutEnd is null || u.LockoutEnd <= DateTimeOffset.UtcNow;
            rows.Add(new Row(u.Id, u.Email ?? u.UserName ?? "", string.Join(", ", roles), u.TenantId, enabled, u.Id == currentUserId));
        }
        isLoading = false;
    }

    private void Edit(int id) => Nav.NavigateTo($"/adminusers/{id}");

    private async Task ConfirmDeleteAsync()
    {
        showDelete = false;
        using var scope = ScopeFactory.CreateScope();
        var um = scope.ServiceProvider.GetRequiredService<UserManager<AdminUser>>();
        var user = await um.Users.FirstOrDefaultAsync(u => u.Id == deleteTargetId);
        if (user is not null && user.Id != currentUserId && InScope(user))
            await um.DeleteAsync(user);
        await RefreshAsync();
    }

    // Enforce tenant scope (AdminUser is not query-filtered).
    private bool InScope(AdminUser user)
        => !CurrentTenant.FilterEnabled || user.TenantId == CurrentTenant.FilterTenantId;
}

@page "/"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject ITenantScopeFactory ScopeFactory
@inject NavigationManager Navigation
@inject IQueueDepthRecorder QueueDepthRecorder
@inject WinSmtpRelay.AdminUi.Services.BrowserTimeService BrowserTime
@inject IActivityFeed Feed
@inject ICurrentTenant CurrentTenant
@implements IAsyncDisposable

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Dashboard</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Dashboard</h1>
        <p>Server overview and recent activity</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

@if (!loaded)
{
    <div class="card-grid">
        @for (var i = 0; i < 3; i++)
        {
            <BbCard>
                <BbCardHeader><BbSkeleton Class="h-4 w-24" /></BbCardHeader>
                <BbCardContent><BbSkeleton Class="h-8 w-16" /></BbCardContent>
            </BbCard>
        }
    </div>
}
else
{
    <div class="card-grid">
        <BbCard>
            <BbCardHeader>
                <BbCardDescription>Queue Depth</BbCardDescription>
            </BbCardHeader>
            <BbCardContent>
                <div class="stat-value @(queueDepth > 100 ? "warning" : "")">@queueDepth</div>
            </BbCardContent>
        </BbCard>
        <BbCard>
            <BbCardHeader>
                <BbCardDescription>Server Uptime</BbCardDescription>
            </BbCardHeader>
            <BbCardContent>
                <div class="stat-value" style="font-size:1.2rem">@uptime</div>
            </BbCardContent>
        </BbCard>
        <BbCard>
            <BbCardHeader>
                <BbCardDescription>Version</BbCardDescription>
            </BbCardHeader>
            <BbCardContent>
                <div class="stat-value" style="font-size:1.2rem">@version</div>
            </BbCardContent>
        </BbCard>
    </div>
}

<h2 style="font-size:1.1rem; margin-bottom:0.75rem">Email Volume</h2>

<BbCard>
    <BbCardContent>
        <BbTabs DefaultValue="day" @bind-Value="activeTab" @bind-Value:after="OnTabChanged">
            <BbTabsList>
                <BbTabsTrigger Value="minute">Minute</BbTabsTrigger>
                <BbTabsTrigger Value="hour">Hour</BbTabsTrigger>
                <BbTabsTrigger Value="day">Day</BbTabsTrigger>
                <BbTabsTrigger Value="month">Month</BbTabsTrigger>
            </BbTabsList>

            <BbTabsContent Value="minute">
                @if (minuteChartData is not null)
                {
                    <BbChart Data="@minuteChartData" Height="300px">
                        <BbXAxis DataKey="label" />
                        <BbYAxis />
                        <BbChartTooltip />
                        <BbChartLegend />
                        <BbArea DataKey="sent" Name="Sent" Color="var(--success)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                        <BbArea DataKey="failed" Name="Failed" Color="var(--destructive)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                        <BbLine DataKey="queue" Name="Queue Depth" Color="var(--chart-3)" Curve="CurveType.Smooth" StrokeWidth="2" />
                    </BbChart>
                }
                else
                {
                    <BbSkeleton Class="h-[300px] w-full" />
                }
            </BbTabsContent>

            <BbTabsContent Value="hour">
                @if (chartData is not null)
                {
                    <BbAreaChart Data="@chartData" Height="300px">
                        <BbXAxis DataKey="label" />
                        <BbYAxis />
                        <BbChartTooltip />
                        <BbChartLegend />
                        <BbArea DataKey="sent" Name="Sent" Color="var(--success)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                        <BbArea DataKey="failed" Name="Failed" Color="var(--destructive)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                    </BbAreaChart>
                }
                else
                {
                    <BbSkeleton Class="h-[300px] w-full" />
                }
            </BbTabsContent>

            <BbTabsContent Value="day">
                @if (chartData is not null)
                {
                    <BbAreaChart Data="@chartData" Height="300px">
                        <BbXAxis DataKey="label" />
                        <BbYAxis />
                        <BbChartTooltip />
                        <BbChartLegend />
                        <BbArea DataKey="sent" Name="Sent" Color="var(--success)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                        <BbArea DataKey="failed" Name="Failed" Color="var(--destructive)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                    </BbAreaChart>
                }
                else
                {
                    <BbSkeleton Class="h-[300px] w-full" />
                }
            </BbTabsContent>

            <BbTabsContent Value="month">
                @if (chartData is not null)
                {
                    <BbAreaChart Data="@chartData" Height="300px">
                        <BbXAxis DataKey="label" />
                        <BbYAxis />
                        <BbChartTooltip />
                        <BbChartLegend />
                        <BbArea DataKey="sent" Name="Sent" Color="var(--success)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                        <BbArea DataKey="failed" Name="Failed" Color="var(--destructive)" FillOpacity="0.4" Curve="CurveType.Smooth" />
                    </BbAreaChart>
                }
                else
                {
                    <BbSkeleton Class="h-[300px] w-full" />
                }
            </BbTabsContent>
        </BbTabs>
    </BbCardContent>
</BbCard>

<h2 style="font-size:1.1rem; margin:1.5rem 0 0.75rem">Recent Messages</h2>

@if (!loaded)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@recentMessages">
        <BbTableHeader>
            <BbTableRow TData="QueuedMessage">
                <BbTableHeaderCell TData="QueuedMessage">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Sender</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Recipients</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Status</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Created</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (recentMessages.Count == 0)
            {
                <BbTableRow TData="QueuedMessage">
                    <BbTableCell colspan="5" class="text-muted" style="text-align:center;">No messages in queue</BbTableCell>
                </BbTableRow>
            }
            @foreach (var msg in recentMessages)
            {
                <BbTableRow Item="@msg">
                    <BbTableCell class="mono">@msg.Id</BbTableCell>
                    <BbTableCell>@msg.Sender</BbTableCell>
                    <BbTableCell>@msg.Recipients</BbTableCell>
                    <BbTableCell><span class="badge-status @GetBadgeCss(msg.Status)">@msg.Status</span></BbTableCell>
                    <BbTableCell><LocalTime Utc="@msg.CreatedUtc" /></BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About the Dashboard</BbDialogTitle>
            <BbDialogDescription>Understanding the server overview</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The Dashboard provides an at-a-glance overview of your WIN-SMTP-RELAY server.
            </p>
            <h4 style="margin-top:1rem;">Stat cards</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Queue Depth</strong> &mdash; number of messages currently waiting to be delivered. A high number may indicate delivery issues.</li>
                <li><strong>Server Uptime</strong> &mdash; how long the WIN-SMTP-RELAY Windows service has been running.</li>
                <li><strong>Version</strong> &mdash; the installed software version.</li>
            </ul>
            <h4 style="margin-top:1rem;">Email Volume</h4>
            <p>
                Shows email throughput over four time windows. The <strong>Minute</strong> and <strong>Hour</strong> tabs
                update in real time via SignalR. The <strong>Day</strong> and <strong>Month</strong> tabs refresh when selected.
            </p>
            <h4 style="margin-top:1rem;">Recent Messages</h4>
            <p>
                Shows the 10 most recent messages across all statuses (queued, delivered, bounced).
                This gives you a quick view of what is flowing through the relay.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private bool loaded;
    private int queueDepth;
    private string uptime = "";
    private string version = "";
    private IReadOnlyList<QueuedMessage> recentMessages = [];

    private DateTime processStartTime;

    // Chart state
    private string activeTab = "day";
    private object[]? chartData;
    private object[]? minuteChartData;
    private bool _disposed;
    private System.Threading.Timer? refreshTimer;
    private System.Threading.Timer? uptimeTimer;
    private System.Threading.Timer? minuteRefreshTimer;
    private System.Threading.Timer? _chartDebounceTimer;
    private int _minuteRefreshing; // re-entrancy gate for the per-second minute timer

    protected override async Task OnInitializedAsync()
    {
        // Re-render chart labels in local time once the browser time zone is detected.
        BrowserTime.Changed += OnTimeZoneChanged;

        // Load stat cards + recent messages (queue depth is tenant-scoped — see ReadQueueDepthAsync)
        queueDepth = await ReadQueueDepthAsync();
        using (var scope = ScopeFactory.CreateScope())
        {
            var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
            recentMessages = await queue.GetRecentAsync(10);
        }

        processStartTime = System.Diagnostics.Process.GetCurrentProcess().StartTime;
        UpdateUptime();

        version = typeof(Dashboard).Assembly.GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>()?.InformationalVersion
                  ?? typeof(Dashboard).Assembly.GetName().Version?.ToString()
                  ?? "dev";
        loaded = true;

        // Load initial chart data
        await LoadChartDataAsync();

        // Subscribe to the in-process activity feed for live chart + queue-depth updates.
        Feed.Received += OnActivity;

        // Periodic refresh: uptime every 30s
        uptimeTimer = new System.Threading.Timer(_ =>
        {
            if (_disposed) return;
            UpdateUptime();
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        // Boundary-aligned refresh: hour tab on full minute, day on full hour, month on midnight
        ScheduleNextBoundaryRefresh();

        // Every second: refresh minute chart from server-side queue depth history
        minuteRefreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            // A periodic timer fires again even if the previous async callback hasn't finished; gate
            // re-entrancy so overlapping runs don't race on the shared chart/queue-depth state.
            if (Interlocked.Exchange(ref _minuteRefreshing, 1) == 1) return;
            try
            {
                var depth = await ReadQueueDepthAsync();
                if (_disposed) return;
                await InvokeAsync(async () =>
                {
                    if (_disposed) return;
                    queueDepth = depth;
                    if (activeTab == "minute")
                        await LoadChartDataAsync();
                    StateHasChanged();
                });
            }
            finally { Interlocked.Exchange(ref _minuteRefreshing, 0); }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateUptime()
    {
        var elapsed = DateTime.Now - processStartTime;
        uptime = elapsed.Days > 0
            ? $"{elapsed.Days}d {elapsed.Hours}h {elapsed.Minutes}m"
            : $"{elapsed.Hours}h {elapsed.Minutes}m";
    }

    private void OnActivity(ActivityEvent e)
    {
        if (_disposed) return;
        // React only to this circuit's scope (a host admin in "All tenants" sees everything).
        if (!CurrentTenant.Owns(e)) return;

        switch (e.Kind)
        {
            case ActivityKind.DeliveryAttempt:
                ScheduleChartRefresh();
                break;
            case ActivityKind.QueueChanged:
            case ActivityKind.MessageReceived:
                _ = InvokeAsync(async () =>
                {
                    if (_disposed) return;
                    queueDepth = await ReadQueueDepthAsync();
                    await RefreshRecentMessagesAsync();
                    StateHasChanged();
                });
                break;
        }
    }

    private async Task RefreshRecentMessagesAsync()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
            recentMessages = await queue.GetRecentAsync(10);
        }
        catch { }
    }

    /// <summary>
    /// Debounces chart refresh so rapid-fire DeliveryAttempt events
    /// (one per recipient) don't cause N concurrent DB queries.
    /// </summary>
    private void ScheduleChartRefresh()
    {
        _chartDebounceTimer?.Dispose();
        _chartDebounceTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            if (activeTab == "minute" || activeTab == "hour")
            {
                await LoadChartDataAsync();
                if (!_disposed) await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromMilliseconds(500), Timeout.InfiniteTimeSpan);
    }

    private void ScheduleNextBoundaryRefresh()
    {
        var now = DateTime.UtcNow;
        // Next full minute
        var nextMinute = now.AddSeconds(60 - now.Second).AddMilliseconds(-now.Millisecond);
        var delay = nextMinute - now;
        if (delay <= TimeSpan.Zero) delay = TimeSpan.FromSeconds(1);

        refreshTimer?.Dispose();
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            var utcNow = DateTime.UtcNow;

            // Every full minute: refresh hour tab
            if (activeTab == "hour")
            {
                await LoadChartDataAsync();
                if (!_disposed) await InvokeAsync(StateHasChanged);
            }

            // Every full hour: refresh day tab
            if (utcNow.Minute == 0 && activeTab == "day")
            {
                await LoadChartDataAsync();
                if (!_disposed) await InvokeAsync(StateHasChanged);
            }

            // At midnight: refresh month tab
            if (utcNow.Hour == 0 && utcNow.Minute == 0 && activeTab == "month")
            {
                await LoadChartDataAsync();
                if (!_disposed) await InvokeAsync(StateHasChanged);
            }

            // Re-schedule aligned to the next full minute
            if (!_disposed) ScheduleNextBoundaryRefresh();
        }, null, delay, Timeout.InfiniteTimeSpan);
    }

    private async Task OnTabChanged()
    {
        chartData = null;
        minuteChartData = null;
        await LoadChartDataAsync();
    }

    private void OnTimeZoneChanged() => InvokeAsync(async () =>
    {
        if (_disposed) return;
        await LoadChartDataAsync();
        StateHasChanged();
    });

    // Tenant-scoped queue depth: a tenant admin sees only their own pending count, never the host-wide
    // total. Only host scope uses the background recorder (which counts across all tenants).
    private async Task<int> ReadQueueDepthAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var current = scope.ServiceProvider.GetRequiredService<ICurrentTenant>();
        if (current.IsHostScope)
            return QueueDepthRecorder.CurrentDepth;
        var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
        return await queue.GetQueueDepthAsync();
    }

    private async Task LoadChartDataAsync()
    {
        // Compute off the dispatcher, then assign the shared render fields ON the dispatcher, so timer
        // callbacks (which run on the thread pool) never tear state the renderer is reading.
        var forMinute = activeTab == "minute";
        object[] data = [];
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var stats = scope.ServiceProvider.GetRequiredService<IStatisticsService>();

            if (forMinute)
            {
                var buckets = await stats.GetLiveStatisticsAsync();
                var depthHistory = QueueDepthRecorder.GetHistory();
                data = buckets.Select(b =>
                {
                    var depth = depthHistory.TryGetValue(b.Label, out var v) ? v : 0;
                    return (object)new { label = BrowserTime.Format(b.TimestampUtc, "HH:mm:ss"), sent = b.Sent, failed = b.Failed, queue = depth };
                }).ToArray();
            }
            else if (activeTab == "month")
            {
                var monthly = await stats.GetMonthlyStatisticsAsync();
                data = monthly.Select(m => (object)new { label = m.Date, sent = m.Sent, failed = m.Failed }).ToArray();
            }
            else
            {
                var buckets = activeTab switch
                {
                    "hour" => await stats.GetHourlyStatisticsAsync(),
                    "day" => await stats.GetDailyStatisticsAsync(),
                    _ => await stats.GetHourlyStatisticsAsync()
                };
                data = buckets.Select(b => (object)new { label = BrowserTime.Format(b.TimestampUtc, "HH:mm"), sent = b.Sent, failed = b.Failed }).ToArray();
            }
        }
        catch
        {
            data = [];
        }

        await InvokeAsync(() =>
        {
            if (_disposed) return;
            if (forMinute) minuteChartData = data;
            else chartData = data;
            StateHasChanged();
        });
    }

    private static string GetBadgeCss(MessageStatus status) => status switch
    {
        MessageStatus.Delivered => "badge-success",
        MessageStatus.Failed or MessageStatus.Bounced => "badge-error",
        MessageStatus.Queued => "badge-muted",
        _ => "badge-muted"
    };

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        Feed.Received -= OnActivity;
        BrowserTime.Changed -= OnTimeZoneChanged;
        _chartDebounceTimer?.Dispose();
        if (minuteRefreshTimer is not null)
            await minuteRefreshTimer.DisposeAsync();
        if (uptimeTimer is not null)
            await uptimeTimer.DisposeAsync();
        if (refreshTimer is not null)
            await refreshTimer.DisposeAsync();
    }
}

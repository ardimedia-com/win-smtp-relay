@page "/health"
@page "/deliverability"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@implements IDisposable
@inject ITenantScopeFactory ScopeFactory
@inject IPublicSuffixService PublicSuffix
@inject WinSmtpRelay.AdminUi.Services.PublicIpDetector IpDetector
@inject IJSRuntime JS

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>Deliverability</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Deliverability</h1>
        <p>The DNS your domains and sending IPs need so mail is trusted and delivered — SPF, DKIM, DMARC, MX, reverse DNS, and the public hostname. Status reflects live DNS; publish the expected values at your provider and Re-check.</p>
    </div>
    <div class="flex gap-1 items-center">
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="nowrap" @onclick="RefreshAsync" Disabled="@isLoading">
            <LucideIcon Name="refresh-cw" /> Re-check all
        </BbButton>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
            <LucideIcon Name="info" /> About
        </BbButton>
    </div>
</div>

@if (isLoading)
{
    <BbCard>
        <BbCardContent>
            <div style="display:flex;align-items:center;gap:0.75rem;padding:0.4rem 0 0.8rem;">
                <span class="spin" style="display:inline-flex;"><LucideIcon Name="loader-circle" /></span>
                <span>Checking live DNS records@(totalChecks > 0 ? $" — {completedChecks} of {totalChecks}" : "")…</span>
            </div>
            <BbSkeleton Class="h-[140px] w-full" />
        </BbCardContent>
    </BbCard>
}
else if (loadError is not null)
{
    <p class="text-danger">@loadError</p>
}
else
{
    @* Reusable card renderer for a titled group of DNS record checks *@
    RenderFragment<CheckGroup> groupCard = g =>
        @<BbCard Class="mb-1">
            <BbCardHeader>
                <BbCardTitle>@g.Title</BbCardTitle>
                @if (!string.IsNullOrEmpty(g.Subtitle)) { <BbCardDescription>@g.Subtitle</BbCardDescription> }
            </BbCardHeader>
            <BbCardContent>
                @if (g.Alignment is { } al)
                {
                    <div class="dns-record" style="border-left:3px solid @AlignmentColor(al.Verdict);padding-left:0.75rem;">
                        <div class="dns-record-head">
                            <strong>DMARC outcome</strong>
                            <span class="badge-status @AlignmentBadge(al.Verdict)">@AlignmentText(al.Verdict)</span>
                        </div>
                        <div class="text-muted" style="font-size:0.8rem;">@al.Summary</div>
                    </div>
                }
                @foreach (var rec in g.Records)
                {
                    <div class="dns-record">
                        <div class="dns-record-head">
                            <strong>@rec.RecordType</strong>
                            <span class="badge-status @BadgeClass(rec.Status)">@rec.Status</span>
                        </div>
                        <div class="dns-record-name mono text-muted">@rec.RecordName</div>
                        <div class="text-muted" style="font-size:0.8rem;">@rec.Explanation</div>
                        @if (!string.IsNullOrEmpty(rec.Expected))
                        {
                            <div class="dns-record-row">
                                <span class="dns-record-label">Expected</span>
                                <code class="mono dns-record-value">@rec.Expected</code>
                                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" @onclick="() => CopyAsync(rec.Expected)" title="Copy">
                                    <LucideIcon Name="copy" />
                                </BbButton>
                            </div>
                        }
                        <div class="dns-record-row">
                            <span class="dns-record-label">Found</span>
                            <code class="mono dns-record-value">@(string.IsNullOrEmpty(rec.Live) ? "— not found —" : rec.Live)</code>
                        </div>
                        @if (!string.IsNullOrEmpty(rec.Suggested))
                        {
                            <div class="dns-record-row">
                                <span class="dns-record-label">To publish</span>
                                <code class="mono dns-record-value dns-record-suggested">@rec.Suggested</code>
                                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => CopyAsync(rec.Suggested!)" title="Copy">
                                    <LucideIcon Name="copy" /> Copy
                                </BbButton>
                            </div>
                        }
                    </div>
                }
                @if (!string.IsNullOrEmpty(g.ActionHref))
                {
                    <a href="@g.ActionHref" style="text-decoration:none;display:inline-block;margin-top:0.5rem;">
                        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
                            <LucideIcon Name="arrow-right" /> @g.ActionLabel
                        </BbButton>
                    </a>
                }
            </BbCardContent>
        </BbCard>;

    <BbTabs DefaultValue="ip" @bind-Value="activeTab">
        <BbTabsList>
            <BbTabsTrigger Value="ip">IP addresses</BbTabsTrigger>
            <BbTabsTrigger Value="dns">Check DNS</BbTabsTrigger>
        </BbTabsList>

        <BbTabsContent Value="ip">
            <BbCard Class="mb-1">
                <BbCardHeader>
                    <BbCardTitle>Relay security</BbCardTitle>
                    <BbCardDescription>Who may send to external (non-hosted) recipients through this relay</BbCardDescription>
                </BbCardHeader>
                <BbCardContent>
                    <div class="dns-record">
                        <div class="dns-record-head">
                            <strong>Open-relay protection</strong>
                            <span class="badge-status badge-success">Active</span>
                        </div>
                        <div class="text-muted" style="font-size:0.8rem;">
                            Relaying to a domain this server does not host always requires SMTP authentication or an
                            explicit allow-IP rule. This is enforced in code and cannot be turned off by configuration.
                        </div>
                        <div class="dns-record-row">
                            <span class="dns-record-label">Unauth. relay</span>
                            <span class="dns-record-value">
                                @if (relayExplicitAllow.Count == 0)
                                {
                                    <text>Only authenticated SMTP users may relay (no allow-IP rule grants it).</text>
                                }
                                else
                                {
                                    <text>Allowed without auth from: <code class="mono">@string.Join(", ", relayExplicitAllow)</code></text>
                                }
                            </span>
                        </div>
                        @if (relayAnyAllow)
                        {
                            <div class="dns-record-row">
                                <span class="dns-record-label"><span class="badge-status badge-warning">Note</span></span>
                                <span class="dns-record-value text-muted" style="font-size:0.8rem;">
                                    An &ldquo;any&rdquo; (<code class="mono">0.0.0.0/0</code> / <code class="mono">::/0</code>) allow rule is
                                    configured. It permits connections but does <strong>not</strong> authorize external relaying — use SMTP
                                    AUTH or a specific allow-IP rule for that.
                                </span>
                            </div>
                        }
                    </div>
                </BbCardContent>
            </BbCard>
            @if (outboundIpGroup is not null) { @groupCard(outboundIpGroup) }
            @if (hostnameGroup is not null) { @groupCard(hostnameGroup) }
            @if (ipGroups.Count == 0)
            {
                <p class="text-muted">No sending IPs configured. Add them under <a href="/settings?tab=dns">Settings → Sending identity</a> so SPF and reverse-DNS can be checked.</p>
            }
            @foreach (var g in ipGroups) { @groupCard(g) }
        </BbTabsContent>

        <BbTabsContent Value="dns">
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Check a domain</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <div class="form-group" style="max-width:480px;">
                        <BbLabel For="domain">Domain</BbLabel>
                        <BbInput Id="domain" @bind-Value="adHocDomain" Placeholder="example.com" />
                        @if (adHocError is not null)
                        {
                            <p class="text-danger" style="font-size:0.8rem;margin-top:0.25rem;">@adHocError</p>
                        }
                    </div>
                </BbCardContent>
                <BbCardFooter>
                    <BbButton Variant="ButtonVariant.Default" @onclick="CheckAdHocAsync" Disabled="@string.IsNullOrWhiteSpace(adHocDomain)">
                        <LucideIcon Name="search" /> Check
                    </BbButton>
                </BbCardFooter>
            </BbCard>

            @{
                var pendingDomains = candidateDomains
                    .Where(c => !senderGroups.Any(g => g.Title == c.Domain)
                                && !inboundGroups.Any(g => g.Title == c.Domain)
                                && !adHocGroups.Any(g => g.Title == c.Domain))
                    .ToList();
            }
            @if (pendingDomains.Count > 0 || candidateIps.Count > 0)
            {
                <BbCard Class="mb-1">
                    <BbCardHeader>
                        <BbCardTitle>Used in your configuration</BbCardTitle>
                        <BbCardDescription>Domains and IPs found in your settings — check the ones that send or receive mail.</BbCardDescription>
                    </BbCardHeader>
                    <BbCardContent>
                        @if (pendingDomains.Count > 0)
                        {
                            <div class="health-candidates">
                                @foreach (var c in pendingDomains)
                                {
                                    <div class="health-candidate">
                                        <div>
                                            <code class="mono">@c.Domain</code>
                                            <span class="text-muted" style="font-size:0.78rem;margin-left:0.4rem;">@c.Source</span>
                                        </div>
                                        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => CheckCandidateAsync(c.Domain)">
                                            <LucideIcon Name="search" /> Check
                                        </BbButton>
                                    </div>
                                }
                            </div>
                        }
                        @if (candidateIps.Count > 0)
                        {
                            <div class="health-candidates" style="margin-top:0.6rem;">
                                @foreach (var ip in candidateIps)
                                {
                                    <div class="health-candidate">
                                        <div>
                                            <code class="mono">@ip</code>
                                            <span class="text-muted" style="font-size:0.78rem;margin-left:0.4rem;">sending / egress IP</span>
                                        </div>
                                        <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" @onclick="ShowIpChecks">
                                            View IP checks
                                        </BbButton>
                                    </div>
                                }
                            </div>
                        }
                    </BbCardContent>
                </BbCard>
            }

            @if (senderGroups.Count == 0 && inboundGroups.Count == 0 && adHocGroups.Count == 0)
            {
                <p class="text-muted">No sender or recipient domains configured yet. Add a sender domain under <a href="/domains/sender">Accepted Domains (Sender)</a>, pick a candidate above, or check one by hand.</p>
            }
            @foreach (var g in adHocGroups) { @groupCard(g) }
            @foreach (var g in senderGroups) { @groupCard(g) }
            @foreach (var g in inboundGroups) { @groupCard(g) }
        </BbTabsContent>
    </BbTabs>
}

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Deliverability</BbDialogTitle>
            <BbDialogDescription>What to verify so your mail is accepted</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p><strong>IP addresses</strong></p>
            <ul style="padding-left:1.25rem;">
                <li><strong>Public hostname (A/AAAA)</strong> — must resolve to your sending IP; used in SPF (<code>a:</code>) and as the EHLO name.</li>
                <li><strong>Reverse DNS (PTR)</strong> — each sending IP should have a PTR matching the hostname (FCrDNS). Missing/mismatched reverse DNS is a top reason mail is rejected or spam-foldered.</li>
                <li><strong>SPF coverage</strong> — a tenant's egress IP must be listed in your sending IPs, or mail from it fails SPF.</li>
                <li><strong>Blocklist (DNSBL)</strong> — each sending IP is checked against Spamhaus ZEN and SpamCop. <strong>Listed</strong> (red) means receivers like Microsoft 365 will reject your mail (SMTP 5.7.1) — use the delisting link and send from a clean IP. A <strong>&ldquo;could not query&rdquo;</strong> result is <em>not</em> a clean pass: Spamhaus refuses lookups from public resolvers (e.g. 8.8.8.8 / 1.1.1.1) with a special code, which this page reports honestly rather than as &ldquo;not listed&rdquo;. To get a real answer, run the relay where its DNS resolver is the server&rsquo;s own/ISP resolver (or use a Spamhaus DQS key).</li>
            </ul>
            <p><strong>Check DNS</strong></p>
            <ul style="padding-left:1.25rem;">
                <li><strong>SPF / DKIM / DMARC</strong> (per sender domain) — TXT records that let receivers verify mail you send <em>as</em> that domain.</li>
                <li><strong>MX</strong> (per recipient / backup-MX domain) — must point to this relay so it can receive mail <em>for</em> that domain.</li>
                <li><strong>Used in your configuration</strong> — domains found in your settings (the public hostname's registrable domain, DKIM domains, the DMARC report address) offered as one-click checks, plus an ad-hoc box for anything else.</li>
            </ul>
            <p class="text-muted">Status reflects live DNS and is subject to TTL/propagation — after publishing a change, allow time and Re-check.</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose><BbButton Variant="ButtonVariant.Outline">Close</BbButton></BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private record CheckGroup(string Title, string? Subtitle, List<DnsRecordResult> Records, string? ActionHref = null, string? ActionLabel = null, DmarcAlignment? Alignment = null);
    private record DomainCandidate(string Domain, string Source);

    // Deep-linkable tab, e.g. /health?tab=dns.
    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    private string activeTab = "ip";

    private List<CheckGroup> senderGroups = [];
    private List<CheckGroup> inboundGroups = [];
    private List<CheckGroup> ipGroups = [];
    // Ad-hoc / candidate domain checks the operator ran by hand. Kept separate from the configured
    // senderGroups so "Re-check all" can refresh the configured domains without discarding these.
    private List<CheckGroup> adHocGroups = [];
    private CheckGroup? outboundIpGroup;
    private CheckGroup? hostnameGroup;
    private List<string> relayExplicitAllow = [];
    private bool relayAnyAllow;
    private List<DomainCandidate> candidateDomains = [];
    private List<string> candidateIps = [];
    private string adHocDomain = "";
    private string? adHocError;
    private bool isLoading = true;
    private string? loadError;
    private bool showHelp;

    // Live progress for the loading indicator while the (now concurrent) DNS checks run.
    private int totalChecks;
    private int completedChecks;

    // Cancels the in-flight (possibly slow) live DNS lookups if the user navigates away / the circuit
    // is disposed, so a background continuation can't keep querying or touch a disposed renderer.
    private readonly CancellationTokenSource _cts = new();

    protected override void OnInitialized() =>
        activeTab = Tab is "ip" or "dns" ? Tab : "ip";

    private void ShowIpChecks() => activeTab = "ip";

    // Defer the (live, possibly slow) DNS checks until after the first paint, so the page shows
    // a skeleton immediately instead of blocking on N sequential lookups.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshAsync();
            try
            {
                await InvokeAsync(StateHasChanged);
            }
            catch (ObjectDisposedException) { /* circuit gone while the DNS lookup was in flight */ }
            catch (OperationCanceledException) { /* circuit gone while the DNS lookup was in flight */ }
        }
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        loadError = null;
        completedChecks = 0;
        totalChecks = 0;
        StateHasChanged();
        try
        {
            // ----- Phase 1: read all DB-backed config once (fast, single scope, no concurrency) -----
            // The live DNS lookups in phase 2 run concurrently, each in its own scope, because
            // DnsSetupService is scoped + stateful (it caches DnsSettings and uses the DbContext), so it
            // can't be shared across parallel calls. Gather everything they need here first.
            bool isHostScope;
            int? tenantId;
            DnsSettings settings;
            List<string> senderDomainNames;
            List<(string Domain, bool Backup)> mxDomains;
            string? egress = null;
            List<DkimDomain> dkimList;

            using (var scope = ScopeFactory.CreateScope())
            {
                var sp = scope.ServiceProvider;
                var current = sp.GetRequiredService<ICurrentTenant>();
                isHostScope = current.IsHostScope;
                tenantId = current.TenantId;

                settings = await sp.GetRequiredService<IDnsSettingsService>().GetAsync();
                senderDomainNames = [.. (await sp.GetRequiredService<IAcceptedSenderDomainService>().GetAllAsync())
                    .Select(s => s.Domain.Trim().ToLowerInvariant()).Where(d => d.Length > 0).Distinct()];

                List<string> recipients = [.. (await sp.GetRequiredService<IAcceptedDomainService>().GetAllAsync())
                    .Select(x => x.Domain.Trim().ToLowerInvariant()).Where(x => x.Length > 0).Distinct()];
                mxDomains = [.. recipients.Select(d => (Domain: d, Backup: false))];
                if (isHostScope)
                {
                    var backup = await sp.GetRequiredService<IBackupMxSettingsService>().GetAsync();
                    foreach (var d in backup.DomainList.Select(x => x.Trim().ToLowerInvariant()).Where(x => x.Length > 0).Distinct())
                        mxDomains.Add((d, true));
                }

                // Relay-security posture: open-relay protection is always enforced (external relay needs AUTH
                // or an explicit, non-"any" allow-IP rule). Surface which allow networks grant unauthenticated
                // relay, and flag an "any" (…/0) allow rule which does NOT grant relay.
                var relayRules = await sp.GetRequiredService<IRuntimeConfigCache>().GetIpAccessRulesAsync(_cts.Token);
                var allowNetworks = relayRules.Where(r => r.Action == IpAccessAction.Allow).Select(r => r.Network.Trim()).ToList();
                relayExplicitAllow = [.. allowNetworks.Where(n => !n.EndsWith("/0"))];
                relayAnyAllow = allowNetworks.Any(n => n.EndsWith("/0"));

                if (tenantId is { } tid)
                    egress = (await sp.GetRequiredService<ITenantService>().GetByIdAsync(tid))?.EgressIpAddress?.Trim();

                dkimList = [.. await sp.GetRequiredService<IDkimDomainService>().GetAllAsync()];
            }

            var sendingIps = SplitList(settings.SendingIpAddresses);
            // A tenant egress IP is only an extra check when it isn't already one of the sending IPs.
            var egressExtra = !string.IsNullOrWhiteSpace(egress) && !sendingIps.Any(s => IpEquals(s, egress)) ? egress : null;
            var ipList = new List<string>(sendingIps);
            if (egressExtra is not null) ipList.Add(egressExtra);

            // ----- Phase 2: run every live DNS / HTTP check concurrently (each in its own scope) -----
            var ipDetectTask = Track(IpDetector.DetectAsync(_cts.Token));
            var senderTasks = senderDomainNames.Select(d => Check((s, c) => s.CheckDomainAsync(d, c))).ToList();
            var mxTasks = mxDomains.Select(m => Check((s, c) => s.CheckMxAsync(m.Domain, c))).ToList();
            var hostnameTask = Check((s, c) => s.CheckHostnameAsync(c));
            var ptrTasks = ipList.Select(ip => Check((s, c) => s.CheckReverseDnsAsync(ip, c))).ToList();
            var blTasks = ipList.Select(ip => Check((s, c) => s.CheckBlocklistsAsync(ip, c))).ToList();

            totalChecks = 1 + senderTasks.Count + mxTasks.Count + 1 + ptrTasks.Count + blTasks.Count;
            await InvokeAsync(StateHasChanged);

            var allTasks = new List<Task> { ipDetectTask, hostnameTask };
            allTasks.AddRange(senderTasks);
            allTasks.AddRange(mxTasks);
            allTasks.AddRange(ptrTasks);
            allTasks.AddRange(blTasks);
            await Task.WhenAll(allTasks);

            // ----- Phase 3: assemble the display groups from the completed results -----
            senderGroups = [.. senderTasks.Select(t => t.Result)
                .Select(s => new CheckGroup(s.Domain, "Sending identity — you send mail as this domain", [s.Spf, s.Dkim, s.Dmarc], Alignment: s.Alignment))];

            inboundGroups = [];
            for (var i = 0; i < mxDomains.Count; i++)
                inboundGroups.Add(new CheckGroup(mxDomains[i].Domain,
                    mxDomains[i].Backup
                        ? "Backup MX (host-level) — holds mail when the primary is unreachable"
                        : "Inbound — this relay accepts mail for this domain",
                    [mxTasks[i].Result]));

            // Detected outbound IP vs the configured sending IPs — flags a stale config when this server's
            // public IP has changed (e.g. a dynamic ISP address), which the per-IP checks below cannot show
            // because they only validate whatever is configured. On a problem, link to the settings section.
            var outboundCheck = BuildOutboundIpCheck(ipDetectTask.Result, sendingIps);
            var outboundIssue = outboundCheck.Status is DnsRecordStatus.Mismatch or DnsRecordStatus.NotConfigured;
            outboundIpGroup = new CheckGroup("Outbound IP",
                "What this server actually sends from, compared with your configured sending IPs",
                [outboundCheck],
                outboundIssue ? "/settings?tab=dns" : null,
                outboundIssue ? "Update sending IPs in Settings" : null);

            hostnameGroup = new CheckGroup(
                string.IsNullOrWhiteSpace(settings.PublicHostname) ? "(public hostname)" : settings.PublicHostname,
                "Public hostname — used in SPF (a:) and as the EHLO name",
                [hostnameTask.Result]);

            ipGroups = [];
            for (var i = 0; i < ipList.Count; i++)
            {
                var isEgress = egressExtra is not null && i == ipList.Count - 1;
                List<DnsRecordResult> records = isEgress
                    ? [ptrTasks[i].Result, blTasks[i].Result, SpfCoverage(ipList[i], inSpf: false)]
                    : [ptrTasks[i].Result, blTasks[i].Result];
                ipGroups.Add(new CheckGroup(ipList[i],
                    isEgress ? "Tenant outbound IP — outbound mail for this tenant leaves from here" : "Sending IP",
                    records));
            }
            candidateIps = ipList;

            // ----- Check-DNS candidates: domains in use that aren't already auto-checked above.
            // Helps when no sender/recipient domain is configured yet (e.g. derive ardimedia.com
            // from the public hostname smtp2.ardimedia.com).
            // A domain that is now a configured sender/recipient domain shouldn't also linger as an
            // ad-hoc result card; drop those so it shows once (under its configured group).
            var configuredDomains = new HashSet<string>(
                senderGroups.Select(g => g.Title).Concat(inboundGroups.Select(g => g.Title)),
                StringComparer.OrdinalIgnoreCase);
            adHocGroups.RemoveAll(g => configuredDomains.Contains(g.Title));
            // Don't offer as a candidate anything already shown above (configured or ad-hoc-checked).
            var checkedDomains = new HashSet<string>(configuredDomains, StringComparer.OrdinalIgnoreCase);
            checkedDomains.UnionWith(adHocGroups.Select(g => g.Title));
            var cands = new List<DomainCandidate>();
            void AddCandidate(string? domain, string source)
            {
                if (string.IsNullOrWhiteSpace(domain)) return;
                var d = domain.Trim().TrimEnd('.').ToLowerInvariant();
                if (d.Length == 0 || Uri.CheckHostName(d) != UriHostNameType.Dns) return;
                if (checkedDomains.Contains(d) || cands.Any(c => string.Equals(c.Domain, d, StringComparison.OrdinalIgnoreCase))) return;
                cands.Add(new DomainCandidate(d, source));
            }
            if (PublicSuffix.GetRegistrableDomain(settings.PublicHostname) is { } regHost)
                AddCandidate(regHost, $"derived from {settings.PublicHostname}");
            foreach (var dk in dkimList)
                AddCandidate(dk.Domain, "DKIM domain");
            AddCandidate(EmailDomain(settings.DmarcReportEmail), "DMARC report address");
            candidateDomains = cands;
        }
        catch (Exception)
        {
            loadError = "Could not check DNS just now — try Re-check.";
        }
        finally
        {
            isLoading = false;
        }
    }

    // Runs a single live DNS check in its own tenant-scoped DI scope and reports progress when it
    // finishes. DnsSetupService is scoped + stateful and touches the DbContext, so each concurrent
    // check needs its own scope (the active tenant is propagated by ScopeFactory).
    private Task<T> Check<T>(Func<IDnsSetupService, CancellationToken, Task<T>> check)
    {
        var ct = _cts.Token;
        return Task.Run(async () =>
        {
            try
            {
                using var scope = ScopeFactory.CreateScope();
                var dns = scope.ServiceProvider.GetRequiredService<IDnsSetupService>();
                return await check(dns, ct);
            }
            finally
            {
                await ReportProgressAsync();
            }
        }, ct);
    }

    // Wraps a non-scoped async task (e.g. the HTTP IP detection) so it also advances the progress count.
    private async Task<T> Track<T>(Task<T> inner)
    {
        try { return await inner; }
        finally { await ReportProgressAsync(); }
    }

    private async Task ReportProgressAsync()
    {
        System.Threading.Interlocked.Increment(ref completedChecks);
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { /* circuit gone */ }
        catch (OperationCanceledException) { /* circuit gone */ }
    }

    private static bool IpEquals(string? a, string? b) =>
        System.Net.IPAddress.TryParse(a?.Trim(), out var ia)
        && System.Net.IPAddress.TryParse(b?.Trim(), out var ib)
        && ia.Equals(ib);

    private async Task CheckAdHocAsync()
    {
        var domain = adHocDomain.Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(domain) || Uri.CheckHostName(domain) != UriHostNameType.Dns)
        {
            adHocError = "Enter a valid domain name (e.g. example.com).";
            return;
        }
        adHocError = null;
        adHocDomain = "";
        await RunDomainCheckAsync(domain, "Ad-hoc check");
    }

    private Task CheckCandidateAsync(string domain) => RunDomainCheckAsync(domain, "Checked from your configuration");

    private async Task RunDomainCheckAsync(string rawDomain, string subtitle)
    {
        var domain = rawDomain.Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(domain) || Uri.CheckHostName(domain) != UriHostNameType.Dns) return;
        using var scope = ScopeFactory.CreateScope();
        var dns = scope.ServiceProvider.GetRequiredService<IDnsSetupService>();
        var setup = await dns.CheckDomainAsync(domain, _cts.Token);
        adHocGroups.RemoveAll(g => g.Title == domain);
        adHocGroups.Insert(0, new CheckGroup(domain, subtitle, [setup.Spf, setup.Dkim, setup.Dmarc], Alignment: setup.Alignment));
        activeTab = "dns";
    }

    private static string? EmailDomain(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return null;
        var at = email.LastIndexOf('@');
        return at < 0 || at == email.Length - 1 ? null : email[(at + 1)..].Trim().TrimEnd('.').ToLowerInvariant();
    }

    private static DnsRecordResult BuildOutboundIpCheck(IReadOnlyList<string> detected, List<string> configured)
    {
        var configuredStr = configured.Count > 0 ? string.Join(", ", configured) : "";
        if (detected.Count == 0)
            return new("Detected outbound IP", "(external lookup)", configuredStr, null, DnsRecordStatus.NotConfigured,
                "Could not detect this server's public IP (no internet, or the lookup was blocked). Best-effort only.");

        var detectedStr = string.Join(", ", detected);
        var matches = detected.Any(d => configured.Any(c => IpEquals(c, d)));
        return matches
            ? new("Detected outbound IP", "(external lookup)", configuredStr, detectedStr, DnsRecordStatus.Ok,
                "This server's detected public IP is one of your configured sending IPs.")
            : new("Detected outbound IP", "(external lookup)", configuredStr.Length == 0 ? "(none configured)" : configuredStr,
                detectedStr, DnsRecordStatus.Mismatch,
                "This server's outbound IP does not match any configured sending IP. If your IP changed (e.g. a dynamic ISP " +
                "address), update Settings → Sending identity — otherwise the A / reverse-DNS / SPF-coverage checks below are " +
                "validating the wrong address. (Best-effort: detected via an external HTTP lookup, which normally egresses from " +
                "the same public IP as SMTP.)");
    }

    private static DnsRecordResult SpfCoverage(string ip, bool inSpf) => new(
        "SPF coverage (config)", ip, "must be a configured sending IP", inSpf ? "configured" : "missing",
        inSpf ? DnsRecordStatus.Ok : DnsRecordStatus.Mismatch,
        inSpf
            ? "This egress IP is in your sending IPs, so it is covered by SPF."
            : "This egress IP is NOT in your sending IPs — add it under Settings → Sending identity, or mail from it fails SPF. (This checks your configuration, not a DNS record.)");

    private static List<string> SplitList(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? []
            : [.. value.Split([';', ','], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)];

    private async Task CopyAsync(string value)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", value); }
        catch { /* best-effort copy */ }
    }

    private static string AlignmentBadge(DmarcAlignmentVerdict v) => v switch
    {
        DmarcAlignmentVerdict.DkimAligned => "badge-success",
        DmarcAlignmentVerdict.SpfConditional => "badge-warning",
        _ => "badge-error"
    };

    private static string AlignmentText(DmarcAlignmentVerdict v) => v switch
    {
        DmarcAlignmentVerdict.DkimAligned => "Passes (DKIM-aligned)",
        DmarcAlignmentVerdict.SpfConditional => "Conditional (SPF only)",
        _ => "Will fail"
    };

    private static string AlignmentColor(DmarcAlignmentVerdict v) => v switch
    {
        DmarcAlignmentVerdict.DkimAligned => "var(--primary)",
        DmarcAlignmentVerdict.SpfConditional => "#d97706",
        _ => "#dc2626"
    };

    private static string BadgeClass(DnsRecordStatus status) => status switch
    {
        DnsRecordStatus.Ok => "badge-success",
        DnsRecordStatus.Mismatch => "badge-warning",
        DnsRecordStatus.Missing => "badge-error",
        DnsRecordStatus.Listed => "badge-error",
        _ => "badge-muted"
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}

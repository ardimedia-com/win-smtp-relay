@page "/settings/certificate"
@using Microsoft.AspNetCore.Components.Forms
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject IServiceScopeFactory ScopeFactory
@inject IAdminCertificateProvider CertProvider

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>HTTPS certificate</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>HTTPS certificate</h1>
    <p>The certificate the admin UI is served with. Out of the box the relay generates a self-signed certificate (browsers show a warning) — import a trusted certificate here to remove the warning.</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[160px] w-full" />
}
else
{
    <BbCard Class="mb-1">
        <BbCardHeader>
            <BbCardTitle>Current certificate</BbCardTitle>
        </BbCardHeader>
        <BbCardContent>
            <div class="dns-record">
                <div class="dns-record-head">
                    <strong>@(info.HasImportedCertificate ? "Imported certificate" : "Built-in self-signed certificate")</strong>
                    <span class="badge-status @(info.HasImportedCertificate ? "badge-success" : "badge-warning")">
                        @(info.HasImportedCertificate ? "Trusted (imported)" : "Self-signed")
                    </span>
                </div>
                @if (!info.HasImportedCertificate)
                {
                    <div class="text-muted" style="font-size:0.8rem;">
                        Browsers will warn about this certificate because it is not issued by a trusted authority.
                        That is expected; the connection is still encrypted. Import a real certificate below to remove the warning.
                    </div>
                }
                <div class="dns-record-row">
                    <span class="dns-record-label">Subject</span>
                    <code class="mono dns-record-value">@(CurrentSubject ?? "—")</code>
                </div>
                <div class="dns-record-row">
                    <span class="dns-record-label">Expires</span>
                    <code class="mono dns-record-value">@(CurrentExpiry?.ToString("yyyy-MM-dd") ?? "—")</code>
                </div>
                @if (!string.IsNullOrEmpty(CurrentThumbprint))
                {
                    <div class="dns-record-row">
                        <span class="dns-record-label">Thumbprint</span>
                        <code class="mono dns-record-value">@CurrentThumbprint</code>
                    </div>
                }
            </div>

            @if (info.HasImportedCertificate)
            {
                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="RemoveAsync" Disabled="@busy" Class="mt-1">
                    <LucideIcon Name="trash-2" /> Remove imported certificate (revert to self-signed)
                </BbButton>
            }
        </BbCardContent>
    </BbCard>

    <BbCard Class="mb-1">
        <BbCardHeader>
            <BbCardTitle>Import a certificate</BbCardTitle>
            <BbCardDescription>Upload a <strong>PFX / PKCS#12</strong> file that includes the private key. The new certificate is applied to new connections immediately — no service restart needed.</BbCardDescription>
        </BbCardHeader>
        <BbCardContent>
            <div class="form-group" style="max-width:520px;">
                <BbLabel For="pfx">Certificate file (.pfx / .p12)</BbLabel>
                <InputFile id="pfx" OnChange="OnFileSelected" accept=".pfx,.p12" />
            </div>
            <div class="form-group" style="max-width:520px;margin-top:0.75rem;">
                <BbLabel For="pfx-pass">Password (if the PFX is password-protected)</BbLabel>
                <BbInput Id="pfx-pass" Type="InputType.Password" @bind-Value="password" Placeholder="PFX password" />
            </div>

            <BbButton Variant="ButtonVariant.Default" @onclick="ImportAsync" Disabled="@(busy || selectedFile is null)" Class="mt-1">
                <LucideIcon Name="upload" /> @(busy ? "Importing…" : "Import certificate")
            </BbButton>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <p class="text-muted" style="margin-top:0.5rem;">@statusMessage</p>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <p class="text-danger" style="margin-top:0.5rem;">@errorMessage</p>
            }

            <p class="text-muted" style="font-size:0.78rem;margin-top:0.75rem;margin-bottom:0;">
                The certificate (without its password) is stored encrypted in the database. After importing, reload this
                page over the new certificate to confirm the browser no longer warns.
            </p>
        </BbCardContent>
    </BbCard>

    <BbCard Class="mb-1">
        <BbCardHeader>
            <BbCardTitle>Use a certificate installed on this server</BbCardTitle>
            <BbCardDescription>Certificates in the Windows <span class="mono">LocalMachine\My</span> store that have a private key, a server-authentication purpose, and <strong>chain to a trusted root</strong> (self-signed / untrusted certificates are not listed — they would still cause a browser warning). The chosen one is copied (with its key) into the relay and applied immediately. The private key must be exportable and readable by the service account.</BbCardDescription>
        </BbCardHeader>
        <BbCardContent>
            @{
                var trusted = storeCerts.Where(c => c.IsTrusted).ToList();
                var hidden = storeCerts.Count - trusted.Count;
            }
            @if (trusted.Count == 0)
            {
                <p class="text-muted" style="font-size:0.85rem;margin:0;">
                    No trusted certificate found in the machine store.
                    @if (hidden > 0)
                    {
                        <text>@hidden self-signed or untrusted certificate(s) are not listed — they would still trigger a browser warning. Use one issued by a CA your clients trust, or import a PFX above.</text>
                    }
                    else
                    {
                        <text>A certificate needs a private key, a server-authentication purpose, and must chain to a trusted root.</text>
                    }
                </p>
            }
            else
            {
                <div style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr><th>Subject</th><th>Issuer</th><th>Expires</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in trusted)
                        {
                            <tr>
                                <td><code class="mono">@c.Subject</code></td>
                                <td class="text-muted">@c.Issuer</td>
                                <td class="text-muted">@c.NotAfterUtc.ToString("yyyy-MM-dd")</td>
                                <td style="text-align:right;">
                                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => UseStoreCertAsync(c.Thumbprint)" Disabled="@busy">
                                        <LucideIcon Name="check" /> Use
                                    </BbButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                @if (hidden > 0)
                {
                    <p class="text-muted" style="font-size:0.78rem;margin-top:0.5rem;margin-bottom:0;">@hidden self-signed or untrusted certificate(s) are not listed — they would still cause a browser warning. To use a self-signed certificate, add it to the machine's Trusted Root store first.</p>
                }
            }
        </BbCardContent>
    </BbCard>
}

@code {
    private bool isLoading = true;
    private bool busy;
    private AdminCertificateSettings info = new();
    private IBrowserFile? selectedFile;
    private string? password;
    private IReadOnlyList<StoreCertificateInfo> storeCerts = [];
    private string? statusMessage;
    private string? errorMessage;

    // Snapshot of the certificate Kestrel is currently serving (self-signed or imported).
    private string? CurrentSubject;
    private DateTime? CurrentExpiry;
    private string? CurrentThumbprint;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAdminCertificateService>();
        info = await svc.GetAsync();
        storeCerts = svc.ListStoreCertificates();

        var current = CertProvider.Current;
        CurrentSubject = current?.Subject;
        CurrentExpiry = current?.NotAfter;
        CurrentThumbprint = current?.Thumbprint;
        isLoading = false;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        statusMessage = null;
        errorMessage = null;
    }

    private async Task ImportAsync()
    {
        if (selectedFile is null) return;
        busy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            using var ms = new MemoryStream();
            await selectedFile.OpenReadStream(maxAllowedSize: 512 * 1024).CopyToAsync(ms);

            // Import + hot-swap in one step (Kestrel reads the provider per handshake).
            using var scope = ScopeFactory.CreateScope();
            await scope.ServiceProvider.GetRequiredService<WinSmtpRelay.Security.AdminCertificateApplier>()
                .ImportAndApplyAsync(ms.ToArray(), password);

            password = null;
            selectedFile = null;
            await LoadAsync();
            statusMessage = "Certificate imported and applied. New connections use it now — reload this page to confirm.";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not import the certificate: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task UseStoreCertAsync(string thumbprint)
    {
        busy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            // Copy from the store + hot-swap in one step, like a PFX import.
            using var scope = ScopeFactory.CreateScope();
            await scope.ServiceProvider.GetRequiredService<WinSmtpRelay.Security.AdminCertificateApplier>()
                .ImportFromStoreAndApplyAsync(thumbprint);

            await LoadAsync();
            statusMessage = "Certificate copied from the store and applied. New connections use it now — reload this page to confirm.";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not use the certificate: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task RemoveAsync()
    {
        busy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            // Remove + immediately revert the served certificate to the configured/self-signed one.
            using var scope = ScopeFactory.CreateScope();
            await scope.ServiceProvider.GetRequiredService<WinSmtpRelay.Security.AdminCertificateApplier>()
                .RemoveAndRevertAsync();

            await LoadAsync();
            statusMessage = "Imported certificate removed. The built-in self-signed certificate is in use again.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not remove the certificate: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }
}

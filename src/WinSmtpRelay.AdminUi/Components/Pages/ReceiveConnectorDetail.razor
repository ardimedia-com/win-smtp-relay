@page "/connectors/receive/new"
@page "/connectors/receive/{Id:int}"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject ITenantScopeFactory ScopeFactory
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/connectors/receive">Receive Connectors</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>@(IsNew ? "New" : name)</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>@(IsNew ? "New receive connector" : $"Receive connector: {name}")</h1>
    <p>SMTP listener endpoint &mdash; changes require a service restart to take effect</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else if (notFound)
{
    <p class="text-danger">Receive connector not found.</p>
    <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel"><LucideIcon Name="arrow-left" /> Back</BbButton>
}
else
{
    <BbCard>
        <BbCardContent>
            <div class="form-grid">
                <div class="form-group col-span-full">
                    <BbLabel For="name">Name</BbLabel>
                    <BbInput Id="name" @bind-Value="name" Placeholder="Default" />
                </div>
                <div class="form-group">
                    <BbLabel For="bind-address">Bind Address</BbLabel>
                    <BbInput Id="bind-address" @bind-Value="address" Placeholder="0.0.0.0" />
                </div>
                <div class="form-group">
                    <BbLabel For="port">Port</BbLabel>
                    <BbInput Id="port" Type="InputType.Number" @bind-Value="port" />
                </div>
                <div class="form-group">
                    <BbLabel For="require-tls">Require TLS</BbLabel>
                    <BbNativeSelect Id="require-tls" @bind-Value="requireTls">
                        <option value="false">No</option>
                        <option value="true">Yes (STARTTLS)</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel For="implicit-tls">Implicit TLS</BbLabel>
                    <BbNativeSelect Id="implicit-tls" @bind-Value="implicitTls">
                        <option value="false">No</option>
                        <option value="true">Yes</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel For="require-auth">Require Auth</BbLabel>
                    <BbNativeSelect Id="require-auth" @bind-Value="requireAuth">
                        <option value="false">No</option>
                        <option value="true">Yes</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel For="max-message-size">Max Message Size (MB)</BbLabel>
                    <BbInput Id="max-message-size" Type="InputType.Number" @bind-Value="maxSizeMb" />
                </div>
                <div class="form-group">
                    <BbLabel For="max-connections">Max Connections</BbLabel>
                    <BbInput Id="max-connections" Type="InputType.Number" @bind-Value="maxConn" />
                </div>
                <div class="form-group">
                    <BbLabel For="enabled">Enabled</BbLabel>
                    <BbNativeSelect Id="enabled" @bind-Value="enabled">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </BbNativeSelect>
                </div>
            </div>
        </BbCardContent>
        <BbCardFooter>
            <div class="flex gap-1 items-center">
                <BbButton Variant="ButtonVariant.Default" @onclick="SaveAsync" Disabled="@string.IsNullOrWhiteSpace(name)">
                    <LucideIcon Name="save" /> Save
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel">Cancel</BbButton>
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <span class="text-muted" style="margin-left:0.5rem">@statusMessage</span>
                }
            </div>
        </BbCardFooter>
    </BbCard>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => Id is null;

    private bool isLoading = true;
    private bool notFound;
    private string? statusMessage;

    private string name = "";
    private string address = "0.0.0.0";
    private string port = "25";
    private string requireTls = "false";
    private string implicitTls = "false";
    private string requireAuth = "false";
    private string maxSizeMb = "25";
    private string maxConn = "100";
    private string enabled = "true";

    protected override async Task OnInitializedAsync()
    {
        if (IsNew)
        {
            isLoading = false;
            return;
        }

        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IReceiveConnectorService>();
        var c = await svc.GetByIdAsync(Id!.Value);
        if (c is null)
        {
            notFound = true;
            isLoading = false;
            return;
        }

        name = c.Name;
        address = c.Address;
        port = c.Port.ToString();
        requireTls = c.RequireTls.ToString().ToLowerInvariant();
        implicitTls = c.ImplicitTls.ToString().ToLowerInvariant();
        requireAuth = c.RequireAuth.ToString().ToLowerInvariant();
        maxSizeMb = (c.MaxMessageSizeBytes / (1024 * 1024)).ToString();
        maxConn = c.MaxConnections.ToString();
        enabled = c.IsEnabled.ToString().ToLowerInvariant();
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IReceiveConnectorService>();

        var connector = new ReceiveConnector
        {
            Id = Id ?? 0,
            Name = name.Trim(),
            Address = address.Trim(),
            Port = int.TryParse(port, out var p) ? p : 25,
            RequireTls = requireTls == "true",
            ImplicitTls = implicitTls == "true",
            RequireAuth = requireAuth == "true",
            MaxMessageSizeBytes = (int.TryParse(maxSizeMb, out var s) ? s : 25) * 1024 * 1024,
            MaxConnections = int.TryParse(maxConn, out var mc) ? mc : 100,
            IsEnabled = enabled == "true"
        };

        if (IsNew)
            await svc.CreateAsync(connector);
        else
            await svc.UpdateAsync(connector);

        Nav.NavigateTo("/connectors/receive");
    }

    private void Cancel() => Nav.NavigateTo("/connectors/receive");
}

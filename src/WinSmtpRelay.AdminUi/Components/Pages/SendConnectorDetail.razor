@page "/connectors/send/new"
@page "/connectors/send/{Id:int}"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.AdminFull)]
@inject ITenantScopeFactory ScopeFactory
@inject IRuntimeConfigCache ConfigCache
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/connectors/send">Send Connectors</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>@(IsNew ? "New" : name)</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>@(IsNew ? "New send connector" : $"Send connector: {name}")</h1>
    <p>Outbound delivery route &mdash; smart host or direct MX delivery</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else if (notFound)
{
    <p class="text-danger">Send connector not found.</p>
    <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel"><LucideIcon Name="arrow-left" /> Back</BbButton>
}
else
{
    <BbCard>
        <BbCardContent>
            @if (isBrevo)
            {
                <div style="border:1px solid var(--border);border-radius:var(--radius);padding:0.75rem 1rem;background:var(--muted);margin-bottom:1rem;font-size:0.85rem;line-height:1.55;">
                    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.35rem;">
                        <LucideIcon Name="mail-check" Size="16" />
                        <strong>Brevo smart host</strong>
                    </div>
                    <span class="text-muted">
                        Host, port and TLS are pre-filled. Enter your <strong>Brevo account email</strong> as
                        <em>Username</em> and a <strong>Brevo SMTP key</strong> as <em>Password</em> (Brevo dashboard →
                        <em>SMTP &amp; API → SMTP</em>; the SMTP key is not your login password). Set <em>Default</em> to
                        <em>Yes</em> to route all of this organization's outbound mail through Brevo, or add a Domain Route
                        for specific sender domains. Free tier: 300 emails/day; paid plans offer higher volume and a
                        dedicated IP — see <a href="https://www.brevo.com/pricing/" target="_blank" rel="noopener noreferrer">Brevo pricing</a>.
                    </span>
                </div>
            }
            <div class="form-grid">
                <div class="form-group col-span-full">
                    <BbLabel For="name">Name</BbLabel>
                    <BbInput Id="name" @bind-Value="name" Placeholder="Default" />
                </div>
                <div class="form-group col-span-full">
                    <BbLabel For="smart-host">Smart Host (empty = direct MX)</BbLabel>
                    <BbInput Id="smart-host" @bind-Value="smartHost" Placeholder="smtp.example.com" />
                </div>
                <div class="form-group">
                    <BbLabel For="port">Port</BbLabel>
                    <BbInput Id="port" Type="InputType.Number" @bind-Value="port" />
                </div>
                <div class="form-group">
                    <BbLabel For="username">Username</BbLabel>
                    <BbInput Id="username" @bind-Value="username" />
                </div>
                <div class="form-group">
                    <BbLabel For="password">Password</BbLabel>
                    <BbInput Id="password" Type="InputType.Password" @bind-Value="password" />
                </div>
                <div class="form-group">
                    <BbLabel For="opportunistic-tls">Opportunistic TLS</BbLabel>
                    <BbNativeSelect Id="opportunistic-tls" @bind-Value="opportunisticTls">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel For="require-tls">Require TLS</BbLabel>
                    <BbNativeSelect Id="require-tls" @bind-Value="requireTls">
                        <option value="false">No</option>
                        <option value="true">Yes</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel For="default">Default</BbLabel>
                    <BbNativeSelect Id="default" @bind-Value="isDefault">
                        <option value="false">No</option>
                        <option value="true">Yes</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel For="concurrent-deliveries">Concurrent Deliveries</BbLabel>
                    <BbInput Id="concurrent-deliveries" Type="InputType.Number" @bind-Value="concurrency" />
                </div>
                <div class="form-group">
                    <BbLabel For="max-retry-hours">Max Retry Hours</BbLabel>
                    <BbInput Id="max-retry-hours" Type="InputType.Number" @bind-Value="maxRetry" />
                </div>
                <div class="form-group col-span-full">
                    <BbLabel For="retry-intervals">Retry Intervals (minutes, comma-separated)</BbLabel>
                    <BbInput Id="retry-intervals" @bind-Value="retryIntervals" Placeholder="1,5,30,120,480,1440" />
                </div>
                <div class="form-group">
                    <BbLabel For="enabled">Enabled</BbLabel>
                    <BbNativeSelect Id="enabled" @bind-Value="enabled">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </BbNativeSelect>
                </div>
            </div>
        </BbCardContent>
        <BbCardFooter>
            <div class="flex gap-1 items-center">
                <BbButton Variant="ButtonVariant.Default" @onclick="SaveAsync" Disabled="@string.IsNullOrWhiteSpace(name)">
                    <LucideIcon Name="save" /> Save
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel">Cancel</BbButton>
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <span class="text-muted" style="margin-left:0.5rem">@statusMessage</span>
                }
            </div>
        </BbCardFooter>
    </BbCard>
}

@code {
    [Parameter] public int? Id { get; set; }

    /// <summary>Optional connector template to pre-fill a New connector (e.g. "brevo").</summary>
    [SupplyParameterFromQuery] public string? Template { get; set; }

    private bool IsNew => Id is null;
    private bool isBrevo;

    private bool isLoading = true;
    private bool notFound;
    private string? statusMessage;

    private string name = "";
    private string smartHost = "";
    private string port = "587";
    private string username = "";
    private string password = "";
    private string opportunisticTls = "true";
    private string requireTls = "false";
    private string isDefault = "false";
    private string concurrency = "4";
    private string maxRetry = "48";
    private string retryIntervals = "1,5,30,120,480,1440";
    private string enabled = "true";

    protected override async Task OnInitializedAsync()
    {
        if (IsNew)
        {
            if (string.Equals(Template, "brevo", StringComparison.OrdinalIgnoreCase))
            {
                // Pre-fill the Brevo smart-host settings; the admin supplies their account email +
                // SMTP key. Require TLS — Brevo always offers STARTTLS on 587, so enforce encryption.
                isBrevo = true;
                name = "Brevo";
                smartHost = "smtp-relay.brevo.com";
                port = "587";
                opportunisticTls = "true";
                requireTls = "true";
            }
            isLoading = false;
            return;
        }

        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ISendConnectorService>();
        var c = await svc.GetByIdAsync(Id!.Value);
        if (c is null)
        {
            notFound = true;
            isLoading = false;
            return;
        }

        name = c.Name;
        smartHost = c.SmartHost ?? "";
        port = c.SmartHostPort.ToString();
        username = c.Username ?? "";
        password = c.EncryptedPassword ?? "";
        opportunisticTls = c.OpportunisticTls.ToString().ToLowerInvariant();
        requireTls = c.RequireTls.ToString().ToLowerInvariant();
        isDefault = c.IsDefault.ToString().ToLowerInvariant();
        concurrency = c.MaxConcurrentDeliveries.ToString();
        maxRetry = c.MaxRetryHours.ToString();
        retryIntervals = c.RetryIntervalsMinutes;
        enabled = c.IsEnabled.ToString().ToLowerInvariant();
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ISendConnectorService>();

        var connector = new SendConnector
        {
            Id = Id ?? 0,
            Name = name.Trim(),
            SmartHost = string.IsNullOrWhiteSpace(smartHost) ? null : smartHost.Trim(),
            SmartHostPort = int.TryParse(port, out var p) ? p : 587,
            Username = string.IsNullOrWhiteSpace(username) ? null : username.Trim(),
            EncryptedPassword = string.IsNullOrWhiteSpace(password) ? null : password,
            OpportunisticTls = opportunisticTls == "true",
            RequireTls = requireTls == "true",
            IsDefault = isDefault == "true",
            MaxConcurrentDeliveries = int.TryParse(concurrency, out var conc) ? conc : 4,
            MaxRetryHours = int.TryParse(maxRetry, out var mr) ? mr : 48,
            RetryIntervalsMinutes = retryIntervals.Trim(),
            ConnectTimeoutSeconds = 30,
            IsEnabled = enabled == "true"
        };

        if (IsNew)
            await svc.CreateAsync(connector);
        else
            await svc.UpdateAsync(connector);

        ConfigCache.Invalidate();
        Nav.NavigateTo("/connectors/send");
    }

    private void Cancel() => Nav.NavigateTo("/connectors/send");
}

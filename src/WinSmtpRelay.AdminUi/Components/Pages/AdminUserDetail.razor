@page "/adminusers/new"
@page "/adminusers/{Id:int}"
@using System.Security.Claims
@using System.Security.Cryptography
@using Microsoft.EntityFrameworkCore
@using WinSmtpRelay.Core.Interfaces
@attribute [Authorize(Policy = AuthorizationPolicies.AdminFull)]
@inject IServiceScopeFactory ScopeFactory
@inject ICurrentTenant CurrentTenant
@inject NavigationManager Nav
@inject IJSRuntime JS

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/adminusers">Admin Users</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>@(IsNew ? "New" : email)</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>@(IsNew ? $"New {(CurrentTenant.FilterEnabled ? "tenant" : "host")} admin" : $"Admin: {email}")</h1>
    <p>Web-admin login account (separate from SMTP relay users).</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[260px] w-full" />
}
else if (notFound)
{
    <p class="text-danger">Admin user not found.</p>
    <BbButton Variant="ButtonVariant.Outline" @onclick="GoBack"><LucideIcon Name="arrow-left" /> Back</BbButton>
}
else if (createdPassword is not null)
{
    @* One-time password display after create/reset. The plaintext is never persisted. *@
    <div style="max-width:560px;">
        <BbCard>
            <BbCardHeader><BbCardTitle>@secretTitle</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div class="badge-status badge-warning" style="display:block;padding:0.75rem;line-height:1.5;margin-bottom:1rem;">
                    <strong>@secretDescription</strong>
                </div>
                <div class="form-group">
                    <BbLabel>One-time password</BbLabel>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <BbInput Value="@createdPassword" ReadOnly="true" Class="mono" />
                        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" title="Copy" @onclick="CopyAsync">
                            <LucideIcon Name="copy" /> Copy
                        </BbButton>
                    </div>
                    @if (copied) { <span class="text-muted" style="font-size:0.8125rem;">Copied to clipboard</span> }
                </div>
            </BbCardContent>
            <BbCardFooter><BbButton Variant="ButtonVariant.Default" @onclick="GoBack">Done</BbButton></BbCardFooter>
        </BbCard>
    </div>
}
else if (IsNew)
{
    <div style="max-width:520px;">
        <BbCard>
            <BbCardContent>
                <div class="form-group">
                    <BbLabel>Email</BbLabel>
                    <BbInput @bind-Value="newEmail" Placeholder="admin@tenant.example" />
                </div>
                @if (CurrentTenant.FilterEnabled)
                {
                    <div class="form-group">
                        <BbLabel>Role</BbLabel>
                        <select class="account-input" @bind="newRole">
                            <option value="@RelayRoles.TenantAdmin">Tenant Admin (read/write)</option>
                            <option value="@RelayRoles.TenantViewer">Tenant Viewer (read-only)</option>
                        </select>
                    </div>
                }
                else
                {
                    <p class="text-muted" style="font-size:0.8125rem;">Created as a host administrator.</p>
                }
            </BbCardContent>
            <BbCardFooter>
                <div class="flex gap-1 items-center">
                    <BbButton Variant="ButtonVariant.Default" @onclick="CreateAsync" Disabled="@string.IsNullOrWhiteSpace(newEmail)">
                        <LucideIcon Name="user-plus" /> Create
                    </BbButton>
                    <BbButton Variant="ButtonVariant.Outline" @onclick="GoBack">Cancel</BbButton>
                    @if (!string.IsNullOrEmpty(statusMessage)) { <span class="text-muted" style="margin-left:0.5rem">@statusMessage</span> }
                </div>
            </BbCardFooter>
        </BbCard>
    </div>
}
else
{
    <div style="max-width:520px;">
        <BbCard>
            <BbCardContent>
                <div class="form-group"><BbLabel>Email</BbLabel><div>@email</div></div>
                <div class="form-group"><BbLabel>Role</BbLabel><div>@role</div></div>
                <div class="form-group"><BbLabel>Tenant</BbLabel><div>@(tenantId?.ToString() ?? "host")</div></div>
                <div class="form-group"><BbLabel>Status</BbLabel>
                    <div><span class="badge-status @(enabled ? "badge-success" : "badge-muted")">@(enabled ? "Enabled" : "Disabled")</span></div>
                </div>
                @if (isSelf)
                {
                    <p class="text-muted" style="font-size:0.8125rem;">This is your account — you can't disable, reset, or delete it here.</p>
                }
            </BbCardContent>
            <BbCardFooter>
                <div class="flex gap-1 items-center">
                    @if (!isSelf)
                    {
                        <BbButton Variant="ButtonVariant.Outline" @onclick="ToggleAsync">
                            <LucideIcon Name="@(enabled ? "pause" : "play")" /> @(enabled ? "Disable" : "Enable")
                        </BbButton>
                        <BbButton Variant="ButtonVariant.Outline" @onclick="ResetPasswordAsync">
                            <LucideIcon Name="key-round" /> Reset password
                        </BbButton>
                    }
                    <BbButton Variant="ButtonVariant.Outline" @onclick="GoBack">Back</BbButton>
                    @if (!string.IsNullOrEmpty(statusMessage)) { <span class="text-muted" style="margin-left:0.5rem">@statusMessage</span> }
                </div>
            </BbCardFooter>
        </BbCard>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => Id is null;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool isLoading = true;
    private bool notFound;
    private string? statusMessage;
    private int currentUserId;

    // Create form
    private string newEmail = "";
    private string newRole = RelayRoles.TenantAdmin;

    // One-time secret (create or reset)
    private string? createdPassword;
    private string secretTitle = "Admin created";
    private string secretDescription = "";
    private bool copied;

    // Edit/view state
    private string email = "";
    private string role = "";
    private int? tenantId;
    private bool enabled;
    private bool isSelf;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var idVal = (await AuthState).User.FindFirstValue(ClaimTypes.NameIdentifier);
            int.TryParse(idVal, out currentUserId);
        }
        if (!IsNew)
            await LoadAsync();
        isLoading = false;
    }

    private async Task LoadAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var um = scope.ServiceProvider.GetRequiredService<UserManager<AdminUser>>();
        var user = await um.Users.FirstOrDefaultAsync(u => u.Id == Id!.Value);
        if (user is null || !InScope(user))
        {
            notFound = true;
            return;
        }
        email = user.Email ?? user.UserName ?? "";
        role = string.Join(", ", await um.GetRolesAsync(user));
        tenantId = user.TenantId;
        enabled = user.LockoutEnd is null || user.LockoutEnd <= DateTimeOffset.UtcNow;
        isSelf = user.Id == currentUserId;
    }

    private async Task CreateAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var um = scope.ServiceProvider.GetRequiredService<UserManager<AdminUser>>();

        var scoped = CurrentTenant.FilterEnabled;
        var assignedRole = scoped ? newRole : RelayRoles.HostAdmin;

        // Server-side allowlist: a tenant-scoped admin may only assign tenant roles (the <select>
        // value is client-supplied and must not be trusted to gate HostAdmin).
        if (scoped && assignedRole is not (RelayRoles.TenantAdmin or RelayRoles.TenantViewer))
        {
            statusMessage = "Invalid role for a tenant admin.";
            return;
        }

        var user = new AdminUser
        {
            UserName = newEmail.Trim(),
            Email = newEmail.Trim(),
            EmailConfirmed = true,
            TenantId = scoped ? CurrentTenant.FilterTenantId : null,
            IsHostAdmin = !scoped,
            MustChangePassword = true,
            CreatedUtc = DateTimeOffset.UtcNow
        };

        var password = GenerateTempPassword();
        var result = await um.CreateAsync(user, password);
        if (!result.Succeeded)
        {
            statusMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        await um.AddToRoleAsync(user, assignedRole);
        createdPassword = password;
        secretTitle = "Admin created";
        secretDescription = "Share this one-time password securely. The user must change it on first sign-in.";
    }

    private async Task ResetPasswordAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var um = scope.ServiceProvider.GetRequiredService<UserManager<AdminUser>>();
        var user = await um.Users.FirstOrDefaultAsync(u => u.Id == Id!.Value);
        if (user is null || user.Id == currentUserId || !InScope(user)) return;

        var password = GenerateTempPassword();
        var token = await um.GeneratePasswordResetTokenAsync(user);
        var result = await um.ResetPasswordAsync(user, token, password);
        if (!result.Succeeded)
        {
            statusMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        // Force a change on next sign-in. ResetPasswordAsync rolls the security stamp, so existing
        // sessions for this user are invalidated on the next revalidation.
        user.MustChangePassword = true;
        await um.UpdateAsync(user);

        createdPassword = password;
        secretTitle = "Password reset";
        secretDescription = $"Share this one-time password with {user.Email} securely. They must change it on next sign-in.";
    }

    private async Task ToggleAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var um = scope.ServiceProvider.GetRequiredService<UserManager<AdminUser>>();
        var user = await um.Users.FirstOrDefaultAsync(u => u.Id == Id!.Value);
        if (user is null || user.Id == currentUserId || !InScope(user)) return;

        var isEnabled = user.LockoutEnd is null || user.LockoutEnd <= DateTimeOffset.UtcNow;
        await um.SetLockoutEnabledAsync(user, true);
        await um.SetLockoutEndDateAsync(user, isEnabled ? DateTimeOffset.MaxValue : null);
        await LoadAsync();
    }

    private async Task CopyAsync()
    {
        if (createdPassword is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", createdPassword);
        copied = true;
    }

    private bool InScope(AdminUser user)
        => !CurrentTenant.FilterEnabled || user.TenantId == CurrentTenant.FilterTenantId;

    private static string GenerateTempPassword()
    {
        const string upper = "ABCDEFGHJKLMNPQRSTUVWXYZ", lower = "abcdefghijkmnpqrstuvwxyz", digits = "23456789", symbols = "!@#$%^&*-_=+";
        const string all = upper + lower + digits + symbols;
        Span<char> b = stackalloc char[20];
        b[0] = upper[RandomNumberGenerator.GetInt32(upper.Length)];
        b[1] = lower[RandomNumberGenerator.GetInt32(lower.Length)];
        b[2] = digits[RandomNumberGenerator.GetInt32(digits.Length)];
        b[3] = symbols[RandomNumberGenerator.GetInt32(symbols.Length)];
        for (var i = 4; i < b.Length; i++) b[i] = all[RandomNumberGenerator.GetInt32(all.Length)];
        for (var i = b.Length - 1; i > 0; i--) { var j = RandomNumberGenerator.GetInt32(i + 1); (b[i], b[j]) = (b[j], b[i]); }
        return new string(b);
    }

    private void GoBack() => Nav.NavigateTo("/adminusers");
}

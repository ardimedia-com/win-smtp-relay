@page "/filters/headers/new"
@page "/filters/headers/{Id:int}"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject ITenantScopeFactory ScopeFactory
@inject IRuntimeConfigCache ConfigCache
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/filters?tab=headers">Message Filters</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>@(IsNew ? "New header rule" : headerName)</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>@(IsNew ? "New header rule" : $"Edit header rule")</h1>
    <p>Rewrite, add, or remove a header on outgoing messages</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else if (notFound)
{
    <p class="text-danger">Header rule not found.</p>
    <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel"><LucideIcon Name="arrow-left" /> Back</BbButton>
}
else
{
    <BbCard>
        <BbCardContent>
            <div class="form-grid">
                <div class="form-group col-span-full">
                    <BbLabel>Header Name</BbLabel>
                    <BbInput @bind-Value="headerName" Placeholder="X-Custom-Header" />
                </div>
                <div class="form-group">
                    <BbLabel>Action</BbLabel>
                    <BbNativeSelect @bind-Value="action">
                        <option value="Set">Set</option>
                        <option value="Remove">Remove</option>
                        <option value="Append">Append</option>
                    </BbNativeSelect>
                </div>
                <div class="form-group">
                    <BbLabel>Match Value (optional, regex)</BbLabel>
                    <BbInput @bind-Value="matchValue" Placeholder=".*" />
                </div>
                <div class="form-group">
                    <BbLabel>New Value</BbLabel>
                    <BbInput @bind-Value="newValue" Placeholder="new value" />
                </div>
                <div class="form-group">
                    <BbLabel>Sort Order</BbLabel>
                    <BbInput Type="InputType.Number" @bind-Value="sortOrder" />
                </div>
                <div class="form-group">
                    <BbLabel>Enabled</BbLabel>
                    <BbNativeSelect @bind-Value="enabled">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </BbNativeSelect>
                </div>
            </div>
        </BbCardContent>
        <BbCardFooter>
            <div class="flex gap-1 items-center">
                <BbButton Variant="ButtonVariant.Default" @onclick="SaveAsync" Disabled="@string.IsNullOrWhiteSpace(headerName)">
                    <LucideIcon Name="save" /> Save
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel">Cancel</BbButton>
            </div>
        </BbCardFooter>
    </BbCard>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => Id is null;

    private bool isLoading = true;
    private bool notFound;

    private string headerName = "";
    private string action = "Set";
    private string matchValue = "";
    private string newValue = "";
    private string sortOrder = "0";
    private string enabled = "true";

    protected override async Task OnInitializedAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IMessageFilterService>();
        var rules = await svc.GetHeaderRulesAsync();

        if (IsNew)
        {
            sortOrder = (rules.Count > 0 ? rules.Max(r => r.SortOrder) + 1 : 1).ToString();
            isLoading = false;
            return;
        }

        var r = rules.FirstOrDefault(x => x.Id == Id!.Value);
        if (r is null) { notFound = true; isLoading = false; return; }

        headerName = r.HeaderName;
        action = r.Action;
        matchValue = r.MatchValue ?? "";
        newValue = r.NewValue ?? "";
        sortOrder = r.SortOrder.ToString();
        enabled = r.IsEnabled.ToString().ToLowerInvariant();
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IMessageFilterService>();

        var entry = new HeaderRewriteEntry
        {
            Id = Id ?? 0,
            HeaderName = headerName.Trim(),
            Action = action,
            MatchValue = string.IsNullOrWhiteSpace(matchValue) ? null : matchValue.Trim(),
            NewValue = string.IsNullOrWhiteSpace(newValue) ? null : newValue.Trim(),
            SortOrder = int.TryParse(sortOrder, out var s) ? s : 0,
            IsEnabled = enabled == "true"
        };

        if (IsNew) await svc.CreateHeaderRuleAsync(entry);
        else await svc.UpdateHeaderRuleAsync(entry);
        ConfigCache.Invalidate();
        Nav.NavigateTo("/filters?tab=headers");
    }

    private void Cancel() => Nav.NavigateTo("/filters?tab=headers");
}

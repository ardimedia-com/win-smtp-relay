@page "/tenants/new"
@page "/tenants/{Id:int}"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.HostAdmin)]
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Nav
@inject WinSmtpRelay.AdminUi.Services.LocalNetworkProbe NetProbe

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbLink Href="/tenants">Tenants</BbBreadcrumbLink></BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem><BbBreadcrumbPage>@(IsNew ? "New" : name)</BbBreadcrumbPage></BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>@(IsNew ? "New tenant" : $"Tenant: {name}")</h1>
    <p>Isolated relay configuration. Host administrators only.</p>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[260px] w-full" />
}
else if (notFound)
{
    <p class="text-danger">Tenant not found.</p>
    <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel"><LucideIcon Name="arrow-left" /> Back</BbButton>
}
else
{
    <BbCard>
        <BbCardContent>
            <div class="form-grid">
            <div class="form-group">
                <BbLabel For="name">Name</BbLabel>
                <BbInput Id="name" @bind-Value="name" Placeholder="Acme Corp" />
            </div>
            <div class="form-group">
                <BbLabel For="slug">Slug</BbLabel>
                @if (IsNew)
                {
                    <BbInput Id="slug" @bind-Value="slug" Placeholder="acme" />
                }
                else
                {
                    <div><span class="mono">@slug</span></div>
                }
            </div>

            @if (!IsNew)
            {
                <div class="form-group">
                    <BbLabel For="enabled">Enabled</BbLabel>
                    @if (IsDefault)
                    {
                        <div><span class="badge-status badge-success">Enabled</span> <span class="text-muted" style="font-size:0.78rem;">(the default tenant cannot be disabled)</span></div>
                    }
                    else
                    {
                        <BbNativeSelect Id="enabled" @bind-Value="enabled">
                            <option value="true">Enabled</option>
                            <option value="false">Disabled</option>
                        </BbNativeSelect>
                        <p class="text-muted" style="font-size:0.78rem;margin-top:0.25rem;">Enabling a pending self-service signup also confirms and unlocks its admins.</p>
                    }
                </div>
                <div class="form-group col-span-full">
                    <BbLabel For="egress-ip-address">Outbound (sending) IP</BbLabel>
                    <BbInput Id="egress-ip-address" @bind-Value="egress" Placeholder="(OS default)" />
                    <p class="text-muted" style="font-size:0.78rem;margin-top:0.25rem;">Outbound mail for this tenant binds to this source IP. The host must own it; leave blank for the OS default.</p>
                    <div class="flex gap-1 items-center" style="margin-top:0.5rem;flex-wrap:wrap;">
                        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="DetectLocalIps">
                            <LucideIcon Name="search" /> Detect local IPs
                        </BbButton>
                        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="TestOutboundAsync" Disabled="@probing">
                            <LucideIcon Name="plug" /> @(probing ? "Testing…" : "Test outbound")
                        </BbButton>
                    </div>
                    @if (localIps.Count > 0)
                    {
                        <div style="margin-top:0.4rem;display:flex;gap:0.35rem;flex-wrap:wrap;align-items:center;">
                            <span class="text-muted" style="font-size:0.78rem;">Detected — click to use:</span>
                            @foreach (var ip in localIps)
                            {
                                <button type="button" class="badge-status badge-muted" style="cursor:pointer;border:none;" title="Use this IP" @onclick="@(() => egress = ip)">@ip</button>
                            }
                        </div>
                    }
                    @if (probeResults.Count > 0)
                    {
                        <div style="margin-top:0.4rem;font-size:0.78rem;line-height:1.5;">
                            <div class="text-muted">Outbound test from @(string.IsNullOrWhiteSpace(egress) ? "the OS-default IP" : egress):</div>
                            @foreach (var r in probeResults)
                            {
                                <div class="@(r.Ok ? "" : "text-danger")">@(r.Ok ? "✓" : "✗") @r.Label — @r.Message</div>
                            }
                        </div>
                    }
                </div>
                <div class="form-group">
                    <BbLabel>Created</BbLabel>
                    <div><LocalTime Utc="@createdUtc" Format="yyyy-MM-dd HH:mm" /></div>
                </div>
            }
            </div>
        </BbCardContent>
        <BbCardFooter>
            <div class="flex gap-1 items-center">
                <BbButton Variant="ButtonVariant.Default" @onclick="SaveAsync"
                        Disabled="@(string.IsNullOrWhiteSpace(name) || (IsNew && string.IsNullOrWhiteSpace(slug)))">
                    <LucideIcon Name="save" /> Save
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel">Cancel</BbButton>
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <span class="text-muted" style="margin-left:0.5rem">@statusMessage</span>
                }
            </div>
        </BbCardFooter>
    </BbCard>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => Id is null;
    private bool IsDefault => Id == TenantDefaults.DefaultTenantId;

    private bool isLoading = true;
    private bool notFound;
    private string? statusMessage;

    private string name = "";
    private string slug = "";
    private string enabled = "true";
    private string egress = "";
    private bool wasEnabled;
    private DateTimeOffset createdUtc;

    // Outbound-IP helpers: list the host's local IPv4s to pick from, and test outbound SMTP from the
    // chosen source IP so the operator can confirm it can actually reach the internet on the SMTP ports.
    private List<string> localIps = [];
    private bool probing;
    private readonly List<(bool Ok, string Label, string Message)> probeResults = [];

    private void DetectLocalIps() => localIps = [.. NetProbe.GetLocalIpv4Addresses()];

    private async Task TestOutboundAsync()
    {
        probing = true;
        probeResults.Clear();
        try
        {
            var src = string.IsNullOrWhiteSpace(egress) ? null : egress.Trim();
            var mx = await NetProbe.TestOutboundAsync(src, "gmail-smtp-in.l.google.com", 25);
            probeResults.Add((mx.Ok, "Port 25 → public MX (direct delivery)", mx.Message));
            var sub = await NetProbe.TestOutboundAsync(src, "smtp-relay.brevo.com", 587);
            probeResults.Add((sub.Ok, "Port 587 → Brevo (smart host)", sub.Message));
        }
        finally
        {
            probing = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (IsNew)
        {
            isLoading = false;
            return;
        }

        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        var t = await svc.GetByIdAsync(Id!.Value);
        if (t is null)
        {
            notFound = true;
            isLoading = false;
            return;
        }

        name = t.Name;
        slug = t.Slug;
        enabled = t.IsEnabled.ToString().ToLowerInvariant();
        wasEnabled = t.IsEnabled;
        egress = t.EgressIpAddress ?? "";
        createdUtc = t.CreatedUtc;
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();

        if (IsNew)
        {
            try
            {
                await svc.CreateAsync(name.Trim(), slug.Trim());
                Nav.NavigateTo("/tenants");
            }
            catch (InvalidOperationException ex)
            {
                statusMessage = ex.Message;
            }
            return;
        }

        var targetEnabled = IsDefault || enabled == "true";
        try
        {
            // Enabling a previously-disabled tenant approves a pending self-service signup
            // (confirms + unlocks its admins); the name is then applied via Update.
            if (targetEnabled && !wasEnabled)
            {
                var signup = scope.ServiceProvider.GetRequiredService<ITenantSignupService>();
                await signup.ApproveTenantAsync(Id!.Value);
                await svc.UpdateAsync(Id!.Value, name.Trim(), true);
            }
            else
            {
                await svc.UpdateAsync(Id!.Value, name.Trim(), targetEnabled);
            }

            await svc.SetEgressIpAsync(Id!.Value, string.IsNullOrWhiteSpace(egress) ? null : egress.Trim());
            Nav.NavigateTo("/tenants");
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
        }
    }

    private void Cancel() => Nav.NavigateTo("/tenants");
}

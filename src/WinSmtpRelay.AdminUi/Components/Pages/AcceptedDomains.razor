@page "/domains"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject ITenantScopeFactory ScopeFactory
@inject IRuntimeConfigCache ConfigCache
@inject IDnsSetupService DnsSetup

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Accepted Domains (Recipient)</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Accepted Domains (Recipient)</h1>
        <p>Recipient domains the relay accepts mail for. If empty, all recipient domains are accepted.</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About
    </BbButton>
</div>

<div style="max-width:400px;">
<BbCard Class="mb-1">
    <BbCardHeader>
        <BbCardTitle>Add Domain</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        <div class="form-group">
            <BbLabel>Domain</BbLabel>
            <BbInput @bind-Value="newDomain" Placeholder="example.com" />
        </div>
    </BbCardContent>
    <BbCardFooter>
        <BbButton Variant="ButtonVariant.Default" @onclick="CreateAsync"
                Disabled="@string.IsNullOrWhiteSpace(newDomain)">
            <LucideIcon Name="plus" /> Add
        </BbButton>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="text-muted" style="margin-left:1rem">@statusMessage</span>
        }
    </BbCardFooter>
</BbCard>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[200px] w-full" />
}
else
{
    <BbTable Data="@domains">
        <BbTableHeader>
            <BbTableRow TData="AcceptedDomain">
                <BbTableHeaderCell TData="AcceptedDomain">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Domain</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Added</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Ownership</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Actions</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (domains.Count == 0)
            {
                <BbTableRow TData="AcceptedDomain">
                    <BbTableCell colspan="5" style="text-align:center;">No accepted domains configured &mdash; all domains are accepted</BbTableCell>
                </BbTableRow>
            }
            @foreach (var d in domains)
            {
                <BbTableRow Item="@d">
                    <BbTableCell>@d.Id</BbTableCell>
                    <BbTableCell>@d.Domain</BbTableCell>
                    <BbTableCell><LocalTime Utc="@d.CreatedUtc" Format="yyyy-MM-dd" /></BbTableCell>
                    <BbTableCell>
                        @if (d.VerifiedUtc is not null)
                        {
                            <span class="badge-status" title="@($"Verified {d.VerifiedUtc:yyyy-MM-dd}")">Verified</span>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;gap:0.25rem;">
                                <div>
                                    <span class="badge-status badge-muted">Unverified</span>
                                    <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost"
                                            @onclick="() => VerifyAsync(d)" title="Check DNS now">
                                        <LucideIcon Name="shield-check" /> Verify
                                    </BbButton>
                                </div>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    Add this TXT record at <span class="mono">@d.Domain</span>:<br />
                                    <span class="mono">@DnsSetup.BuildOwnershipRecord(d.VerificationToken)</span>
                                </div>
                            </div>
                        }
                    </BbTableCell>
                    <BbTableCell>
                        <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost"
                                @onclick="() => { deleteTargetId = d.Id; showDeleteConfirm = true; }">
                            <LucideIcon Name="trash-2" />
                        </BbButton>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Domain</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will remove this domain from the accepted list. Mail for this domain will be rejected.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Accepted Domains (Recipient)</BbDialogTitle>
            <BbDialogDescription>Which recipient domains the relay will accept mail for</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>Accepted recipient domains define which recipient domain addresses the relay will accept during the SMTP <code>RCPT TO</code> command.</p>
            <p>If the list is <strong>empty</strong>, the relay accepts mail for <em>all</em> recipient domains (open relay for authenticated users).</p>
            <p>If one or more domains are listed, only recipients at those domains are accepted. All other recipient domain addresses are rejected with a 550 error.</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<AcceptedDomain> domains = [];
    private string newDomain = "";
    private string? statusMessage;
    private bool isLoading = true;
    private bool showHelp;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAcceptedDomainService>();
        domains = await svc.GetAllAsync();
        isLoading = false;
    }

    private async Task CreateAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAcceptedDomainService>();

        if (await svc.ExistsAsync(newDomain))
        {
            statusMessage = $"Domain '{newDomain}' is already in use";
            return;
        }

        try
        {
            await svc.CreateAsync(newDomain);
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
            return;
        }
        ConfigCache.Invalidate();
        statusMessage = $"Domain '{newDomain}' added";
        newDomain = "";
        await RefreshAsync();
    }

    private async Task VerifyAsync(AcceptedDomain d)
    {
        statusMessage = $"Checking DNS for {d.Domain}…";
        StateHasChanged();

        var verified = await DnsSetup.CheckOwnershipAsync(d.Domain, d.VerificationToken);
        if (verified)
        {
            using var scope = ScopeFactory.CreateScope();
            await scope.ServiceProvider.GetRequiredService<IAcceptedDomainService>().MarkVerifiedAsync(d.Id);
            ConfigCache.Invalidate();
            statusMessage = $"Ownership of {d.Domain} verified";
        }
        else
        {
            statusMessage = $"Verification TXT record for {d.Domain} not found yet (DNS can take time to propagate)";
        }
        await RefreshAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAcceptedDomainService>();
        await svc.DeleteAsync(deleteTargetId);
        ConfigCache.Invalidate();
        statusMessage = "Domain deleted";
        showDeleteConfirm = false;
        await RefreshAsync();
    }
}

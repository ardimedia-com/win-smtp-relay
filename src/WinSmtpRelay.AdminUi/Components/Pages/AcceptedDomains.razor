@page "/domains"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@attribute [Authorize(Policy = AuthorizationPolicies.AdminFull)]
@inject ITenantScopeFactory ScopeFactory
@inject IRuntimeConfigCache ConfigCache
@inject IDnsSetupService DnsSetup
@inject NavigationManager Nav

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Accepted Domains (Recipient)</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Accepted Domains (Recipient)</h1>
        <p>Recipient domains the relay accepts mail for. If empty, all recipient domains are accepted.</p>
    </div>
    <div class="flex gap-1 items-center">
        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="@(() => Nav.NavigateTo("/domains/new"))">
            <LucideIcon Name="plus" /> New domain
        </BbButton>
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
            <LucideIcon Name="info" /> About
        </BbButton>
    </div>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[200px] w-full" />
}
else
{
    <BbTable Data="@domains">
        <BbTableHeader>
            <BbTableRow TData="AcceptedDomain">
                <BbTableHeaderCell TData="AcceptedDomain">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Domain</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Added</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain">Ownership</BbTableHeaderCell>
                <BbTableHeaderCell TData="AcceptedDomain"></BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (domains.Count == 0)
            {
                <BbTableRow TData="AcceptedDomain">
                    <BbTableCell colspan="5" style="text-align:center;">No accepted domains configured &mdash; all domains are accepted</BbTableCell>
                </BbTableRow>
            }
            @foreach (var d in domains)
            {
                <BbTableRow Item="@d" class="list-row-clickable" @onclick="() => Edit(d.Id)">
                    <BbTableCell>@d.Id</BbTableCell>
                    <BbTableCell>@d.Domain</BbTableCell>
                    <BbTableCell><LocalTime Utc="@d.CreatedUtc" Format="yyyy-MM-dd" /></BbTableCell>
                    <BbTableCell>
                        @if (d.VerifiedUtc is not null)
                        {
                            <span class="badge-status" title="@($"Verified {d.VerifiedUtc:yyyy-MM-dd}")">Verified</span>
                        }
                        else
                        {
                            <span class="badge-status badge-muted">Unverified</span>
                        }
                    </BbTableCell>
                    <BbTableCell>
                        <div class="list-row-actions" @onclick:stopPropagation="true">
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Edit" @onclick="() => Edit(d.Id)">
                                <LucideIcon Name="pencil" />
                            </BbButton>
                            <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost" title="Delete"
                                    @onclick="() => { deleteTargetId = d.Id; showDeleteConfirm = true; }">
                                <LucideIcon Name="trash-2" />
                            </BbButton>
                        </div>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Domain</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will remove this domain from the accepted list. Mail for this domain will be rejected.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Accepted Domains (Recipient)</BbDialogTitle>
            <BbDialogDescription>Which recipient domains the relay will accept mail for</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>Accepted recipient domains define which recipient domain addresses the relay will accept during the SMTP <code>RCPT TO</code> command.</p>
            <p>If the list is <strong>empty</strong>, the relay accepts inbound mail for <em>all</em> recipient domains. This is <strong>not</strong> an open relay: delivering to an <em>external</em> (non-hosted) domain still requires SMTP authentication or an explicit allow-IP rule &mdash; a broad/&ldquo;any&rdquo; rule does not authorize relaying.</p>
            <p>If one or more domains are listed, only recipients at those domains are accepted. All other recipient domain addresses are rejected with a 550 error.</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<AcceptedDomain> domains = [];
    private bool isLoading = true;
    private bool showHelp;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAcceptedDomainService>();
        domains = await svc.GetAllAsync();
        isLoading = false;
    }

    private void Edit(int id) => Nav.NavigateTo($"/domains/{id}");

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAcceptedDomainService>();
        await svc.DeleteAsync(deleteTargetId);
        ConfigCache.Invalidate();
        showDeleteConfirm = false;
        await RefreshAsync();
    }
}

@page "/activity"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@implements IDisposable
@inject IActivityFeed Feed
@inject ICurrentTenant CurrentTenant

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Live Activity</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Live Activity</h1>
        <p>Real-time feed of SMTP connections, messages, and deliveries</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

<div style="margin-bottom:1rem;display:flex;align-items:center;gap:1rem;">
    <span class="badge-status badge-success">Live</span>
    <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Outline" @onclick="ClearFeed">
        <LucideIcon Name="eraser" />
        Clear
    </BbButton>
</div>

<div class="activity-feed">
    @if (events.Count == 0)
    {
        <p style="text-align:center;" class="text-muted">Waiting for activity...</p>
    }
    @foreach (var evt in events)
    {
        <div class="activity-item @evt.CssClass">
            <span class="activity-time"><LocalTime Utc="@evt.Timestamp" Format="HH:mm:ss" /></span>
            <span class="activity-icon">@evt.Icon</span>
            <span class="activity-text">@evt.Text</span>
        </div>
    }
</div>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Live Activity</BbDialogTitle>
            <BbDialogDescription>Real-time SMTP event monitoring</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                This page shows a real-time feed of what's happening on the SMTP relay, updated live as
                events occur on the server (no page refresh needed).
            </p>
            <h4 style="margin-top:1rem;">Event types</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>&gt;&gt;&gt; Message Received</strong> &mdash; an application submitted an email to the relay. Shows sender, recipients, and size.</li>
                <li><strong>&lt;&lt;&lt; Delivery Attempt</strong> &mdash; the relay tried to deliver a message. Shows the SMTP status code (250 = success) and the remote server used.</li>
                <li><strong>... SMTP Connection</strong> &mdash; a client connected to or disconnected from the SMTP listener.</li>
            </ul>
            <p>
                The feed holds up to 200 events and shows the activity your account is scoped to (a host
                admin in "All tenants" sees everything; otherwise just the selected tenant). Use
                <strong>Clear</strong> to reset.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private bool _disposed;
    private readonly List<FeedItem> events = [];
    private const int MaxEvents = 200;

    protected override void OnInitialized() => Feed.Received += OnActivity;

    private void OnActivity(ActivityEvent e)
    {
        if (_disposed || !IsForMe(e))
            return;

        var (icon, text, css) = e.Kind switch
        {
            ActivityKind.MessageReceived =>
                (">>>", $"Message received from {e.Sender} to {e.Recipients} ({e.SizeBytes} bytes)", "activity-received"),
            ActivityKind.DeliveryAttempt =>
                ("<<<", $"Delivery to {e.Recipient}: {e.StatusCode} via {e.RemoteServer}",
                    e.StatusCode == "250" ? "activity-delivered" : "activity-error"),
            ActivityKind.SmtpConnection =>
                ("...", $"SMTP {e.EventType} from {e.SourceIp}", "activity-connection"),
            _ => ("", "", "")
        };
        if (icon.Length == 0)
            return; // e.g. QueueChanged — not shown in this feed

        // Feed handlers run on the publisher's thread; marshal the list mutation AND the render onto the
        // circuit's dispatcher so the non-thread-safe List is only ever touched there.
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            events.Insert(0, new FeedItem(e.TimestampUtc, icon, text, css));
            if (events.Count > MaxEvents)
                events.RemoveAt(events.Count - 1);
            StateHasChanged();
        });
    }

    /// <summary>Show an event when it isn't tenant-scoped, or it matches this circuit's scope.</summary>
    private bool IsForMe(ActivityEvent e)
        => e.TenantId is null || CurrentTenant.IsHostScope || e.TenantId == CurrentTenant.TenantId;

    private void ClearFeed() => events.Clear();

    public void Dispose()
    {
        _disposed = true;
        Feed.Received -= OnActivity;
    }

    private record FeedItem(DateTimeOffset Timestamp, string Icon, string Text, string CssClass);
}

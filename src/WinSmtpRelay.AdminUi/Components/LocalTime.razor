@using WinSmtpRelay.AdminUi.Services
@implements IDisposable
@inject BrowserTimeService Time

@if (Utc is { } value)
{
    <span title="@($"{value:yyyy-MM-dd HH:mm:ss} UTC")">@Time.Format(value, Format)</span>
}
else
{
    @Null
}

@code {
    /// <summary>The UTC timestamp to display (null renders <see cref="Null"/>).</summary>
    [Parameter, EditorRequired] public DateTime? Utc { get; set; }

    /// <summary>.NET date/time format string applied after conversion to the browser's local time.</summary>
    [Parameter] public string Format { get; set; } = "yyyy-MM-dd HH:mm";

    /// <summary>Text shown when <see cref="Utc"/> is null.</summary>
    [Parameter] public string Null { get; set; } = "—";

    protected override void OnInitialized() => Time.Changed += OnTimeZoneResolved;

    private void OnTimeZoneResolved() => InvokeAsync(StateHasChanged);

    public void Dispose() => Time.Changed -= OnTimeZoneResolved;
}

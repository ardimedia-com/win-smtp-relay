@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Components.Endpoints
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WinSmtpRelay Admin</title>
    <base href="/" />
    <link rel="stylesheet" href="@Assets["_content/BlazorBlueprint.Components/blazorblueprint.css"]" />
    <link rel="stylesheet" href="@Assets["_content/WinSmtpRelay.AdminUi/css/theme.css"]" />
    <link rel="stylesheet" href="@Assets["_content/WinSmtpRelay.AdminUi/css/app.css"]" />
    <script>
        (function() {
            var mode = localStorage.getItem('winsmtprelay-theme');
            if (mode === 'dark') document.documentElement.classList.add('dark');
            var theme = localStorage.getItem('winsmtprelay-color-theme');
            if (theme) document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <ImportMap />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>
<body>
    <Routes @rendermode="PageRenderMode" />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["_content/WinSmtpRelay.AdminUi/js/theme.js"]"></script>
    <script src="@Assets["_content/WinSmtpRelay.AdminUi/js/interop.js"]"></script>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Account pages (login/logout/change-password) are marked [ExcludeFromInteractiveRouting]
    // so they render static SSR — required because cookie sign-in/out needs an unstarted
    // HTTP response (impossible over an established interactive circuit). Everything else
    // stays InteractiveServer.
    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? RenderMode.InteractiveServer : null;
}

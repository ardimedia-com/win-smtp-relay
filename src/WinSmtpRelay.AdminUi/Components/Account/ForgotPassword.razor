@page "/account/forgot-password"
@layout AccountLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.Extensions.Options
@using WinSmtpRelay.Core.Configuration
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject UserManager<AdminUser> UserManager
@inject IMessageQueue Queue
@inject IOptions<AdminUiOptions> UiOptions
@inject IPortalSettingsService PortalSettings
@inject NavigationManager Nav
@inject ILogger<ForgotPassword> Logger

@if (recoveryDisabled)
{
    <h1 class="account-title">Password reset unavailable</h1>
    <p class="account-subtitle">Email-based password reset is disabled on this server. Ask an administrator to reset your password.</p>
    <a class="account-button" href="/account/login">Back to sign in</a>
}
else if (submitted)
{
    <h1 class="account-title">Check your email</h1>
    <p class="account-subtitle">If an account exists for that address, we've sent a password reset link. The link expires after a short time.</p>
    <a class="account-button" href="/account/login">Back to sign in</a>
}
else
{
    <h1 class="account-title">Reset your password</h1>
    <p class="account-subtitle">Enter your account email and we'll send a reset link.</p>

    <EditForm Model="Input" method="post" OnValidSubmit="SubmitAsync" FormName="forgot-password">
        <DataAnnotationsValidator />
        <div class="account-field">
            <label for="email">Email</label>
            <InputText id="email" @bind-Value="Input.Email" autocomplete="username" class="account-input" />
            <ValidationMessage For="() => Input.Email" />
        </div>
        <button type="submit" class="account-button">Send reset link</button>
    </EditForm>

    <p class="account-subtitle" style="margin-top:1rem;text-align:center;">
        Remembered it? <a href="/account/login">Sign in</a>
    </p>
}

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private bool submitted;
    private bool recoveryDisabled;

    protected override async Task OnInitializedAsync()
        => recoveryDisabled = !(await PortalSettings.GetAsync()).EmailRecoveryEnabled;

    private async Task SubmitAsync()
    {
        if (recoveryDisabled)
            return;

        var email = Input.Email.Trim();
        var user = await UserManager.FindByEmailAsync(email);

        if (user is not null)
        {
            // Prefer the runtime (DB) from-address; fall back to the appsettings value.
            var from = (await PortalSettings.GetAsync()).SignupFromAddress;
            if (string.IsNullOrWhiteSpace(from))
                from = UiOptions.Value.SignupFromAddress;
            if (!string.IsNullOrWhiteSpace(from))
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var resetUrl = $"{Nav.BaseUri}account/reset-password?userId={user.Id}&token={Uri.EscapeDataString(token)}";
                var content = new WinSmtpRelay.Core.Mail.SystemEmailContent
                {
                    Title = "Reset your password",
                    Paragraphs =
                    [
                        "A password reset was requested for your WIN-SMTP-RELAY account.",
                        "Choose a new password using the link below.",
                    ],
                    ButtonText = "Reset password",
                    ActionUrl = resetUrl,
                    FooterNote = "If you did not request this, ignore this email.",
                };
                try
                {
                    await AccountEmail.EnqueueAsync(Queue, from, email, "Reset your WIN-SMTP-RELAY password", content,
                        TenantDefaults.DefaultTenantId);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to enqueue password-reset email for {Email}", email);
                }
            }
            else
            {
                Logger.LogWarning("Password reset requested for {Email} but AdminUi:SignupFromAddress is not configured — an administrator must reset it.", email);
            }

            Logger.LogInformation("Password reset requested for {Email}", email);
        }

        // Always show the same result — do not reveal whether the account exists.
        submitted = true;
    }

    private sealed class InputModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";
    }
}

@page "/account/reset-password"
@layout AccountLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@inject UserManager<AdminUser> UserManager
@inject ILogger<ResetPassword> Logger

<PageTitle>Set a new password — WIN-SMTP-RELAY</PageTitle>

@if (done)
{
    <h1 class="account-title">Password updated</h1>
    <p class="account-subtitle">Your password has been reset. You can now sign in.</p>
    <a class="account-button" href="/account/login">Sign in</a>
}
else
{
    <h1 class="account-title">Set a new password</h1>
    @if (errorMessage is not null)
    {
        <div class="account-error" role="alert">@errorMessage</div>
    }
    <EditForm Model="Input" method="post" OnValidSubmit="SubmitAsync" FormName="reset-password">
        <DataAnnotationsValidator />
        <input type="hidden" name="Input.UserId" value="@Input.UserId" />
        <input type="hidden" name="Input.Token" value="@Input.Token" />
        <div class="account-field">
            <label for="new">New password</label>
            <div class="password-field">
                <InputText id="new" type="password" @bind-Value="Input.NewPassword" autocomplete="new-password" class="account-input" />
                <PasswordToggle />
            </div>
            <ValidationMessage For="() => Input.NewPassword" />
        </div>
        <div class="account-field">
            <label for="confirm">Confirm new password</label>
            <div class="password-field">
                <InputText id="confirm" type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" class="account-input" />
                <PasswordToggle />
            </div>
            <ValidationMessage For="() => Input.ConfirmPassword" />
        </div>
        <button type="submit" class="account-button">Reset password</button>
    </EditForm>
}

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery(Name = "userId")]
    private int QueryUserId { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    private string? QueryToken { get; set; }

    private bool done;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        // On the initial GET, seed the hidden fields from the link; they then survive the POST.
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            Input.UserId = QueryUserId;
            Input.Token = QueryToken ?? "";
        }
    }

    private async Task SubmitAsync()
    {
        if (Input.UserId <= 0 || string.IsNullOrEmpty(Input.Token))
        {
            errorMessage = "This reset link is invalid or has expired.";
            return;
        }

        var user = await UserManager.FindByIdAsync(Input.UserId.ToString());
        if (user is null)
        {
            errorMessage = "This reset link is invalid or has expired.";
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Input.Token, Input.NewPassword);
        if (!result.Succeeded)
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        if (user.MustChangePassword)
        {
            user.MustChangePassword = false;
            await UserManager.UpdateAsync(user);
        }

        Logger.LogInformation("Password reset completed for admin {Email}", user.Email);
        done = true;
    }

    private sealed class InputModel
    {
        public int UserId { get; set; }
        public string Token { get; set; } = "";

        [Required, DataType(DataType.Password), MinLength(12, ErrorMessage = "Must be at least 12 characters.")]
        public string NewPassword { get; set; } = "";

        [Required, DataType(DataType.Password), Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}

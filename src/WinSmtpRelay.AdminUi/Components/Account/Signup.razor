@page "/signup"
@layout AccountLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@using System.Text
@using Microsoft.Extensions.Options
@using WinSmtpRelay.Core.Configuration
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject ITenantSignupService SignupService
@inject IMessageQueue Queue
@inject IOptions<AdminUiOptions> UiOptions
@inject WinSmtpRelay.AdminUi.Services.ISignupRateLimiter SignupRateLimiter
@inject NavigationManager Nav
@inject ILogger<Signup> Logger

<PageTitle>Sign up — WinSmtpRelay</PageTitle>

@if (!UiOptions.Value.SelfServiceSignupEnabled)
{
    <h1 class="account-title">Sign up unavailable</h1>
    <p class="account-subtitle">Self-service signup is disabled on this server. Contact an administrator.</p>
    <a class="account-button" href="/account/login">Back to sign in</a>
}
else if (submitted)
{
    <h1 class="account-title">Almost there</h1>
    <p class="account-subtitle">
        Your organization <strong>@Input.TenantName</strong> has been created and is pending activation.
        @if (emailed)
        {
            <text>We sent a verification link to <strong>@Input.Email</strong> — click it to activate your account.</text>
        }
        else
        {
            <text>An administrator will review and approve your account shortly.</text>
        }
    </p>
    <a class="account-button" href="/account/login">Go to sign in</a>
}
else
{
    <h1 class="account-title">Create your organization</h1>
    <p class="account-subtitle">Sign up for a tenant on this relay.</p>

    @if (errorMessage is not null)
    {
        <div class="account-error" role="alert">@errorMessage</div>
    }

    <EditForm Model="Input" method="post" OnValidSubmit="SubmitAsync" FormName="signup">
        <DataAnnotationsValidator />
        <div class="account-field">
            <label for="org">Organization name</label>
            <InputText id="org" @bind-Value="Input.TenantName" class="account-input" />
            <ValidationMessage For="() => Input.TenantName" />
        </div>
        <div class="account-field">
            <label for="slug">Identifier (slug)</label>
            <InputText id="slug" @bind-Value="Input.Slug" class="account-input" />
            <ValidationMessage For="() => Input.Slug" />
        </div>
        <div class="account-field">
            <label for="email">Admin email</label>
            <InputText id="email" @bind-Value="Input.Email" autocomplete="username" class="account-input" />
            <ValidationMessage For="() => Input.Email" />
        </div>
        <div class="account-field">
            <label for="password">Password</label>
            <InputText id="password" type="password" @bind-Value="Input.Password" autocomplete="new-password" class="account-input" />
            <ValidationMessage For="() => Input.Password" />
        </div>
        <div class="account-field">
            <label for="confirm">Confirm password</label>
            <InputText id="confirm" type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" class="account-input" />
            <ValidationMessage For="() => Input.ConfirmPassword" />
        </div>
        <button type="submit" class="account-button">Create organization</button>
    </EditForm>

    <p class="account-subtitle" style="margin-top:1rem;text-align:center;">
        Already have an account? <a href="/account/login">Sign in</a>
    </p>
}

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private string? errorMessage;
    private bool submitted;
    private bool emailed;

    private async Task SubmitAsync()
    {
        if (!UiOptions.Value.SelfServiceSignupEnabled)
            return;

        // Throttle abuse by client IP before creating anything.
        if (!SignupRateLimiter.TryRegister(HttpContext.Connection.RemoteIpAddress?.ToString()))
        {
            errorMessage = "Too many signup attempts from your network. Please try again later.";
            Logger.LogWarning("Signup throttled for IP {Ip}", HttpContext.Connection.RemoteIpAddress);
            return;
        }

        var result = await SignupService.SignUpAsync(Input.TenantName, Input.Slug, Input.Email, Input.Password);
        if (!result.Succeeded)
        {
            errorMessage = result.Error ?? "Signup failed.";
            return;
        }

        var fromAddress = UiOptions.Value.SignupFromAddress;
        if (!string.IsNullOrWhiteSpace(fromAddress) && result.ConfirmToken is not null)
        {
            var confirmUrl = $"{Nav.BaseUri}account/confirm?userId={result.UserId}&token={Uri.EscapeDataString(result.ConfirmToken)}";
            try
            {
                await EnqueueVerificationEmailAsync(fromAddress, Input.Email, confirmUrl, result.TenantId);
                emailed = true;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to enqueue signup verification email for {Email}", Input.Email);
            }
        }

        Logger.LogInformation("Self-service signup created tenant {TenantId} with admin {Email} (emailed={Emailed})",
            result.TenantId, Input.Email, emailed);
        submitted = true;
    }

    private async Task EnqueueVerificationEmailAsync(string from, string to, string confirmUrl, int tenantId)
    {
        var body =
            "Welcome to WinSmtpRelay.\r\n\r\n" +
            "Confirm your account by opening this link:\r\n" +
            confirmUrl + "\r\n\r\n" +
            "If you did not request this, ignore this email.\r\n";
        await AccountEmail.EnqueueAsync(Queue, from, to, "Verify your WinSmtpRelay account", body, tenantId);
    }

    private sealed class InputModel
    {
        [Required, StringLength(200)]
        public string TenantName { get; set; } = "";

        [Required, StringLength(100)]
        public string Slug { get; set; } = "";

        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required, DataType(DataType.Password), MinLength(12, ErrorMessage = "Must be at least 12 characters.")]
        public string Password { get; set; } = "";

        [Required, DataType(DataType.Password), Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}

@page "/account/change-password"
@layout AccountLayout
@attribute [Authorize]
@attribute [ExcludeFromInteractiveRouting]
@inject UserManager<AdminUser> UserManager
@inject SignInManager<AdminUser> SignInManager
@inject NavigationManager Nav
@inject ILogger<ChangePassword> Logger

<h1 class="account-title">Change password</h1>
<p class="account-subtitle">Choose a new password (at least 12 characters).</p>

@if (errorMessage is not null)
{
    <div class="account-error" role="alert">@errorMessage</div>
}

<EditForm Model="Input" method="post" OnValidSubmit="ChangeAsync" FormName="change-password">
    <DataAnnotationsValidator />
    @if (mustChange)
    {
        @* The current password is a temporary bootstrap credential to be replaced — and a user who
           arrived via a sign-in link never typed it. Don't require it; the authenticated session is proof. *@
        <div class="account-info" role="note">
            You're signed in with a temporary password. Choose a new one below — no current password needed.
        </div>
    }
    else
    {
        <div class="account-field">
            <label for="current">Current password</label>
            <div class="password-field">
                <InputText id="current" type="password" @bind-Value="Input.CurrentPassword" autocomplete="current-password" class="account-input" />
                <PasswordToggle />
            </div>
            <ValidationMessage For="() => Input.CurrentPassword" />
        </div>
    }
    <div class="account-field">
        <label for="new">New password</label>
        <div class="password-field">
            <InputText id="new" type="password" @bind-Value="Input.NewPassword" autocomplete="new-password" class="account-input" />
            <PasswordToggle />
        </div>
        <ValidationMessage For="() => Input.NewPassword" />
    </div>
    <div class="account-field">
        <label for="confirm">Confirm new password</label>
        <div class="password-field">
            <InputText id="confirm" type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" class="account-input" />
            <PasswordToggle />
        </div>
        <ValidationMessage For="() => Input.ConfirmPassword" />
    </div>
    <button type="submit" class="account-button">Change password</button>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private string? errorMessage;

    // True when the signed-in account is on a temporary password it must replace. In that state we do NOT
    // ask for the current password (it may have been reached via a sign-in link, where it was never typed).
    private bool mustChange;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        mustChange = user?.MustChangePassword ?? false;
    }

    private async Task ChangeAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            Nav.NavigateTo("/account/login", forceLoad: true);
            return;
        }

        IdentityResult result;
        if (user.MustChangePassword)
        {
            // Forced first change: set the new password without the (temporary) current one. A reset token
            // validates the new password against policy and is atomic; it also rolls the security stamp,
            // which RefreshSignInAsync below re-issues into the cookie so this session stays valid.
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            result = await UserManager.ResetPasswordAsync(user, token, Input.NewPassword);
        }
        else
        {
            // Voluntary change: keep the current-password re-auth guard.
            if (string.IsNullOrEmpty(Input.CurrentPassword))
            {
                errorMessage = "Enter your current password.";
                return;
            }
            result = await UserManager.ChangePasswordAsync(user, Input.CurrentPassword, Input.NewPassword);
        }

        if (!result.Succeeded)
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        if (user.MustChangePassword)
        {
            user.MustChangePassword = false;
            await UserManager.UpdateAsync(user);
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("Admin {Email} changed password", user.Email);

        Nav.NavigateTo("/");
    }

    private sealed class InputModel
    {
        // Not [Required]: omitted on a forced temporary-password change (see mustChange). The voluntary
        // path validates its presence itself.
        [DataType(DataType.Password)]
        public string CurrentPassword { get; set; } = "";

        [Required, DataType(DataType.Password), MinLength(12, ErrorMessage = "Must be at least 12 characters.")]
        public string NewPassword { get; set; } = "";

        [Required, DataType(DataType.Password), Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}

@page "/account/login"
@layout AccountLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@inject SignInManager<AdminUser> SignInManager
@inject WinSmtpRelay.Core.Interfaces.IRuntimeConfigCache ConfigCache
@inject NavigationManager Nav
@inject ILogger<Login> Logger
@inject WinSmtpRelay.Core.Interfaces.IPortalSettingsService PortalSettings

<h1 class="account-title">Sign in</h1>
<p class="account-subtitle">Enter your administrator credentials.</p>

@if (showInitialHint)
{
    <div role="note" style="border:1px solid var(--border);border-radius:6px;padding:0.6rem 0.8rem;margin-bottom:1rem;font-size:0.82rem;line-height:1.5;background:var(--muted);color:var(--foreground);">
        <strong>First run?</strong> Sign in as <code>admin@local</code>.
        @if (passwordFileExists)
        {
            <text>
                The initial password is in this file on the server:<br />
                <a href="@passwordFileUrl"><code>@passwordFilePath</code></a><br />
                <span style="color:var(--muted-foreground);">If your browser blocks opening it, copy that path into Windows Explorer. The file is removed automatically once you change the password.</span>
            </text>
        }
        else
        {
            <text>The one-time initial password is in the <strong>Windows Event Log</strong> (Application, source <code>WinSmtpRelay.Service</code>) — entry &ldquo;INITIAL ADMIN ACCOUNT CREATED&rdquo;.</text>
        }
        You&rsquo;ll be asked to change it on sign-in.
    </div>
}

@if (errorMessage is not null)
{
    <div class="account-error" role="alert">@errorMessage</div>
}

<EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
    <DataAnnotationsValidator />
    <div class="account-field">
        <label for="email">Email</label>
        <InputText id="email" @bind-Value="Input.Email" autocomplete="username" class="account-input" />
        <ValidationMessage For="() => Input.Email" />
    </div>
    <div class="account-field">
        <label for="password">Password</label>
        <div class="password-field">
            <InputText id="password" type="password" @bind-Value="Input.Password" autocomplete="current-password" class="account-input" />
            <PasswordToggle />
        </div>
        <ValidationMessage For="() => Input.Password" />
    </div>
    <label class="account-checkbox">
        <InputCheckbox @bind-Value="Input.RememberMe" /> Keep me signed in
    </label>
    <button type="submit" class="account-button">Sign in</button>
</EditForm>

<p class="account-subtitle" style="margin-top:1rem;text-align:center;">
    <a href="/account/forgot-password">Forgot your password?</a>
</p>

@if (signupEnabled)
{
    <p class="account-subtitle" style="margin-top:1rem;text-align:center;">
        No account? <a href="/signup">Create an organization</a>
    </p>
}

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? errorMessage;
    private bool signupEnabled;
    private bool showInitialHint;
    private bool passwordFileExists;
    private string passwordFilePath = "";
    private string passwordFileUrl = "";

    protected override async Task OnInitializedAsync()
    {
        signupEnabled = (await PortalSettings.GetAsync()).SelfServiceSignupEnabled;

        // First-run hint: surface where the one-time initial password is. The seeder writes it to a file
        // next to the binaries (deleted on first password change); link to it while it exists, otherwise
        // point at the Event Log. Also show the hint while the seeded admin still must change its password.
        passwordFilePath = Path.Combine(AppContext.BaseDirectory, WinSmtpRelay.Core.AdminBootstrap.PasswordFileName);
        passwordFileExists = File.Exists(passwordFilePath);
        if (passwordFileExists)
            passwordFileUrl = new Uri(passwordFilePath).AbsoluteUri;

        var seeded = await SignInManager.UserManager.FindByNameAsync(WinSmtpRelay.Core.AdminBootstrap.InitialAdminEmail);
        showInitialHint = passwordFileExists || seeded is { MustChangePassword: true };
    }

    private async Task LoginUser()
    {
        // Validate the password without issuing the cookie yet, so a disabled tenant
        // can be blocked after a correct password (avoids revealing valid credentials
        // for an account whose tenant is disabled).
        var user = await SignInManager.UserManager.FindByNameAsync(Input.Email);
        if (user is not null)
        {
            var check = await SignInManager.CheckPasswordSignInAsync(user, Input.Password, lockoutOnFailure: true);
            if (check.Succeeded)
            {
                if (user.TenantId is int tenantId && !await ConfigCache.IsTenantEnabledAsync(tenantId))
                {
                    errorMessage = "Your organization's account is disabled. Contact an administrator.";
                    Logger.LogWarning("Sign-in blocked for {Email}: tenant {TenantId} is disabled", Input.Email, tenantId);
                    return;
                }

                await SignInManager.SignInAsync(user, Input.RememberMe);
                Logger.LogInformation("Admin {Email} signed in", Input.Email);
                Nav.NavigateTo(GetSafeReturnUrl());
                return;
            }

            if (check.IsLockedOut)
            {
                errorMessage = "Account locked due to too many failed attempts. Try again later.";
                Logger.LogWarning("Failed admin sign-in for {Email} (lockedOut=True)", Input.Email);
                return;
            }
        }

        errorMessage = "Invalid email or password.";
        Logger.LogWarning("Failed admin sign-in for {Email}", Input.Email);
    }

    // Prevent open redirects: only allow local relative paths.
    private string GetSafeReturnUrl()
    {
        if (!string.IsNullOrEmpty(ReturnUrl) && Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative) && ReturnUrl.StartsWith('/') && !ReturnUrl.StartsWith("//"))
            return ReturnUrl;
        return "/";
    }

    private sealed class InputModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required, DataType(DataType.Password)]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}

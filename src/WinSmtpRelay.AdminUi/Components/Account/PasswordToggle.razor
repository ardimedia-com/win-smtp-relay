@* Show/hide toggle for the immediately-preceding password input. Account pages render as
   static SSR (no interactive circuit), so this uses a plain inline onclick — no Blazor handler,
   no JS load-order or enhanced-navigation dependency. Place directly after the password input
   inside a .password-field wrapper. *@
<button type="button" class="password-toggle" tabindex="-1" aria-label="Show or hide password"
        onclick="var i=this.previousElementSibling; if(i){i.type=i.type==='password'?'text':'password';this.classList.toggle('revealed');}">
    <svg class="eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
    <svg class="eye-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
</button>

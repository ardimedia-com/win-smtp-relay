@inject NavigationManager Nav
@attribute [AllowAnonymous]

@code {
    protected override void OnInitialized()
    {
        var returnUrl = Uri.EscapeDataString(new Uri(Nav.Uri).PathAndQuery);
        // forceLoad: the login page renders static SSR, so it must be reached via a full
        // navigation rather than interactive routing.
        Nav.NavigateTo($"/account/login?returnUrl={returnUrl}", forceLoad: true);
    }
}

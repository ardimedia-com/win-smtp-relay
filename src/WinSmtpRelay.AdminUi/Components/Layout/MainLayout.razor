@inherits LayoutComponentBase
@using WinSmtpRelay.Core.Interfaces
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ICurrentTenant CurrentTenant
@inject WinSmtpRelay.AdminUi.Services.BrowserTimeService BrowserTime
@inject IPortalSettingsService PortalSettings
@inject Microsoft.Extensions.Options.IOptions<WinSmtpRelay.Core.Configuration.AdminUiOptions> UiOptions

@* Constant browser-tab title for every interactive page. Without an always-rendered PageTitle, the
   interactive HeadOutlet blanks the document title on navigation and the browser falls back to the URL
   (e.g. "localhost:8025/update"). Static SSR account pages keep the static <title> in App.razor. *@
<PageTitle>WIN-SMTP-RELAY</PageTitle>

<BbTooltipProvider>
<BbSidebarProvider DefaultOpen="true">
    <BbSidebar>
        <BbSidebarHeader>
            <BbSidebarHeaderContent>
                <BbSidebarHeaderInfo>
                    <span style="font-weight:600;font-size:1.1rem;">WIN-SMTP-RELAY</span>
                </BbSidebarHeaderInfo>
            </BbSidebarHeaderContent>
        </BbSidebarHeader>

        <BbSidebarContent>
            @* Monitoring — meaningful in any scope (host = aggregate across all tenants, tenant = scoped). *@
            <BbSidebarGroup>
                <BbSidebarGroupLabel>Monitor</BbSidebarGroupLabel>
                <BbSidebarMenu>
                    <BbSidebarMenuItem>
                        <BbSidebarMenuButton Href="/" Match="NavLinkMatch.All">
                            <LucideIcon Name="layout-dashboard" />
                            <span>Dashboard</span>
                        </BbSidebarMenuButton>
                    </BbSidebarMenuItem>
                    <BbSidebarMenuItem>
                        <BbSidebarMenuButton Href="activity">
                            <LucideIcon Name="activity" />
                            <span>Live Activity</span>
                        </BbSidebarMenuButton>
                    </BbSidebarMenuItem>
                    <BbSidebarMenuItem>
                        <BbSidebarMenuButton Href="queue">
                            <LucideIcon Name="inbox" />
                            <span>Queue</span>
                        </BbSidebarMenuButton>
                    </BbSidebarMenuItem>
                    <BbSidebarMenuItem>
                        <BbSidebarMenuButton Href="journal">
                            <LucideIcon Name="book-open" />
                            <span>Journal</span>
                        </BbSidebarMenuButton>
                    </BbSidebarMenuItem>
                </BbSidebarMenu>
            </BbSidebarGroup>

            @* Per-tenant configuration — only meaningful when a specific tenant is in scope. In the
               "All tenants" (host) view these are hidden; select a tenant in the switcher to manage them. *@
            @* Setup and Deliverability are viewable read-only (the pages gate their write actions
               internally); the remaining items are write-capable, so they are gated to AdminFull
               (the detail pages enforce the same policy). *@
            @if (IsTenantScope)
            {
                <BbSidebarGroup>
                    <BbSidebarGroupLabel>Configuration</BbSidebarGroupLabel>
                    <BbSidebarMenu>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="setup">
                                <LucideIcon Name="list-checks" />
                                <span>Setup</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="deliverability">
                                <LucideIcon Name="mail-check" />
                                <span>Deliverability</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <AuthorizeView Policy="@AuthorizationPolicies.AdminFull" Context="cfgAuth">
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="connectors/send">
                                <LucideIcon Name="send" />
                                <span>Send Connectors</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="domains/sender">
                                <LucideIcon Name="at-sign" />
                                <span>Accepted Domains (Sender)</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="domains">
                                <LucideIcon Name="globe" />
                                <span>Accepted Domains (Recipient)</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="ip-rules">
                                <LucideIcon Name="shield" />
                                <span>IP Access Rules</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        @* DKIM key management is host-admin-gated (interim). *@
                        <AuthorizeView Policy="@AuthorizationPolicies.HostAdmin" Context="dkimAuth">
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="dkim">
                                    <LucideIcon Name="shield-check" />
                                    <span>DKIM</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                        </AuthorizeView>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="filters">
                                <LucideIcon Name="filter" />
                                <span>Message Filters</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="smtpusers">
                                <LucideIcon Name="users" />
                                <span>SMTP Users</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="suppressions">
                                <LucideIcon Name="ban" />
                                <span>Suppression List</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        </AuthorizeView>
                    </BbSidebarMenu>
                </BbSidebarGroup>
            }

            @* Account & access management — full admins only. Admin Users is meaningful in both scopes
               (host administrators in the "All tenants" overview; the selected tenant's admins in a tenant
               scope). API keys are per-tenant, so they appear only when a specific tenant is selected. *@
            <AuthorizeView Policy="@AuthorizationPolicies.AdminFull" Context="acctAuth">
                <BbSidebarGroup>
                    <BbSidebarGroupLabel>Users & Access</BbSidebarGroupLabel>
                    <BbSidebarMenu>
                        <BbSidebarMenuItem>
                            <BbSidebarMenuButton Href="adminusers">
                                <LucideIcon Name="user-cog" />
                                <span>Admin Users</span>
                            </BbSidebarMenuButton>
                        </BbSidebarMenuItem>
                        @if (IsTenantScope)
                        {
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="apikeys">
                                    <LucideIcon Name="key-round" />
                                    <span>API Keys</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                        }
                    </BbSidebarMenu>
                </BbSidebarGroup>
            </AuthorizeView>

            @* Global administration — host-wide, NOT per-tenant: host operations (Tenants, Signup, Event
               Log) and server configuration (Settings, cert, listener, rate limits, startup, Update).
               Shown to host admins in ANY scope and set apart with a tinted background, so global config is
               visually distinct from the per-tenant groups above. In a single-tenant deployment the host
               admin is auto-scoped to the sole tenant, so this sits in one merged view with the tenant
               groups; the pages are also HostAdmin-gated at their routes. *@
            <AuthorizeView Policy="@AuthorizationPolicies.HostAdmin" Context="globalAuth">
                <div class="sidebar-global">
                    <BbSidebarGroup>
                        <BbSidebarGroupLabel>Host</BbSidebarGroupLabel>
                        <BbSidebarMenu>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="tenants">
                                    <LucideIcon Name="building-2" />
                                    <span>Tenants</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="host/signup">
                                    <LucideIcon Name="user-plus" />
                                    <span>Signup</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="logs">
                                    <LucideIcon Name="file-text" />
                                    <span>Event Log</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                        </BbSidebarMenu>
                    </BbSidebarGroup>

                    <BbSidebarGroup>
                        <BbSidebarGroupLabel>Server</BbSidebarGroupLabel>
                        <BbSidebarMenu>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="settings">
                                    <LucideIcon Name="settings" />
                                    <span>Settings</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="settings/certificate">
                                    <LucideIcon Name="lock" />
                                    <span>HTTPS Certificate</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="connectors/receive">
                                    <LucideIcon Name="plug" />
                                    <span>Receive Connectors</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="rate-limits">
                                    <LucideIcon Name="gauge" />
                                    <span>Rate Limits</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="startupconfig">
                                    <LucideIcon Name="file-cog" />
                                    <span>Startup Config</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                            <BbSidebarMenuItem>
                                <BbSidebarMenuButton Href="update">
                                    <LucideIcon Name="download" />
                                    <span>Update</span>
                                </BbSidebarMenuButton>
                            </BbSidebarMenuItem>
                        </BbSidebarMenu>
                    </BbSidebarGroup>
                </div>
            </AuthorizeView>
        </BbSidebarContent>

        <BbSidebarFooter>
            <span class="text-muted" style="font-size:0.75rem;">Admin Panel</span>
        </BbSidebarFooter>
    </BbSidebar>

    <BbSidebarInset>
        <header style="display:flex;align-items:center;gap:0.5rem;padding:0.75rem 2rem;border-bottom:1px solid var(--border);">
            <BbSidebarTrigger />
            <ThemeToggle />
            <div style="margin-left:auto;display:flex;align-items:center;gap:1rem;">
                <TenantSwitcher />
                <AuthorizeView>
                    <Authorized>
                        <a href="/account/profile" class="header-user-link" title="Your account — @context.User.Identity?.Name">@context.User.Identity?.Name</a>
                        <form action="/account/logout" method="post" style="margin:0;">
                            <AntiforgeryToken />
                            <button type="submit" class="logout-button" title="Sign out">
                                <LucideIcon Name="log-out" Size="16" />
                                <span>Sign out</span>
                            </button>
                        </form>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>
        <AuthorizeView Context="auth">
            <Authorized>
                @if (auth.User.HasClaim(RelayClaimTypes.MustChangePassword, "true"))
                {
                    <div class="must-change-banner" role="alert">
                        <LucideIcon Name="triangle-alert" Size="16" />
                        <span>You are signed in with a temporary password.</span>
                        <a href="/account/change-password">Change it now</a>
                    </div>
                }
                else if (systemEmailUnconfigured)
                {
                    <div class="must-change-banner" role="alert">
                        <LucideIcon Name="triangle-alert" Size="16" />
                        <span>No from-address is set for system emails — password-reset and sign-in-link emails won't be sent.</span>
                        <a href="/host/signup">Configure it</a>
                    </div>
                }
            </Authorized>
        </AuthorizeView>
        <main style="flex:1;padding:2rem;overflow-y:auto;">
            @if (IsHostScope && IsTenantOnlyRoute)
            {
                @* Direct-URL guard for per-tenant pages in the global view: the EF tenant filter is off
                   in host scope, so these pages would render all tenants' rows merged, and a create would
                   silently land in the Default tenant. The nav already hides them; this covers the URL. *@
                <div class="page-header">
                    <h1>Select an organization</h1>
                    <p>This page manages one organization's configuration. You are in the global (all-tenants)
                       view — pick an organization in the switcher at the top right, then return here.</p>
                </div>
            }
            else
            {
                @Body
            }
        </main>
    </BbSidebarInset>
</BbSidebarProvider>
</BbTooltipProvider>

<BbPortalHost />

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // Nav visibility is driven by scope (the tenant switcher, which is host-admin-only):
    //   IsHostScope   = the "All tenants" overview — a consolidated, cross-tenant cockpit: monitoring
    //                   (Dashboard, Live Activity, Queue, Journal) plus host operations (Admin Users,
    //                   Tenants, Event Log). Only a host admin can enter it.
    //   IsTenantScope = a specific tenant is selected (a host admin who picked one, or a tenant
    //                   admin/viewer, who is always scoped to their own tenant). This is the
    //                   "configuration" view: that tenant's Setup/Deliverability/Configuration/API keys,
    //                   plus — for a host admin only — the server-wide Server group.
    // The two are mutually exclusive. Host-only items (Server group, Host group) are additionally
    // HostAdmin-gated by role, so a tenant admin/viewer never sees them even within a tenant scope.
    private bool IsHostScope => CurrentTenant.IsHostScope;
    private bool IsTenantScope => CurrentTenant.TenantId is not null;

    // Routes that only make sense with a tenant in scope — they list/create tenant-owned entities.
    // Kept next to the nav above: a route hidden from the nav in host scope belongs in this list.
    private static readonly string[] TenantOnlyRoutePrefixes =
    [
        "setup", "deliverability", "health",
        "connectors/send", "domains", "dkim", "ip-rules", "filters",
        "smtpusers", "suppressions", "apikeys",
    ];

    private bool IsTenantOnlyRoute
    {
        get
        {
            var rel = Nav.ToBaseRelativePath(Nav.Uri);
            var cut = rel.IndexOfAny(['?', '#']);
            if (cut >= 0) rel = rel[..cut];
            rel = rel.TrimEnd('/');
            return TenantOnlyRoutePrefixes.Any(p =>
                rel.Equals(p, StringComparison.OrdinalIgnoreCase) ||
                rel.StartsWith(p + "/", StringComparison.OrdinalIgnoreCase));
        }
    }

    private bool systemEmailUnconfigured;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
            return;

        // Hard-enforce the temporary-password change: a user signed in with a
        // must-change password may only reach the change-password page (which uses
        // AccountLayout, so this layout — and thus this redirect — never runs there).
        var state = await AuthState;
        if (state.User.HasClaim(RelayClaimTypes.MustChangePassword, "true"))
        {
            Nav.NavigateTo("/account/change-password", forceLoad: true);
            return;
        }

        // Operability nudge for host admins: if no from-address is configured, the relay silently can't
        // send its own emails (password reset, sign-in links, signup verification). Surface it so it isn't
        // discovered only by "I clicked the button and nothing arrived". Self-clears once configured.
        if (state.User.HasClaim(RelayClaimTypes.IsHostAdmin, "true"))
        {
            var from = (await PortalSettings.GetAsync()).SignupFromAddress;
            if (string.IsNullOrWhiteSpace(from))
                from = UiOptions.Value.SignupFromAddress;
            systemEmailUnconfigured = string.IsNullOrWhiteSpace(from);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Detect the browser time zone (once per circuit) so UTC timestamps render in local time.
        // Retry on every render until it resolves: a single attempt on the first interactive render can
        // miss if JS interop isn't ready yet, which would otherwise leave every timestamp stuck in UTC
        // for the whole session.
        if (BrowserTime.IsReady)
            return;
        try
        {
            var iana = await JS.InvokeAsync<string>("winSmtpRelay.getTimeZoneName");
            var offset = await JS.InvokeAsync<int>("winSmtpRelay.getTimeZoneOffsetMinutes");
            BrowserTime.SetTimeZone(iana, offset);
        }
        catch { /* leave timestamps in UTC until interop becomes available on a later render */ }
    }
}

@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject IServiceScopeFactory ScopeFactory

@* Shown when there is more than one tenant. A single-tenant deployment has no use for the host/tenant
   scope split (the host admin is auto-scoped to the sole tenant), so the switcher is hidden — EXCEPT
   when the admin is currently in host scope anyway: after deleting the second-to-last tenant the cookie
   has no ActiveTenant pin until the security-stamp validator regenerates the principal (up to ~30 min),
   and without the switcher there would be no way to reach tenant scope (Setup, Deliverability, …). *@
<AuthorizeView Policy="@AuthorizationPolicies.HostAdmin">
    <Authorized>
        @if (tenants.Count > 1 || (tenants.Count == 1 && activeTenantId is null))
        {
            <form action="/account/switch-tenant" method="post" style="margin:0;">
                <AntiforgeryToken />
                <label class="tenant-switcher">
                    <LucideIcon Name="building-2" Size="14" />
                    <select name="tenant" aria-label="Tenant scope" onchange="this.form.submit()">
                        <option value="all" selected="@(activeTenantId is null)">Global</option>
                        @foreach (var t in tenants)
                        {
                            <option value="@t.Id" selected="@(activeTenantId == t.Id)">@(t.Name == "Default" ? "Default tenant" : t.Name)</option>
                        }
                    </select>
                </label>
            </form>
        }
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<Tenant> tenants = [];
    private int? activeTenantId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
            return;

        var user = (await AuthState).User;
        if (!user.HasClaim(RelayClaimTypes.IsHostAdmin, "true"))
            return;

        if (int.TryParse(user.FindFirst(RelayClaimTypes.ActiveTenant)?.Value, out var id))
            activeTenantId = id;

        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ITenantService>();
        tenants = await svc.GetAllAsync();
    }
}

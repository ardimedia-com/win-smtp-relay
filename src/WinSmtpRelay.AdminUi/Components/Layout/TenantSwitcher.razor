@using WinSmtpRelay.Core.Authorization
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject IServiceScopeFactory ScopeFactory

@* Shown when the principal can be in more than one scope. A host admin sees "Global" plus the tenants
   they are a member of; a tenant user sees the tenants they are a member of. To reach a tenant they are
   not a member of, a host admin uses break-glass (Host → Tenants), which creates the membership. *@
@if (options.Count > 1)
{
    <form action="/account/switch-tenant" method="post" style="margin:0;">
        <AntiforgeryToken />
        <label class="tenant-switcher">
            <LucideIcon Name="building-2" Size="14" />
            <select name="tenant" aria-label="Tenant scope" onchange="this.form.submit()">
                @foreach (var o in options)
                {
                    <option value="@o.Value" selected="@o.Selected">@o.Label</option>
                }
            </select>
        </label>
    </form>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private sealed record Option(string Value, string Label, bool Selected);

    private List<Option> options = [];

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
            return;

        var user = (await AuthState).User;
        if (user.Identity?.IsAuthenticated != true)
            return;

        var hasHost = RelayAccess.HasHostMembership(user);
        var memberIds = RelayAccess.TenantMemberships(user).Keys.ToHashSet();
        var active = RelayAccess.ActiveTenant(user);

        using var scope = ScopeFactory.CreateScope();
        var tenants = await scope.ServiceProvider.GetRequiredService<ITenantService>().GetAllAsync();

        var opts = new List<Option>();
        if (hasHost)
            opts.Add(new Option("all", "Global", active is null));
        foreach (var t in tenants.Where(t => memberIds.Contains(t.Id)))
            opts.Add(new Option(t.Id.ToString(), t.Name == "Default" ? "Default tenant" : t.Name, active == t.Id));
        options = opts;
    }
}
